{% extends "layout.twig" %}
{% block title %}Pages - {{ app_settings.site_name|default("Site") }}{% endblock %}
{% set breadcrumbs = [{"label": "Pages", "url": "/pages", "icon": "file"}] %}
{% block content %}
  <!-- Hero Section -->
  <section class="hero-section pages-list-hero position-relative py-5 mb-4 overflow-hidden inl-p-0014">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <h1 class="display-4 fw-bold text-white mb-3">
            <i class="bi bi-file-earmark-text me-2"></i>Pages
          </h1>
          <p class="lead text-white-50 fs-5">Browse site pages and documents</p>
        </div>
        <div class="col-lg-4 text-center">
          <div class="hero-icon inl-p-0047">📄</div>
        </div>
      </div>
    </div>
  </section>
  <div class="container py-5 pages-list-page">
    <!-- Page Header -->
    <div class="listing-header">
      <h1>
        <i class="bi bi-journal-text text-primary me-2"></i>{{ title|default("Pages") }}
      </h1>
    </div>
    <!-- Filter Card -->
    <div class="filter-card">
      <div class="filter-group">
        <!-- Search -->
        <div class="filter-section inl-p-0008">
          <form method="get" class="inl-p-0009">
            <input type="text"
                   name="search"
                   value="{{ search|default("") }}"
                   class="search-input"
                   placeholder="Search pages...">
            <button type="submit" class="btn-search">
              <i class="bi bi-search"></i>
            </button>
          </form>
        </div>
        <!-- Per Page -->
        <div class="filter-section">
          <label>Per Page</label>
          <form method="get">
            <select name="per_page" class="filter-select" onchange="this.form.submit()">
              {% for opt in available_per_page|default([6, 12, 18, 24, 36, 60]) %}
                <option value="{{ opt }}" {% if per_page == opt %}selected{% endif %}>{{ opt }}</option>
              {% endfor %}
            </select>
          </form>
        </div>
        <!-- Sort -->
        <div class="filter-section">
          <label>Sort By</label>
          <form method="get">
            <select name="sort" class="filter-select" onchange="this.form.submit()">
              <option value="latest" {% if sort == 'latest' %}selected{% endif %}>Latest</option>
              <option value="oldest" {% if sort == 'oldest' %}selected{% endif %}>Oldest</option>
              <option value="views" {% if sort == 'views' %}selected{% endif %}>Most Views</option>
              <option value="impressions" {% if sort == 'impressions' %}selected{% endif %}>Most Impressions</option>
            </select>
          </form>
        </div>
      </div>
    </div>
    <!-- Pages Grid -->
    {% if pages is not empty %}
      <div class="listing-grid">
        {% for page in pages %}
          {% include 'partials/content-card.twig' with { item: {
          images: page.images|default([]),
          image: page.image|default(page.thumbnail|default(page.image_path|default(null))),
          title: page.title|default('Untitled'),
          subtitle: page.excerpt|default(page.content|default('')|striptags|slice(0, 120) ~ '...'),
          categories: page.categories|default([]),
          tags: page.tags|default([]),
          created_at: page.created_at|default(''),
          url: page.slug|default(page.id),
          slug: page.slug|default(page.id),
          id: page.id,
          type: 'page',
          impressions: page.impressions|default(0),
          views: page.views|default(0)
          }, index: loop.index } %}
        {% endfor %}
      </div>
      <!-- Pagination -->
      {% if total_pages > 1 %}
        <div class="pagination-container">
          <div class="pagination">
            {% if current_page > 1 %}
              <a class="pagination-link"
                 href="?page={{ current_page - 1 }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}"
                 aria-label="Previous">
                <i class="bi bi-chevron-left"></i>
              </a>
            {% else %}
              <span class="pagination-link disabled"><i class="bi bi-chevron-left"></i></span>
            {% endif %}
            {% for p in 1..total_pages %}
              <a class="pagination-link {% if p == current_page %}active{% endif %}"
                 href="?page={{ p }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}">{{ p }}</a>
            {% endfor %}
            {% if current_page < total_pages %}
              <a class="pagination-link"
                 href="?page={{ current_page + 1 }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}"
                 aria-label="Next">
                <i class="bi bi-chevron-right"></i>
              </a>
            {% else %}
              <span class="pagination-link disabled"><i class="bi bi-chevron-right"></i></span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% else %}
      <div class="empty-state">
        <i class="bi bi-journal-text"></i>
        <h3>No pages found</h3>
        <p>Try adjusting your search criteria</p>
      </div>
    {% endif %}
  </div>
{% endblock %}
