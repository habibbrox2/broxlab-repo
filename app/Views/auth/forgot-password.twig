{% extends "layout.twig" %}
{% import '_macros/flash.twig' as flash_macros %}
{% block title %}Reset Your Password - {{ app_settings.site_name|default("BroxBhai") }}{% endblock %}
{% block content %}
  {# Structured Data - Password Reset Page #}
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "{{ app_settings.site_name|default('BroxBhai')|json }}",
  "url": "{{ url }}"
}
  </script>
  <div class="auth-page auth-page-shell">
    <div class="auth-shell auth-shell-sm">
      <div class="auth-card auth-card--shell">
        <div class="auth-card-header auth-shell-header text-center">
          <div class="auth-shell-icon text-white mb-2">
            <i class="bi bi-key-fill"></i>
          </div>
          <h2 class="auth-shell-title mb-2">Forgot Password?</h2>
          <p class="auth-shell-subtitle mb-0">
            No worries! Enter your email and we'll send you a link to reset your password.
          </p>
        </div>
        <div class="auth-card-body auth-shell-body">
            {% if error %}{{ flash_macros.render_flash({ message: error, type: 'danger' }) }}{% endif %}
            {% if success %}{{ flash_macros.render_flash({ message: success, type: 'success' }) }}{% endif %}
            <form method="POST"
                  action="/forgot-password"
                  id="forgotPasswordForm"
                  novalidate>
              <!-- CSRF Token -->
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <!-- Email Field -->
              <div class="mb-4">
                <label for="email" class="form-label">Email Address</label>
                <input type="email"
                       class="form-control form-control-lg"
                       id="email"
                       name="email"
                       value="{{ old_email }}"
                       placeholder="Enter your email address"
                       required>
                <div class="form-text">Enter the email address associated with your account.</div>
                <div class="invalid-feedback">Please provide a valid email.</div>
              </div>
              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary w-100 mb-3 btn-lg">Send Reset Link</button>
            </form>
            <!-- Divider -->
            <hr class="my-4">
            <!-- Help Links -->
            <div class="auth-footer">
              <p class="mb-2">
                Remember your password? <a href="/login" class="text-primary fw-bold">Login here</a>
              </p>
              <p class="mb-0">
                Don't have an account? <a href="/register" class="text-primary fw-bold">Create one</a>
              </p>
            </div>
        </div>
      </div>
      <div class="auth-shell-notes">
        <div class="alert alert-info auth-shell-note" role="alert">
          <h6 class="alert-heading">
            <i class="bi bi-info-circle-fill me-2"></i>What happens next?
          </h6>
          <ol class="mb-0 ps-3">
            <li>We'll send a password reset link to your email</li>
            <li>The link expires in 1 hour for security</li>
            <li>Click the link and create a new password</li>
            <li>You can then login with your new password</li>
          </ol>
        </div>
        <!-- Security Note -->
        <div class="alert alert-warning auth-shell-note" role="alert">
          <small>
            <strong>Security:</strong> Never share your password reset link with anyone.
            If you didn't request this reset, you can safely ignore this email.
          </small>
        </div>
      </div>
    </div>
  </div>
  {# Inline script removed - use external JavaScript file instead #}
{% endblock %}
