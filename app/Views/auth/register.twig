{% extends "layout.twig" %}
{% set suppress_layout_flash = true %}
{% block title %}Create Account - {{ app_settings.site_name|default("BroxBhai") }}{% endblock %}
{% block content %}
  {# Structured Data - Registration Page #}
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "{{ app_settings.site_name|default('BroxBhai')|json }}",
  "url": "{{ url }}"
}
  </script>
  <div class="auth-page register-container d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="auth-card register-card w-100 tw-bg-white tw-rounded-lg tw-shadow-md" style="max-width:500px;">
      <div class="auth-card-header register-header">
        <h2>
          <i class="bi bi-person-plus-fill"></i> Create Account
        </h2>
        <p class="subtitle">Join {{ app_settings.site_name|default("BroxBhai") }} today</p>
      </div>
      <div class="auth-card-body register-body">
        {% set oauth_status_message = error|default('') %}
        {% set oauth_status_type_raw = "danger" %}
        {% if oauth_status_message == '' and success|default('') != '' %}
          {% set oauth_status_message = success %}
          {% set oauth_status_type_raw = "success" %}
        {% endif %}
        {% if oauth_status_message == '' and flash_message %}
          {% set oauth_status_message = flash_message.text|default(flash_message.message|default('')) %}
          {% set oauth_status_type_raw = flash_message.status|default(flash_message.type|default('info')) %}
        {% endif %}
        {% set oauth_status_type = oauth_status_type_raw in ['success', 'danger', 'warning', 'info'] ? oauth_status_type_raw : 'info' %}
        <div id="oauth-status"
             class="auth-response auth-response--{{ oauth_status_type }} auth-response-hidden"
             role="status"
             aria-live="polite"
             data-initial-message="{{ oauth_status_message }}"
             data-initial-type="{{ oauth_status_type }}"></div>
        <form method="POST"
              action="/register"
              id="registerForm"
              class="auth-form"
              data-redirect-url="{{ oauth_redirect }}"
              data-firebase-auth="{{ enable_firebase_oauth ? '1' : '0' }}"
              novalidate>
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          {% if oauth_redirect %}<input type="hidden" name="redirect" value="{{ oauth_redirect }}">{% endif %}
          <div class="form-group mb-3">
            <label for="email" class="form-label">Email Address</label>
            <input type="email"
                   class="form-control"
                   id="email"
                   name="email"
                   value="{{ old_email }}"
                   placeholder="john@example.com"
                   required>
            <div class="form-text">We'll never share your email with anyone else.</div>
          </div>
          <div class="form-group mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text"
                   class="form-control"
                   id="username"
                   name="username"
                   value="{{ old_username }}"
                   placeholder="john_doe"
                   pattern="[a-zA-Z0-9._-]{3,30}"
                   required>
            <div class="form-text">3-30 characters. Letters, numbers, dots, hyphens, and underscores.</div>
          </div>
          <div class="register-name-grid">
            <div class="form-group">
              <label for="first_name" class="form-label">First Name</label>
              <input type="text"
                     class="form-control"
                     id="first_name"
                     name="first_name"
                     value="{{ old_first_name }}"
                     placeholder="John">
            </div>
            <div class="form-group">
              <label for="last_name" class="form-label">Last Name</label>
              <input type="text"
                     class="form-control"
                     id="last_name"
                     name="last_name"
                     value="{{ old_last_name }}"
                     placeholder="Doe">
            </div>
          </div>
          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <div class="input-wrapper">
              <input type="password"
                     class="form-control"
                     id="password"
                     name="password"
                     placeholder="Enter a strong password"
                     autocomplete="new-password"
                     required>
              <i class="bi bi-eye password-toggle"
                 id="passwordToggle"
                 role="button"
                 tabindex="0"
                 aria-label="Show password"
                 aria-controls="password"
                 aria-pressed="false"
                 data-toggle-password="password"></i>
            </div>
            <div class="password-strength">
              <div class="strength-bar" data-strength="1"></div>
              <div class="strength-bar" data-strength="2"></div>
              <div class="strength-bar" data-strength="3"></div>
              <div class="strength-bar" data-strength="4"></div>
            </div>
            <div id="passwordFeedback" class="form-text"></div>
          </div>
          <div class="form-group">
            <label for="confirm_password" class="form-label">Confirm Password</label>
            <div class="input-wrapper">
              <input type="password"
                     class="form-control"
                     id="confirm_password"
                     name="confirm_password"
                     placeholder="Repeat password"
                     autocomplete="new-password"
                     required>
              <i class="bi bi-eye password-toggle"
                 id="confirmPasswordToggle"
                 role="button"
                 tabindex="0"
                 aria-label="Show confirm password"
                 aria-controls="confirm_password"
                 aria-pressed="false"
                 data-toggle-password="confirm_password"></i>
            </div>
            <div id="confirmFeedback" class="form-text"></div>
          </div>
          <div class="form-check">
            <input type="checkbox"
                   class="form-check-input"
                   id="terms"
                   name="terms"
                   required>
            <label class="form-check-label" for="terms">
              I agree to the <a href="/terms" target="_blank">Terms & Conditions</a> and <a href="/privacy" target="_blank">Privacy Policy</a>
            </label>
          </div>
          <button type="submit" class="btn-register" id="submitBtn">
            <i class="bi bi-person-plus"></i> Create Account
          </button>
        </form>
        {% if enable_firebase_oauth %}
          <div class="divider">
            <div class="divider-text">Continue With</div>
          </div>
          <div id="auth-buttons" class="d-flex justify-content-center gap-2 mt-3">
            <button type="button"
                    class="btn btn-outline-secondary auth-btn"
                    id="auth-google-btn"
                    title="Sign up with Google"
                    aria-label="Sign up with Google">
              <i class="bi bi-google"></i>
            </button>
            <button type="button"
                    class="btn btn-outline-secondary auth-btn"
                    id="auth-facebook-btn"
                    title="Sign up with Facebook"
                    aria-label="Sign up with Facebook">
              <i class="bi bi-facebook"></i>
            </button>
            <button type="button"
                    class="btn btn-outline-secondary auth-btn"
                    id="auth-guest-btn"
                    title="Continue as Guest"
                    aria-label="Continue as guest">
              <i class="bi bi-person"></i>
            </button>
          </div>
          <div class="auth-buttons auth-buttons-hidden">
            <div id="firebaseui-auth-container"
                 class="firebaseui-auth-container"
                 {% if oauth_redirect %}data-redirect-url="{{ oauth_redirect }}"{% endif %}></div>
          </div>
        {% endif %}
        <div class="auth-footer footer-links">
          <p>
            Already have an account? <a href="/login{% if oauth_redirect %}?redirect={{ oauth_redirect|url_encode }}{% endif %}">Sign in here</a>
          </p>
        </div>
      </div>
    </div>
  </div>
  <!-- Register form handler -->
  <script src="{{ asset('/assets/js/dist/auth/register.js') }}"
          defer
          type="module"></script>
  {# Account conflict resolution modal (Firebase auth) #}
  {% include 'auth/account-conflict-modal.twig' %}
{% endblock %}
