{% extends "layout.twig" %}
{% import '_macros/flash.twig' as flash_macros %}
{% block title %}Reset Your Password - {{ app_settings.site_name|default("BroxBhai") }}{% endblock %}
{% block content %}
  <div class="auth-page auth-page-shell">
    <div class="auth-shell auth-shell-sm">
      <div class="auth-card auth-card--shell">
        <div class="auth-card-header auth-shell-header text-center">
          <div class="auth-shell-icon text-white mb-2">
            <i class="bi bi-shield-lock-fill"></i>
          </div>
          <h2 class="auth-shell-title mb-2">Reset Your Password</h2>
          <p class="auth-shell-subtitle mb-0">Enter your new password below.</p>
        </div>
        <div class="auth-card-body auth-shell-body">
            {% if error %}{{ flash_macros.render_flash({ message: error, type: 'danger' }) }}{% endif %}
            {% if success %}{{ flash_macros.render_flash({ message: success, type: 'success' }) }}{% endif %}
            {% if token_valid %}
              <form method="POST" action="/reset-password" novalidate>
                <!-- CSRF Token -->
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                <input type="hidden" name="token" value="{{ token }}">
                <!-- New Password Field -->
                <div class="mb-3">
                  <label for="password" class="form-label">New Password</label>
                  <input type="password"
                         class="form-control"
                         id="password"
                         name="password"
                         autocomplete="new-password"
                         required>
                  <div class="form-text">Minimum 8 characters. Must include uppercase, lowercase, number, and special character.</div>
                  <div id="passwordFeedback" class="form-text"></div>
                  <div class="invalid-feedback">Password must meet all requirements.</div>
                </div>
                <!-- Confirm Password Field -->
                <div class="mb-4">
                  <label for="confirm_password" class="form-label">Confirm Password</label>
                  <input type="password"
                         class="form-control"
                         id="confirm_password"
                         name="confirm_password"
                         autocomplete="new-password"
                         required>
                  <div id="confirmFeedback" class="form-text"></div>
                  <div class="invalid-feedback">Passwords do not match.</div>
                </div>
                <!-- Submit Button -->
                <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">Reset Password</button>
              </form>
              <hr class="my-4">
              <div class="auth-footer">
                <p class="mb-0">
                  Remember your password? <a href="/login" class="text-primary fw-bold">Login here</a>
                </p>
              </div>
            {% else %}
              <div class="alert alert-danger" role="alert">
                <strong>Invalid or Expired Token</strong>
                <p class="mb-2">The password reset link is invalid or has expired.</p>
                <a href="/forgot-password" class="btn btn-primary btn-sm">Request a new link</a>
              </div>
            {% endif %}
        </div>
      </div>
      <div class="auth-shell-notes">
        <div class="alert alert-info auth-shell-note" role="alert">
          <h6 class="alert-heading">
            <i class="bi bi-shield-fill me-2"></i>Password Requirements
          </h6>
          <ul class="mb-0 ps-3">
            <li id="req-length">Minimum 8 characters</li>
            <li id="req-upper">At least one uppercase letter (A-Z)</li>
            <li id="req-lower">At least one lowercase letter (a-z)</li>
            <li id="req-number">At least one number (0-9)</li>
            <li id="req-special">At least one special character (!@#$%^&*)</li>
          </ul>
        </div>
        <!-- Security Note -->
        <div class="alert alert-warning auth-shell-note" role="alert">
          <small>
            <strong>Security:</strong> Never use the same password as your other accounts.
            Make sure your new password is strong and unique.
          </small>
        </div>
      </div>
    </div>
  </div>
  {# Inline script removed - use external JavaScript file instead #}
{% endblock %}
