{% extends 'layout.twig' %}

{% block title %}Terms of Service - {{ app_settings.site_name|default('BroxBhai') }}{% endblock %}

{% set breadcrumbs = [
  { label: 'Terms of Service', url: '/terms', icon: 'file-lines' }
] %}

{% block content %}
<div class="page-terms public-static-page">
  <section class="hero-section public-page-hero public-hero--terms position-relative py-5 mb-4 overflow-hidden">
    <div class="container">
      <div class="row align-items-center g-4">
