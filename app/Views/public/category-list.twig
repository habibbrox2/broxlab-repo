{% extends "layout.twig" %}

{% block title %}All Categories | Browse Content by Categories | {{ app_settings.site_name|default('BroxBhai') }}{% endblock %}

{% set breadcrumbs = [
  { label: 'Categories', url: '/categories', icon: 'folder' }
] %}

{% block content %}


{# Structured Data - Collection Page Schema #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "All Categories",
  "description": "Browse all categories on {{ app_settings.site_name|default('BroxBhai') }}. Find content organized by categories.",
  "url": "{{ current_url }}"
}
</script>

{# Hero Section #}
<section class="hero-section position-relative py-5 mb-5 overflow-hidden" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-8">
        <h1 class="display-4 fw-bold text-white mb-3">
          <i class="bi bi-collection me-2"></i>Browse All Categories
        </h1>
        <p class="lead text-white-50 fs-5">
          Explore content organized by categories. {{ total_categories }} categories to discover.
        </p>
      </div>
      <div class="col-lg-4 text-center">
        <div class="hero-icon" style="font-size: 4rem;">📂</div>
      </div>
    </div>
  </div>
</section>

<div class="container py-5">
  {# Page Header #}
  <div class="listing-header">
    <h2><i class="bi bi-collection text-primary me-2"></i>All Categories ({{ total_categories }})</h2>
    <p class="text-muted">Find content by category</p>
  </div>

  {# Filter Card #}
  <div class="filter-card mb-4">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-6">
        <label for="search" class="form-label">
          <i class="bi bi-search me-2"></i>Search Categories
        </label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Search by category name..." value="{{ search|default('') }}">
      </div>

      <div class="col-md-3">
        <label for="per_page" class="form-label">
          <i class="bi bi-list me-2"></i>Per Page
        </label>
        <select class="form-select" id="per_page" name="per_page">
          <option value="6" {% if per_page == 6 %}selected{% endif %}>6 per page</option>
          <option value="12" {% if per_page == 12 %}selected{% endif %}>12 per page</option>
          <option value="24" {% if per_page == 24 %}selected{% endif %}>24 per page</option>
          <option value="48" {% if per_page == 48 %}selected{% endif %}>48 per page</option>
        </select>
      </div>

      <div class="col-md-3">
        <label for="sort" class="form-label">
          <i class="bi bi-sort-down me-2"></i>Sort By
        </label>
        <select class="form-select" id="sort" name="sort">
          <option value="name" {% if sort == 'name' %}selected{% endif %}>Name (A-Z)</option>
          <option value="latest" {% if sort == 'latest' %}selected{% endif %}>Latest</option>
        </select>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-search me-2"></i>Search
        </button>
        <a href="/categories" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-counterclockwise me-2"></i>Reset
        </a>
      </div>
    </form>
  </div>

  {# Categories Grid #}
  {% if categories|length > 0 %}
    <div class="listing-grid mb-5">
      {% for category in categories %}
        {% include 'partials/content-card.twig' with { item: {
            title: category.name,
            subtitle: category.description|default('No description'),
            id: category.slug,
            slug: category.slug,
            count: category.count,
            url: category.slug,
            type: 'category',
            categories: [],
            tags: [],
            created_at: 'now'|date('Y-m-d H:i:s'),
            views: category.count|default(0),
            impressions: 0
        }, index: loop.index } %}
      {% endfor %}
    </div>

    {# Pagination #}
    {% if total_pages > 1 %}
      <nav aria-label="Page navigation" class="d-flex justify-content-center">
        <ul class="pagination">
          {# Previous Button #}
          {% if current_page > 1 %}
            <li class="page-item">
              <a class="page-link" href="?page=1&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">
                <i class="bi bi-chevron-double-left"></i>
              </a>
            </li>
            <li class="page-item">
              <a class="page-link" href="?page={{ current_page - 1 }}&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">
                <i class="bi bi-chevron-left"></i>
              </a>
            </li>
          {% else %}
            <li class="page-item disabled">
              <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
            </li>
            <li class="page-item disabled">
              <span class="page-link"><i class="bi bi-chevron-left"></i></span>
            </li>
          {% endif %}

          {# Page Numbers #}
          {% set start = max(1, current_page - 2) %}
          {% set end = min(total_pages, current_page + 2) %}

          {% if start > 1 %}
            <li class="page-item">
              <a class="page-link" href="?page=1&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">1</a>
            </li>
            {% if start > 2 %}
              <li class="page-item disabled">
                <span class="page-link">...</span>
              </li>
            {% endif %}
          {% endif %}

          {% for page in start..end %}
            {% if page == current_page %}
              <li class="page-item active">
                <span class="page-link">{{ page }}</span>
              </li>
            {% else %}
              <li class="page-item">
                <a class="page-link" href="?page={{ page }}&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">{{ page }}</a>
              </li>
            {% endif %}
          {% endfor %}

          {% if end < total_pages %}
            {% if end < total_pages - 1 %}
              <li class="page-item disabled">
                <span class="page-link">...</span>
              </li>
            {% endif %}
            <li class="page-item">
              <a class="page-link" href="?page={{ total_pages }}&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">{{ total_pages }}</a>
            </li>
          {% endif %}

          {# Next Button #}
          {% if current_page < total_pages %}
            <li class="page-item">
              <a class="page-link" href="?page={{ current_page + 1 }}&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">
                <i class="bi bi-chevron-right"></i>
              </a>
            </li>
            <li class="page-item">
              <a class="page-link" href="?page={{ total_pages }}&per_page={{ per_page }}&search={{ search }}&sort={{ sort }}">
                <i class="bi bi-chevron-double-right"></i>
              </a>
            </li>
          {% else %}
            <li class="page-item disabled">
              <span class="page-link"><i class="bi bi-chevron-right"></i></span>
            </li>
            <li class="page-item disabled">
              <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
            </li>
          {% endif %}
        </ul>
      </nav>
    {% endif %}

  {% else %}
    {# No Categories Found #}
    <div class="alert alert-info text-center py-5">
      <i class="bi bi-inbox" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
      <h5>No categories found</h5>
      <p class="text-muted mb-0">{% if search %}Try adjusting your search criteria.{% else %}Start by creating your first category.{% endif %}</p>
    </div>
  {% endif %}
</div>

<style>
  .category-card {
    border: 1px solid #e9ecef;
    border-radius: 0.5rem;
    transition: all 0.3s ease;
  }

  .category-card:hover {
    border-color: #f5576c;
    box-shadow: 0 4px 12px rgba(245, 87, 108, 0.1);
    transform: translateY(-2px);
  }

  .category-icon {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(245, 87, 108, 0.1);
    border-radius: 0.5rem;
  }

  @media (max-width: 768px) {
    .display-4 {
      font-size: 2.5rem;
    }

    .hero-icon {
      display: none;
    }
  }
</style>

{% endblock %}
