{% extends "layout.twig" %}

{# ===== SEO Meta Tags ===== #}
{% block title %}{{ app_settings.meta_title ?: app_settings.site_name ~ ' | Official Website' }}{% endblock %}
{% block og_type %}website{% endblock %}

{% block extra_styles %}{% endblock %}

{% block content %}

{# ===== JSON-LD: HomePage Schema ===== #}
{# Helps Google understand this is the homepage and improves featured snippet chances #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "{{ canonical_url|default(url) }}",
    "name": "{{ app_settings.meta_title ?: app_settings.site_name|json }}",
    "description": "{{ app_settings.meta_description ?: 'Welcome to ' ~ app_settings.site_name|json }}",
    "url": "{{ url|json }}",
    "image": "{{ app_settings.site_logo ?: url ~ 'assets/images/default-logo.png'|json }}",
    "isPartOf": {
        "@type": "WebSite",
        "@id": "{{ url|json }}",
        "name": "{{ app_settings.site_name|json }}"
    },
    "datePublished": "{{ 'now'|date('c') }}",
    "dateModified": "{{ 'now'|date('c') }}"
}
</script>

{# ==================== HERO SECTION ==================== #}
