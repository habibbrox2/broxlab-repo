<section class="py-5 bg-light" aria-labelledby="newsletter-title">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <div class="card border-0 shadow-lg rounded-4 p-5 newsletter-card home-newsletter-card text-center">
          <div class="mb-4">
            <span class="bg-primary bg-gradient rounded-circle p-3 mb-3 d-inline-block">
              <i class="bi bi-envelope-paper-fill text-white fs-1" aria-hidden="true"></i>
            </span>
            <h2 id="newsletter-title" class="fw-bold display-6 mb-2">Get Latest Updates</h2>
            <p class="lead text-muted">Subscribe for the latest news, reviews, and exclusive offers</p>
          </div>
          <form id="home-newsletter-form" class="row g-2 justify-content-center" aria-label="Newsletter subscription form">
            <div class="col-md-10">
              <label for="newsletter-email" class="visually-hidden">Email address</label>
              <input type="email" 
                     id="newsletter-email"
                     name="email"
                     class="form-control rounded-pill px-4 py-3 shadow-sm" 
                     placeholder="Your email address" 
                     aria-label="Enter your email address"
                     required>
            </div>
            <div class="col-md-6">
              <button type="submit" class="btn btn-primary rounded-pill fw-bold" aria-label="Subscribe to newsletter">
                <i class="bi bi-send-fill me-2" aria-hidden="true"></i>Subscribe
              </button>
            </div>
          </form>
          
          <script>
          document.getElementById('home-newsletter-form').addEventListener('submit', async (e) => {
              e.preventDefault();
              const formData = new FormData(e.target);
              
              try {
                  const response = await fetch('/newsletter/subscribe', {
                      method: 'POST',
                      body: formData
                  });
                  const data = await response.json();
                  
                  if (data.success) {
                      showMessage(data.message || 'Successfully subscribed to our newsletter', 'success');
                      e.target.reset();
                  } else {
                      showMessage(data.error || 'An error occurred', 'error');
                  }
              } catch (err) {
                  showMessage('Error: ' + err.message, 'error');
              }
          });
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

