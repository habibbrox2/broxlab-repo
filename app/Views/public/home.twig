{# ==================== LATEST UPDATES SECTION ==================== #}
<div class="container py-4 home-latest-section" id="latest-updates">
    {# ==================== TOP POSTS & SERVICES SLIDER ==================== #}
    <section class="home-top-slider mb-5" aria-labelledby="home-top-slider-title">
      <div class="home-top-slider__head">
        <div>
          <h3 id="home-top-slider-title" class="home-top-slider__title mb-1">Top Posts & Services</h3>
          <p class="home-top-slider__subtitle mb-0">Most viewed content picked from posts and services.</p>
        </div>
        <div class="home-top-slider__controls" aria-label="Top slider controls">
          <button type="button" class="home-top-slider__btn" data-top-prev aria-label="Previous slide">
            <i class="bi bi-chevron-left"></i>
          </button>
          <button type="button" class="home-top-slider__btn" data-top-next aria-label="Next slide">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
      </div>

      <div class="home-top-slider__viewport">
        <div class="home-top-slider__track" data-top-track role="list" aria-label="Top posts and services">
          {% for p in top_posts|default([]) %}
            <a href="/posts/view/{{ p.slug }}" class="home-top-card is-post" role="listitem" aria-label="Top post: {{ p.title }}">
              <div class="home-top-card__media">
                {% if p.image %}
                  <img src="{{ p.image }}" alt="{{ p.title }}" loading="lazy" decoding="async">
                {% else %}
                  <span class="home-top-card__placeholder"><i class="bi bi-newspaper"></i></span>
                {% endif %}
              </div>
              <div class="home-top-card__body">
                <span class="home-top-card__type">Post</span>
                <h4 class="home-top-card__title">{{ p.title }}</h4>
                <div class="home-top-card__meta">
                  <span><i class="bi bi-eye-fill"></i> {{ p.views|default(0)|number_format }}</span>
                  <span class="home-top-card__rating"><i class="bi bi-star-fill"></i> {{ p.rating_average|default(0)|number_format(1) }} <small>({{ p.rating_total|default(0)|number_format }})</small></span>
                  <span><i class="bi bi-calendar3"></i> {{ p.created_at|date('d M, Y') }}</span>
                </div>
              </div>
            </a>
          {% endfor %}

          {% for s in top_services|default([]) %}
            <a href="/services/{{ s.slug }}" class="home-top-card is-service" role="listitem" aria-label="Top service: {{ s.title|default(s.name) }}">
              <div class="home-top-card__media">
                {% if s.image %}
                  <img src="{{ s.image }}" alt="{{ s.title|default(s.name) }}" loading="lazy" decoding="async">
                {% else %}
                  <span class="home-top-card__placeholder"><i class="bi bi-award-fill"></i></span>
                {% endif %}
              </div>
              <div class="home-top-card__body">
                <span class="home-top-card__type">Service</span>
                <h4 class="home-top-card__title">{{ s.title|default(s.name) }}</h4>
                <div class="home-top-card__meta">
                  <span><i class="bi bi-eye-fill"></i> {{ s.views|default(0)|number_format }}</span>
                  <span class="home-top-card__rating"><i class="bi bi-star-fill"></i> {{ s.rating_average|default(0)|number_format(1) }} <small>({{ s.rating_total|default(0)|number_format }})</small></span>
                  <span><i class="bi bi-calendar3"></i> {{ s.created_at|date('d M, Y') }}</span>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>

      {% if (top_posts|default([])|length == 0) and (top_services|default([])|length == 0) %}
        <div class="home-top-slider__empty">Top content not available right now.</div>
      {% endif %}
    </section>

    {# ==================== HEADER WITH TAB NAVIGATION ==================== #}
    <div class="latest-updates-header mb-4">
      {# Section Title #}
      <div class="section-title-wrapper mb-3 mb-md-0">
        <h2 class="fw-bold m-0 display-6 display-md-5">
          <span class="text-primary border-bottom border-3 border-primary pb-2">Recent</span> Feed
        </h2>
      </div>
      
      {# Modern Tab Navigation #}
      <nav class="modern-tab-nav" role="tablist" aria-label="Feed tabs">
        <div class="tab-buttons-wrapper">
          <button class="tab-btn active" 
                  id="recent-tab" 
                  role="tab" 
                  aria-selected="true" 
                  aria-controls="latest-feed"
                  data-tab="recent">
            <i class="bi bi-clock-history" aria-hidden="true"></i>
            <span class="tab-label">Recent</span>
          </button>
          
          <button class="tab-btn" 
                  id="services-tab" 
                  role="tab" 
                  aria-selected="false" 
                  aria-controls="services-feed"
                  data-tab="services">
            <i class="bi bi-briefcase" aria-hidden="true"></i>
            <span class="tab-label">Services</span>
          </button>
        </div>
        
        {# Auto-rotate Timer #}
        <div class="tab-timer-wrapper">
          <small class="timer-text" id="auto-rotate-indicator">
            <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
            <span class="d-none d-sm-inline">Auto: </span>
            <span id="rotate-timer">15</span>s
          </small>
        </div>
      </nav>
    </div>

    {# ==================== CONTENT CARDS SECTION ==================== #}
    <div id="latest-feed" class="feed-grid" role="feed" aria-label="Latest content feed">
      {% for item in contents %}
        {% include 'partials/content-card.twig' with { item: item, index: loop.index } %}
      {% else %}
        <div class="feed-empty-state">
          <div class="empty-state-content" role="status" aria-label="No content available">
            <i class="bi bi-box-seam empty-icon" aria-hidden="true"></i>
            <p class="empty-text">No content available at the moment.</p>
          </div>
        </div>
      {% endfor %}
    </div>
    
    {# ==================== SERVICES FEED (AJAX) ==================== #}
    <div id="services-feed" class="feed-grid d-none" role="feed" aria-label="Services feed">
      <!-- Populated via JavaScript -->
    </div>
</div>



{# ==================== JAVASCRIPT ==================== #}
<script>
(function(){
  const servicesTabBtn = document.getElementById('services-tab');
  const recentTabBtn = document.getElementById('recent-tab');
  const latestFeed = document.getElementById('latest-feed');
  const servicesFeed = document.getElementById('services-feed');
  const rotateTimerEl = document.getElementById('rotate-timer');
  
  let servicesLoaded = false;
  let currentFeed = 'recent';
  let autoRotateTimer = null;
  let countdownTimer = null;
  let countdownValue = 15;
  let isTransitioning = false;

  function setActiveTab(tabName) {
    if (tabName === 'recent') {
      recentTabBtn.classList.add('active');
      servicesTabBtn.classList.remove('active');
      recentTabBtn.setAttribute('aria-selected', 'true');
      servicesTabBtn.setAttribute('aria-selected', 'false');
    } else {
      servicesTabBtn.classList.add('active');
      recentTabBtn.classList.remove('active');
      servicesTabBtn.setAttribute('aria-selected', 'true');
      recentTabBtn.setAttribute('aria-selected', 'false');
    }
  }

  async function loadServices() {
    if (servicesLoaded) return;
    
    servicesFeed.innerHTML = '<div class="loading-spinner" aria-live="polite"><div class="spinner-border spinner-border-sm text-primary me-2" role="status"><span class="visually-hidden">Loading</span></div>Loading services…</div>';
    
    try {
      // Prefer server-rendered HTML partial for consistent markup (uses content-card.twig)
      const res = await fetch('/api/services/html');
      if (!res.ok) throw new Error('Failed to load services');
      const html = await res.text();
      servicesFeed.innerHTML = html || '<div class="feed-empty-state"><div class="empty-state-content">No services found.</div></div>';
      servicesLoaded = true;
    } catch (err) {
      servicesFeed.innerHTML = '<div class="feed-empty-state"><div class="empty-state-content text-danger">Failed to load services.</div></div>';
      console.error(err);
    }
  }

  function resetCountdown() {
    countdownValue = 15;
    if (rotateTimerEl) rotateTimerEl.textContent = countdownValue;
  }

  function startCountdown() {
    resetCountdown();
    if (countdownTimer) clearInterval(countdownTimer);
    
    countdownTimer = setInterval(() => {
      countdownValue--;
      if (rotateTimerEl) rotateTimerEl.textContent = countdownValue;
      
      if (countdownValue <= 0) {
        clearInterval(countdownTimer);
        rotateFeeds();
      }
    }, 1000);
  }

  function stopCountdown() {
    if (countdownTimer) clearInterval(countdownTimer);
  }

  function rotateFeeds() {
    if (isTransitioning) return;
    
    if (currentFeed === 'recent') {
      showServices();
    } else {
      showRecent();
    }
  }

  function showServices() {
    if (isTransitioning) return;
    isTransitioning = true;
    
    latestFeed.classList.add('fade-out');
    setTimeout(() => {
      latestFeed.classList.add('d-none');
      latestFeed.classList.remove('fade-out');
      servicesFeed.classList.remove('d-none');
      currentFeed = 'services';
      setActiveTab('services');
      loadServices();
      startCountdown();
      isTransitioning = false;
    }, 600);
  }

  function showRecent() {
    if (isTransitioning) return;
    isTransitioning = true;
    
    servicesFeed.classList.add('fade-out');
    setTimeout(() => {
      servicesFeed.classList.add('d-none');
      servicesFeed.classList.remove('fade-out');
      latestFeed.classList.remove('d-none');
      currentFeed = 'recent';
      setActiveTab('recent');
      startCountdown();
      isTransitioning = false;
    }, 600);
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/[&<>"']/g, function(ch){
      return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;'}[ch]);
    });
  }

  // Event listeners
  if (servicesTabBtn) {
    servicesTabBtn.addEventListener('click', function(e){
      e.preventDefault();
      stopCountdown();
      if (currentFeed !== 'services') showServices();
    });
  }

  if (recentTabBtn) {
    recentTabBtn.addEventListener('click', function(e){
      e.preventDefault();
      stopCountdown();
      if (currentFeed !== 'recent') showRecent();
    });
  }

  // Start auto-rotate
  window.addEventListener('load', function() {
    setTimeout(() => startCountdown(), 1000);
  });
})();

(function(){
  const sliderRoot = document.querySelector('.home-top-slider');
  if (!sliderRoot) return;

  const track = sliderRoot.querySelector('[data-top-track]');
  const prevBtn = sliderRoot.querySelector('[data-top-prev]');
  const nextBtn = sliderRoot.querySelector('[data-top-next]');
  if (!track || !prevBtn || !nextBtn) return;

  const getStep = () => {
    const firstCard = track.querySelector('.home-top-card');
    if (!firstCard) return 320;
    const styles = window.getComputedStyle(track);
    const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
    return Math.round(firstCard.getBoundingClientRect().width + gap);
  };

  const goNext = () => {
    const maxScrollLeft = Math.max(0, track.scrollWidth - track.clientWidth);
    if (track.scrollLeft >= maxScrollLeft - 5) {
      track.scrollTo({ left: 0, behavior: 'smooth' });
      return;
    }
    track.scrollBy({ left: getStep(), behavior: 'smooth' });
  };

  const goPrev = () => {
    if (track.scrollLeft <= 5) {
      track.scrollTo({ left: Math.max(0, track.scrollWidth - track.clientWidth), behavior: 'smooth' });
      return;
    }
    track.scrollBy({ left: -getStep(), behavior: 'smooth' });
  };

  prevBtn.addEventListener('click', goPrev);
  nextBtn.addEventListener('click', goNext);

  let autoTimer = null;
  const startAuto = () => {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(goNext, 5000);
  };
  const stopAuto = () => {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = null;
  };

  sliderRoot.addEventListener('mouseenter', stopAuto);
  sliderRoot.addEventListener('mouseleave', startAuto);
  sliderRoot.addEventListener('touchstart', stopAuto, { passive: true });
  sliderRoot.addEventListener('touchend', startAuto, { passive: true });

  startAuto();
})();
</script>
