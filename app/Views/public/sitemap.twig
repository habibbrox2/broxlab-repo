<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {# Static pages #}
    <url>
        <loc>{{ base_url() }}</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}about-us</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}contact</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}newsletter</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}advertise</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}terms</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>
    
    <url>
        <loc>{{ base_url() }}privacy</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>
    
    {# Content pages #}
    {% for content in contents %}
    <url>
        <loc>{{ base_url() }}post/{{ content.slug }}</loc>
        <lastmod>{{ content.updated_at|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    {% endfor %}
    
    {# Categories #}
    {% for category in categories %}
    <url>
        <loc>{{ base_url() }}category/{{ category.slug }}</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>
    {% endfor %}
    
    {# Tags #}
    {% for tag in tags %}
    <url>
        <loc>{{ base_url() }}tag/{{ tag.slug }}</loc>
        <lastmod>{{ 'now'|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.7</priority>
    </url>
    {% endfor %}
</urlset>