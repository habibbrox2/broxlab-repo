{% extends 'layout.twig' %}

{% block title %}Privacy Policy - {{ app_settings.site_name|default('BroxBhai') }}{% endblock %}

{% set breadcrumbs = [
  { label: 'Privacy Policy', url: '/privacy', icon: 'lock' }
] %}

{% block content %}
<div class="page-privacy public-static-page">
  <section class="hero-section public-page-hero public-hero--privacy position-relative py-5 mb-4 overflow-hidden">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <h1 class="display-4 fw-bold text-white mb-3">
            <i class="bi bi-shield-lock me-2"></i>Privacy Policy
          </h1>
          <p class="lead text-white-50 fs-5 mb-0">
            We value your privacy and data security. Learn how your information is protected.
          </p>
        </div>
        <div class="col-lg-4 text-center">
          <div class="public-hero-icon" aria-hidden="true">
            <i class="bi bi-shield-lock-fill"></i>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="legal-page py-4 py-lg-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-9 col-xl-8 mx-auto">
          <div class="alert alert-info border-0 rounded-4 mb-4" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Last Updated:</strong> {{ 'now'|date('F d, Y') }}
          </div>

          <div class="legal-content public-surface-card">
            <h2 class="h4 fw-bold mt-0 mb-3">Introduction</h2>
            <p>
              {{ app_settings.site_name|default('BroxBhai') }} ("we", "us", or "our") operates this website.
              This page explains how we collect, use, and protect your personal data.
            </p>

            <h2 class="h4 fw-bold mt-5 mb-3">Information Collection and Use</h2>
            <p>
              We collect certain types of information to provide and improve our services.
            </p>

            <h3 class="h5 fw-bold mt-3 mb-2">Types of Data Collected</h3>
            <ul>
              <li><strong>Personal Data:</strong> Name, email address, and phone number.</li>
              <li><strong>Usage Data:</strong> Browser type, IP address, pages visited, and time spent.</li>
              <li><strong>Cookies:</strong> Cookies and similar technologies to improve user experience.</li>
            </ul>

            <h2 class="h4 fw-bold mt-5 mb-3">Use of Data</h2>
            <p>We use collected data for the following purposes:</p>
            <ul>
              <li>To provide and maintain our service.</li>
              <li>To notify you about important updates.</li>
              <li>To provide customer support.</li>
              <li>To analyze usage and improve platform quality.</li>
              <li>To detect, prevent, and resolve technical issues.</li>
            </ul>

            <h2 class="h4 fw-bold mt-5 mb-3">Security of Data</h2>
            <p>
              We apply industry-standard safeguards, but no internet transmission or storage system is fully secure.
            </p>

            <h2 class="h4 fw-bold mt-5 mb-3">Changes to This Privacy Policy</h2>
            <p>
              We may update this policy periodically. Updates will be posted on this page with a revised date.
            </p>

            <h2 class="h4 fw-bold mt-5 mb-3">Contact Us</h2>
            <p>
              If you have any questions about this Privacy Policy, please <a href="/contact">contact us</a>.
            </p>

            <div class="alert alert-info mt-5 mb-0">
              <strong>Last Updated:</strong> {{ 'now'|date('F d, Y') }}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}
