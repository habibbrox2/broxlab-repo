{# ============================
   FILE: templates/_macros/dashboard_macros.twig
   Reusable UI helpers for dashboards
   ============================ #}
{% macro status_badge(status) %}
  {% set s = status|lower %}
  {% set cls =
    s in ['approved','active','success'] ? 'bg-success' :
    (s in ['pending','in review','processing'] ? 'bg-warning text-surface-dark' :
    (s in ['rejected','inactive','failed'] ? 'bg-danger' : 'bg-secondary'))
  %}
  <span class="badge {{ cls }} text-capitalize">{{ status }}</span>
{% endmacro %}

{% macro empty_state(title, subtitle) %}
  <div class="text-center border rounded-4 p-5 bg-light">
    <div class="display-6 mb-2">📭</div>
    <h5 class="mb-1">{{ title }}</h5>
    <p class="text-muted mb-0">{{ subtitle }}</p>
  </div>
{% endmacro %}
