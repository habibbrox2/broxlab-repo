    <button id="scrollTopBtn" type="button" title="Scroll to top" aria-label="Scroll to top of page" style="position: fixed; bottom: 20px; right: 20px; z-index: 999; padding: 10px 14px; border: none; border-radius: 50%; background: var(--bs-primary); color: white; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.15); transition: all 0.3s ease;">
