        {% for role_entry in auth_user.roles %}
            {% set role_name = (role_entry.name is defined ? role_entry.name : role_entry)|default('')|lower|trim %}
            {% if role_name %}
                {% set auth_role_list = auth_role_list|merge([role_name]) %}
