    {# ===== STEP 2: Load Application Core Scripts ===== #}
    <script type="module" src="{{ asset('/assets/js/dist/theme-manager.js') }}"></script>
    <script type="module" src="{{ asset('/assets/js/dist/script.js') }}"></script>

    {# ===== STEP 3: Load Feature Scripts (Non-critical) ===== #}
    <script src="{{ asset('/assets/js/dist/datepicker.js') }}" defer></script>



    {# ===== Page-Specific Scripts Block ===== #}
    {% block extra_scripts %}{% endblock %}

    {# ===== PUBLIC / ADMIN ASSISTANT UI ===== #}
    {% set is_authenticated_user = auth_user is defined and auth_user.is_authenticated is defined and auth_user.is_authenticated %}
    {% set auth_primary_role = (auth_user.role|default(''))|lower|trim %}
    {% set auth_role_list = [] %}
    {% if auth_user is defined and auth_user.roles is defined and auth_user.roles is iterable %}
        {% for role_entry in auth_user.roles %}
            {% set role_name = (role_entry.name is defined ? role_entry.name : role_entry)|default('')|lower|trim %}
            {% if role_name %}
                {% set auth_role_list = auth_role_list|merge([role_name]) %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% set is_super_admin_user = auth_user is defined and auth_user.is_super_admin is defined and auth_user.is_super_admin %}
    {% set is_admin_user = is_super_admin_user
        or auth_primary_role in ['admin', 'superadmin']
        or 'admin' in auth_role_list
        or 'superadmin' in auth_role_list %}
    {% set is_guest_user = not is_authenticated_user %}
    {% set is_regular_user = is_authenticated_user
        and (
            auth_primary_role == 'user'
            or 'user' in auth_role_list
            or (auth_primary_role is empty and auth_role_list is empty)
        ) %}
    {% set show_public_assistant = is_guest_user or is_regular_user %}

        {% if show_public_assistant %}
        {% include 'partials/ai-assistant/public.twig' %}
    {% elseif is_admin_user %}
        {% include 'partials/ai-assistant/admin.twig' %}
    {% endif %}

    <script src="{{ asset('/ai/js/assistant.js') }}"></script>

</body>
</html>
