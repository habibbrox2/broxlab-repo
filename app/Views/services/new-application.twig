{# templates/services/new-application.twig #}
{% extends 'layout.twig' %}
{% block title %}Start New Application{% endblock %}
{% set breadcrumbs = [
  {
    "label": "My Applications",
    "url": "/services/my-applications",
    "icon": "clipboard-list"
  },
  {
    "label": "New Application",
    "icon": "plus-lg"
  }
] %}
{% block content %}
  <style>
    .inl-p-0005 {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .inl-p-0002 {
      width: 88px;
      height: 88px;
      margin: 0 auto;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.35);
      color: #fff;
      font-size: 2rem;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
    }
    .inl-p-0008 {
      flex: 1 1 320px;
    }
    .inl-p-0009 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .inl-p-0009 .search-input {
      flex: 1 1 auto;
    }
  </style>
  {# Hero Section #}
  <section class="hero-section services-new-application-hero position-relative py-5 mb-5 overflow-hidden inl-p-0005">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <h1 class="display-4 fw-bold text-white mb-3">
            <i class="bi bi-plus-circle me-2"></i>Start New Application
          </h1>
          <p class="lead text-white-50 fs-5">Select a service below and submit your application</p>
        </div>
        <div class="col-lg-4 text-center">
          <div class="hero-icon inl-p-0002">
            <i class="bi bi-clipboard-plus" aria-hidden="true"></i>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="container py-5 home-feed-surface services-new-application-page">
    <div class="listing-header">
      <h2>
        <i class="bi bi-briefcase text-primary me-2"></i>Available Services
      </h2>
    </div>
    {# Filter Card #}
    <div class="filter-card">
      <div class="filter-group">
        {# Search #}
        <div class="filter-section inl-p-0008">
          <form method="get" class="inl-p-0009">
            <input type="text"
                   name="search"
                   value="{{ search|default("") }}"
                   class="search-input"
                   placeholder="Search services...">
            <button type="submit" class="btn-search">
              <i class="bi bi-search"></i>
            </button>
          </form>
        </div>
        {# Sort #}
        <div class="filter-section">
          <label>Sort By</label>
          <form method="get">
            <select name="sort" class="filter-select" onchange="this.form.submit()">
              <option value="latest" {% if sort == 'latest' %}selected{% endif %}>Latest</option>
              <option value="name" {% if sort == 'name' %}selected{% endif %}>Name (A-Z)</option>
              <option value="popularity" {% if sort == 'popularity' %}selected{% endif %}>Popular</option>
            </select>
          </form>
        </div>
      </div>
    </div>
    {# Services Grid #}
    {% if services is not empty %}
      <div class="feed-grid" role="feed" aria-label="Available services feed">
        {% for service in services %}
          {% include 'partials/content-card.twig' with { item: {
          images: service.image_urls|default(service.images|default([])),
          image: service.featured_image_url|default(service.image_urls|first|default(service.featured_image.thumbnail_path|default(service.featured_image.image_path|default(service.image_path|default(service.thumbnail|default(null)))))),
          title: service.name,
          subtitle: service.description|default('')|striptags|slice(0, 100) ~ '...',
          rich_excerpt_html: service.description|default(''),
          categories: service.categories|default([]),
          tags: service.tags|default([]),
          created_at: service.created_at,
          url: service.slug,
          id: service.id,
          slug: service.slug,
          type: 'service',
          price: service.price,
          status: service.status|default(''),
          is_premium: service.is_premium|default(0),
          is_free: service.is_free|default(0),
          views: service.views|default(0),
          impressions: service.impressions|default(0)
          }, index: loop.index } %}
        {% endfor %}
      </div>
    {% else %}
      <div class="feed-empty-state">
        <div class="empty-state-content"
             role="status"
             aria-label="No services available for application">
          <i class="bi bi-briefcase"></i>
          <h3>No applications available</h3>
          <p>There are no services available for application at this time.</p>
          <a href="/services/my-applications" class="btn btn-outline-primary mt-3">
            <i class="bi bi-arrow-left"></i> Back
          </a>
        </div>
      </div>
    {% endif %}
  </div>
{% endblock %}
