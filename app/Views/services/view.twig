                        {% set gateway_icon = 'bi-wallet2' %}
                      {% elseif gateway_key == 'nagad' %}
                        {% set gateway_icon = 'bi-phone' %}
                      {% elseif gateway_key == 'rocket' %}
                        {% set gateway_icon = 'bi-rocket-takeoff-fill' %}
                      {% endif %}
