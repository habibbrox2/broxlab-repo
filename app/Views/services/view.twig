{% extends 'layout.twig' %}
{% block title %}{{ service.name }} - Apply for Service{% endblock %}
{% set breadcrumbs = [
  { 'label': 'Services', 'url': '/services', 'icon': 'briefcase' },
  { 'label': service.name, 'icon': 'award' }
] %}
{% block content %}
  <!-- Enhanced Hero Section with Animated Gradient -->
  <div class="hero-section position-relative overflow-hidden py-5 inl-p-0056">
    <!-- Animated Background Elements -->
    <div class="position-absolute w-100 h-100 top-0 start-0 inl-p-0062">
      <div class="position-absolute rounded-circle inl-p-0063"></div>
      <div class="position-absolute rounded-circle inl-p-0064"></div>
    </div>
    <div class="container position-relative">
      <div class="row align-items-center">
        <div class="col-md-8">
          <div class="d-flex align-items-center gap-3 mb-3">
            {% if service.icon %}
              <div class="icon-wrapper inl-p-0065">
                <i class="{{ service.icon }} fs-1"></i>
              </div>
            {% endif %}
            <div>
              <h1 class="display-4 fw-bold mb-0 inl-p-0066">{{ service.name }}</h1>
            </div>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            {% if service.is_premium is defined and service.is_premium == 1 %}
              <span class="badge px-3 py-2 rounded-pill inl-p-0067">
                <i class="bi bi-crown me-1"></i> Premium Service
              </span>
              {% if service.price is defined and service.price %}
                <span class="badge bg-white text-surface-dark px-3 py-2 rounded-pill inl-p-0068">
                  <i class="bi bi-cash-coin text-success me-1"></i>
                  {{ app_settings.currency_symbol|default("$") }}{{ service.price|number_format(2, '.', ',') }}
                </span>
              {% endif %}
            {% elseif service.is_premium is defined and service.is_premium == 0 %}
              <span class="badge bg-success px-3 py-2 rounded-pill inl-p-0069">
                <i class="bi bi-check me-1"></i> Free Service
              </span>
            {% elseif service.is_free is defined and service.is_free %}
              <span class="badge bg-success px-3 py-2 rounded-pill inl-p-0069">
                <i class="bi bi-check me-1"></i> Free Service
              </span>
            {% endif %}
            {% if service.status == 'active' %}
              <span class="badge bg-white text-surface-dark px-3 py-2 rounded-pill inl-p-0068">
                <i class="bi bi-check-circle text-success me-1"></i> Active Now
              </span>
            {% endif %}
            {% if service.impressions is defined %}
              <span class="badge bg-white text-surface-dark px-3 py-2 rounded-pill inl-p-0068">
                <i class="bi bi-bar-chart-line text-info me-1"></i> {{ service.impressions|number_format }} Impressions
              </span>
            {% endif %}
            {% if service.views is defined %}
              <span class="badge bg-white text-surface-dark px-3 py-2 rounded-pill inl-p-0068">
                <i class="bi bi-eye-fill text-success me-1"></i> {{ service.views|number_format }} Views
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="container py-5">
    <div class="row g-4">
      <!-- Left Column: Enhanced Images & Info -->
      <div class="col-lg-5">
        <!-- Enhanced Image Carousel with Modern Design -->
        {% if service.images and service.images|length > 0 %}
          <div id="serviceCarousel"
               class="carousel slide mb-4 rounded-4 overflow-hidden position-relative inl-p-0070"
               data-bs-ride="carousel">
            <div class="carousel-inner">
              {% for image in service.images %}
                <div class="carousel-item {% if loop.first %}active{% endif %}">
                  <div class="position-relative inl-p-0071">
                    {% set img_src = image is iterable
                      ? (image.thumbnail_path ?? image.image_path ?? image.url ?? image.path ?? '')
                      : (image|default(''))
                    %}
                    {% if not img_src and service.featured_image_url %}
                      {% set img_src = service.featured_image_url %}
                    {% endif %}
                    {% if img_src %}
                      <img src="{{ img_src }}"
                           alt="{{ image is iterable ? (image.alt_text ?? service.name) : service.name }}"
                           class="w-100 h-100 inl-p-0072">
                    {% else %}
                      <div class="rounded-4 d-flex align-items-center justify-content-center w-100 h-100 inl-p-0073">
                        <i class="bi bi-image text-muted fs-2 opacity-25"></i>
                      </div>
                    {% endif %}
                    <!-- Gradient Overlay -->
                    <div class="position-absolute w-100 h-100 top-0 start-0 inl-p-0074"></div>
                  </div>
                  {% if image is iterable and image.caption %}
                    <div class="carousel-caption d-block pb-4">
                      <p class="mb-0 fw-semibold inl-p-0075">{{ image.caption }}</p>
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
            {% if service.images|length > 1 %}
              <!-- Enhanced Carousel Controls -->
              <button class="carousel-control-prev inl-p-0076"
                      type="button"
                      data-bs-target="#serviceCarousel"
                      data-bs-slide="prev">
                <div class="bg-white bg-opacity-75 rounded-circle p-3 d-flex align-items-center justify-content-center inl-p-0077">
                  <span class="carousel-control-prev-icon inl-p-0078" aria-hidden="true"></span>
                </div>
                <span class="visually-hidden">Previous</span>
              </button>
              <button class="carousel-control-next inl-p-0076"
                      type="button"
                      data-bs-target="#serviceCarousel"
                      data-bs-slide="next">
                <div class="bg-white bg-opacity-75 rounded-circle p-3 d-flex align-items-center justify-content-center inl-p-0077">
                  <span class="carousel-control-next-icon inl-p-0078" aria-hidden="true"></span>
                </div>
                <span class="visually-hidden">Next</span>
              </button>
              <!-- Carousel Indicators -->
              <div class="carousel-indicators inl-p-0079">
                {% for image in service.images %}
                  <button type="button"
                          data-bs-target="#serviceCarousel"
                          data-bs-slide-to="{{ loop.index0 }}"
                          class="inl-p-0080{% if loop.first %} active{% endif %}"
                          aria-current="{% if loop.first %}true{% endif %}"
                          aria-label="Slide {{ loop.index }}"></button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% elseif service.featured_image_url or (service.featured_image is defined and service.featured_image.image_path) %}
          <div class="rounded-4 overflow-hidden mb-4 position-relative inl-p-0070">
            {% set feat_src = service.featured_image_url
              ?? (service.featured_image.image_path ?? service.featured_image.thumbnail_path ?? '')
            %}
            {% if feat_src %}
              <img src="{{ feat_src }}"
                   alt="{{ service.featured_image.alt_text ?? service.name }}"
                   class="w-100 inl-p-0081">
            {% else %}
              <div class="rounded-4 d-flex align-items-center justify-content-center mb-4 inl-p-0082">
                <i class="bi bi-image text-muted fs-2 opacity-25"></i>
              </div>
            {% endif %}
          </div>
        {% else %}
          <div class="rounded-4 d-flex align-items-center justify-content-center mb-4 inl-p-0083">
            <i class="bi bi-image text-muted fs-2 opacity-25"></i>
          </div>
        {% endif %}
        <!-- Enhanced Service Info Card -->
        <div class="card border-0 rounded-4 mb-4 inl-p-0084">
          <div class="card-body p-4">
            <!-- Status with Icon and Color Coding -->
            <div class="mb-4">
              <h6 class="text-uppercase fw-bold mb-3 inl-p-0085">
                <i class="bi bi-activity me-2"></i>Status
              </h6>
              {% if service.status == 'active' %}
                <div class="d-flex align-items-center gap-2 p-3 rounded-3 inl-p-0086">
                  <div class="rounded-circle bg-success d-flex align-items-center justify-content-center inl-p-0087">
                    <i class="bi bi-check-circle text-white"></i>
                  </div>
                  <div>
                    <div class="fw-bold text-success">Active</div>
                    <small class="text-muted">Service is currently available</small>
                  </div>
                </div>
              {% elseif service.status == 'inactive' %}
                <div class="d-flex align-items-center gap-2 p-3 rounded-3 inl-p-0088">
                  <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center inl-p-0087">
                    <i class="bi bi-pause-circle text-white"></i>
                  </div>
                  <div>
                    <div class="fw-bold text-warning">Inactive</div>
                    <small class="text-muted">Service temporarily unavailable</small>
                  </div>
                </div>
              {% else %}
                <div class="d-flex align-items-center gap-2 p-3 rounded-3 inl-p-0089">
                  <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center inl-p-0087">
                    <i class="bi bi-archive text-white"></i>
                  </div>
                  <div>
                    <div class="fw-bold text-secondary">Archived</div>
                    <small class="text-muted">Service is no longer active</small>
                  </div>
                </div>
              {% endif %}
            </div>
            <!-- Requirements with Modern Icons -->
            {% if service.requires_approval or service.auto_approve or service.requires_documents %}
              <div class="mb-4">
                <h6 class="text-uppercase fw-bold mb-3 inl-p-0085">
                  <i class="bi bi-clipboard2-check me-2"></i>Requirements
                </h6>
                <div class="d-flex flex-column gap-2">
                  {% if service.requires_approval %}
                    <div class="d-flex align-items-center gap-2 p-2 rounded-2 inl-p-0090">
                      <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0091">
                        <i class="bi bi-patch-check text-white inl-p-0092"></i>
                      </div>
                      <span class="small">Admin approval required</span>
                    </div>
                  {% endif %}
                  {% if service.auto_approve %}
                    <div class="d-flex align-items-center gap-2 p-2 rounded-2 inl-p-0093">
                      <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0094">
                        <i class="bi bi-lightning text-white inl-p-0092"></i>
                      </div>
                      <span class="small">Auto-approved applications</span>
                    </div>
                  {% endif %}
                  {% if service.requires_documents %}
                    <div class="d-flex align-items-center gap-2 p-2 rounded-2 inl-p-0095">
                      <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0096">
                        <i class="bi bi-file-earmark-pdf text-white inl-p-0092"></i>
                      </div>
                      <span class="small">Optional Documents</span>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
            {% include 'partials/content-rating.twig' with { content_type: 'service', content_id: service.id } %}
            <!-- Categories with Enhanced Styling -->
            {% if service.categories %}
              <div class="mb-4">
                <h6 class="text-uppercase fw-bold mb-3 inl-p-0085">
                  <i class="bi bi-folder me-2"></i>Categories
                </h6>
                <div class="d-flex flex-wrap gap-2">
                  {% for category in service.categories %}
                    <span class="badge px-3 py-2 rounded-pill inl-p-0097">{{ category.name }}</span>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
            <!-- Tags with Enhanced Styling -->
            {% if service.tags %}
              <div class="mb-4">
                <h6 class="text-uppercase fw-bold mb-3 inl-p-0085">
                  <i class="bi bi-tags me-2"></i>Tags
                </h6>
                <div class="d-flex flex-wrap gap-2">
                  {% for tag in service.tags %}
                    <span class="badge bg-light text-surface-dark px-3 py-2 rounded-pill inl-p-0098">#{{ tag.name }}</span>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
        <!-- Enhanced Quick Action Buttons -->
        {% if is_logged_in and user_application %}
          <div class="card border-0 rounded-4 overflow-hidden inl-p-0099">
            <div class="card-body p-4 inl-p-0100">
              <div class="mb-3">
                <h6 class="fw-bold mb-2">
                  <i class="bi bi-check-circle me-2"></i>Your Application Status
                </h6>
              </div>
              <div class="mb-3">
                {% if user_application.status == 'pending' %}
                  <span class="badge bg-warning text-surface-dark px-3 py-2 rounded-pill inl-p-0101">
                    <i class="bi bi-clock me-1"></i> Pending Review
                  </span>
                {% elseif user_application.status == 'processing' %}
                  <span class="badge bg-info px-3 py-2 rounded-pill inl-p-0101">
                    <i class="bi bi-arrow-repeat me-1"></i> Processing
                  </span>
                {% elseif user_application.status == 'approved' %}
                  <span class="badge bg-success px-3 py-2 rounded-pill inl-p-0101">
                    <i class="bi bi-check-circle me-1"></i> Approved
                  </span>
                {% elseif user_application.status == 'rejected' %}
                  <span class="badge bg-danger px-3 py-2 rounded-pill inl-p-0101">
                    <i class="bi bi-x-circle me-1"></i> Rejected
                  </span>
                {% endif %}
              </div>
              <a href="/services/applications/{{ user_application.id }}"
                 class="btn btn-dark w-100 py-3 rounded-3 fw-semibold inl-p-0102">
                <i class="bi bi-eye me-2"></i> View Application Details
              </a>
            </div>
          </div>
        {% endif %}
        {% if can_apply %}
          <a href="#applicationFormCard"
             class="btn btn-primary w-100 py-3 rounded-3 fw-semibold position-relative overflow-hidden"
             style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    border: none;
                    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
                    transition: all 0.3s ease;
                    {% if user_application %}margin-top: 1rem;{% endif %}">
            <span class="position-relative inl-p-0103">
              <i class="bi bi-journal-check me-2"></i> Fill Application Form
            </span>
            <!-- Shine Effect -->
            <div class="position-absolute top-0 start-0 w-100 h-100 inl-p-0104"></div>
          </a>
          {% if not is_logged_in %}
            <small class="d-block mt-2 text-muted">You can apply without login. Login users can track applications in profile.</small>
          {% endif %}
        {% endif %}
      </div>
      <!-- Right Column: Enhanced Description & Form -->
      <div class="col-lg-7">
        <!-- Enhanced Description Card -->
        {% if service.description %}
          <div class="card border-0 rounded-4 mb-4 inl-p-0105">
            <div class="card-body p-4">
              <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0106">
                  <i class="bi bi-info-circle text-white fs-5"></i>
                </div>
                <h5 class="card-title fw-bold mb-0">About This Service</h5>
              </div>
              <div class="rich-content rich-content--service-detail">
                {{ service.description|default("No description provided") |raw }}
              </div>
            </div>
          </div>
        {% endif %}
        <!-- Enhanced Metadata/Details Card -->
        {% if service.metadata and service.metadata|length > 0 %}
          <div class="card border-0 rounded-4 mb-4 inl-p-0105">
            <div class="card-body p-4">
              <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0106">
                  <i class="bi bi-list text-white fs-5"></i>
                </div>
                <h5 class="card-title fw-bold mb-0">Service Details</h5>
              </div>
              <div class="row g-3">
                {% for key, value in service.metadata %}
                  <div class="col-md-6">
                    <div class="p-3 rounded-3 h-100">
                      <div class="text-uppercase fw-bold mb-2">{{ key|replace({"_": " "}) }}</div>
                      {% if value is iterable %}
                        <div class="text-theme-strong fw-semibold">{{ value|json_encode }}</div>
                      {% else %}
                        <div class="text-theme-strong fw-semibold">{{ value }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        {% endif %}
        <!-- Enhanced Application Form -->
        {% if form_fields and form_fields|length > 0 %}
          <div id="applicationFormCard" class="card border-0 rounded-4 inl-p-0099">
            <div class="card-body p-4">
              <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center inl-p-0106">
                  <i class="bi bi-journal-text text-white fs-5"></i>
                </div>
                <h5 class="card-title fw-bold mb-0">Application Form</h5>
              </div>
              <form id="applicationForm"
                    method="POST"
                    action="/services/apply"
                    enctype="multipart/form-data">
                <input type="hidden" name="service_id" value="{{ service.id }}">
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                {% if not is_logged_in %}
                  <div class="p-3 p-md-4 mb-4 rounded-3 border border-primary-subtle inl-p-0107">
                    <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                      <i class="bi bi-person-vcard text-primary"></i>
                      Guest Applicant Information
                    </h6>
                    <div class="row g-3">
                      <div class="col-12">
                        <label for="guest_applicant_name" class="form-label fw-semibold mb-1">
                          Applicant Name <span class="text-danger">*</span>
                        </label>
                        <input type="text"
                               class="form-control rounded-3 border-2"
                               id="guest_applicant_name"
                               name="guest_applicant_name"
                               placeholder="Enter your full name"
                               required>
                      </div>
                      <div class="col-md-6">
                        <label for="guest_applicant_email" class="form-label fw-semibold mb-1">
                          Email <span class="text-danger">*</span>
                        </label>
                        <input type="email"
                               class="form-control rounded-3 border-2"
                               id="guest_applicant_email"
                               name="guest_applicant_email"
                               placeholder="example@email.com"
                               required>
                      </div>
                      <div class="col-md-6">
                        <label for="guest_applicant_phone" class="form-label fw-semibold mb-1">
                          Phone Number <span class="text-danger">*</span>
                        </label>
                        <input type="tel"
                               class="form-control rounded-3 border-2"
                               id="guest_applicant_phone"
                               name="guest_applicant_phone"
                               placeholder="01XXXXXXXXX"
                               required>
                      </div>
                    </div>
                  </div>
                {% endif %}
                {% for field in form_fields %}
                  <div class="mb-4">
                    {% set field_icon_class = field.field_type == 'email'
                      ? 'bi bi-envelope'
                      : (field.field_type == 'tel'
                        ? 'bi bi-telephone'
                        : (field.field_type == 'textarea'
                          ? 'bi bi-text-left'
                          : 'bi bi-pencil'))
                    %}
                    <label for="field_{{ field.form_field_name }}"
                           class="form-label fw-semibold d-flex align-items-center gap-2 mb-2">
                      <i class="{{ field_icon_class }} text-primary inl-p-0101"></i>
                      {{ field.label }}
                      {% if field.required %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    {% if field.field_type == 'textarea' %}
                      <textarea class="form-control rounded-3 border-2 inl-p-0108"
                                id="field_{{ field.form_field_name }}"
                                name="{{ field.form_field_name }}"
                                {% if field.required %}required{% endif %}
                                placeholder="{{ field.placeholder|default('') }}"
                                rows="4"
                                onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 0.2rem rgba(102, 126, 234, 0.15)'"
                                onblur="this.style.borderColor='#dee2e6'; this.style.boxShadow='none'"></textarea>
                    {% elseif field.field_type == 'select' %}
                      <select class="form-select rounded-3 border-2 inl-p-0108"
                              id="field_{{ field.form_field_name }}"
                              name="{{ field.form_field_name }}"
                              {% if field.required %}required{% endif %}
                              onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 0.2rem rgba(102, 126, 234, 0.15)'"
                              onblur="this.style.borderColor='#dee2e6'; this.style.boxShadow='none'">
                        <option value="">Select {{ field.label|lower }}</option>
                      </select>
                    {% elseif field.field_type == 'checkbox' %}
                      <div class="form-check p-3 rounded-3 inl-p-0109">
                        <input class="form-check-input inl-p-0110"
                               type="checkbox"
                               id="field_{{ field.form_field_name }}"
                               name="{{ field.form_field_name }}"
                               {% if field.required %}required{% endif %}>
                        <label class="form-check-label ms-2 inl-p-0111"
                               for="field_{{ field.form_field_name }}">{{ field.label }}</label>
                      </div>
                    {% elseif field.field_type == 'date' %}
                      <input type="date"
                             class="form-control rounded-3 border-2 inl-p-0108"
                             id="field_{{ field.form_field_name }}"
                             name="{{ field.form_field_name }}"
                             {% if field.required %}required{% endif %}
                             onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 0.2rem rgba(102, 126, 234, 0.15)'"
                             onblur="this.style.borderColor='#dee2e6'; this.style.boxShadow='none'">
                    {% else %}
                      <input type="{{ field.field_type }}"
                             class="form-control rounded-3 border-2 inl-p-0108"
                             id="field_{{ field.form_field_name }}"
                             name="{{ field.form_field_name }}"
                             {% if field.required %}required{% endif %}
                             placeholder="{{ field.placeholder|default("") }}"
                             onfocus="this.style.borderColor='#667eea'; this.style.boxShadow='0 0 0 0.2rem rgba(102, 126, 234, 0.15)'"
                             onblur="this.style.borderColor='#dee2e6'; this.style.boxShadow='none'">
                    {% endif %}
                    {% if field.validation_rules and field.validation_rules.hint %}
                      <small class="form-text d-flex align-items-center gap-1 mt-2 inl-p-0112">
                        <i class="bi bi-lightbulb inl-p-0092"></i>
                        {{ field.validation_rules.hint }}
                      </small>
                    {% endif %}
                  </div>
                {% endfor %}
                {% if service.requires_documents %}
                  <div class="mt-4 p-3 rounded-3 border border-danger-subtle inl-p-0113">
                    <label class="form-label fw-semibold d-flex align-items-center gap-2">
                      <i class="bi bi-file-earmark-arrow-up text-danger"></i>
                      Optional Documents
                    </label>
                    <input type="file"
                           class="form-control rounded-3"
                           id="required_documents"
                           name="required_documents[]"
                           accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.jpg,.jpeg,.png,.webp"
                           multiple>
                    <small class="form-text text-muted mt-2 d-block">
                      Upload supporting documents if available (PDF, Office files, or images), or submit without files.
                    </small>
                  </div>
                {% endif %}
                {% if service.is_premium %}
                  <div class="alert alert-warning rounded-3 mt-4 mb-0">
                    <i class="bi bi-credit-card me-2"></i>
                    After clicking apply, payment step will open in a modal.
                  </div>
                  <input type="hidden"
                         name="payment_mode"
                         id="payment_mode_hidden"
                         value="manual">
                  <input type="hidden"
                         name="payment_gateway"
                         id="payment_gateway_hidden"
                         value="">
                  <input type="hidden"
                         name="payment_sender_number"
                         id="payment_sender_number_hidden"
                         value="">
                  <input type="hidden"
                         name="payment_method"
                         id="payment_method_hidden"
                         value="">
                  <input type="hidden"
                         name="payment_transaction_id"
                         id="payment_transaction_id_hidden"
                         value="">
                  <input type="hidden"
                         name="payment_receiver_account"
                         id="payment_receiver_account_hidden"
                         value="">
                  <input type="hidden"
                         name="payment_instruction_message"
                         id="payment_instruction_message_hidden"
                         value="">
                  <input type="hidden"
