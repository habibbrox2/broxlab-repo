                               decoding="async"
                               onload="this.nextElementSibling.style.display='none';"
                               onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';">
                          <span class="payment-logo-fallback" aria-hidden="true">
                            <i class="bi {{ gateway_icon }}"></i>
                          </span>
                        </span>
                        <span class="gateway-option__label d-none d-md-inline">{{ method.label|default(method.key|default('') ) }}</span>
                      </button>
                    {% endfor %}
