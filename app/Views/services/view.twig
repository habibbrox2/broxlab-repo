      margin-bottom: 0.7rem;
      color: #475569;
      font-size: 0.86rem;
    }
    .manual-method-steps {
      display: flex;
      flex-direction: column;
      gap: 0.48rem;
    }
    .manual-step-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #334155;
      font-size: 0.84rem;
      line-height: 1.35;
    }
    .manual-step-badge {
      width: 1.4rem;
      height: 1.4rem;
      border-radius: 999px;
      background: var(--manual-accent);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .manual-receiver-box {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-left: 1.9rem;
      padding: 0.5rem;
      border: 1px dashed rgba(var(--manual-accent-rgb), 0.35);
      background: #fff;
      border-radius: 0.75rem;
    }
    .manual-receiver-input {
      flex: 1;
      border: 0;
      outline: none;
      background: transparent;
      color: #0f172a;
      font-weight: 700;
      font-size: 0.9rem;
      min-width: 0;
    }
    .manual-copy-btn {
      border: 1px solid rgba(var(--manual-accent-rgb), 0.35);
      background: var(--manual-bg-soft);
      color: var(--manual-accent);
      border-radius: 0.6rem;
      padding: 0.35rem 0.62rem;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.8rem;
      font-weight: 600;
      white-space: nowrap;
      transition: all 0.2s ease;
    }
    .manual-copy-btn:hover:not(:disabled) {
      background: var(--manual-bg-strong);
    }
    .manual-copy-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }
    .manual-instruction-note {
      border: 1px solid rgba(var(--manual-accent-rgb), 0.22);
      background: var(--manual-bg-soft);
      border-radius: 0.75rem;
      padding: 0.65rem 0.75rem;
      color: #475569;
      font-size: 0.82rem;
      line-height: 1.45;
    }
    .manual-theme-note {
      color: #64748b;
      font-size: 0.77rem;
    }
    @media (max-width: 767.98px) {
      .inl-p-0071 { height: 280px; }
      .inl-p-0073, .inl-p-0082, .inl-p-0083 { min-height: 280px; }
      .manual-payment-theme {
        padding: 0.75rem;
      }
      .manual-method-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .manual-method-option {
        padding: 0.45rem 0.5rem;
        gap: 0.42rem;
      }
      .gateway-option {
        min-height: 2.4rem;
        padding: 0.4rem 0.54rem;
      }
      .gateway-option__logo {
        width: 1.52rem;
        height: 1.52rem;
      }
      .manual-method-option__label {
        font-size: 0.78rem;
      }
      .manual-method-hero {
        padding: 0.72rem;
      }
      .manual-step-row {
        font-size: 0.8rem;
      }
      .manual-receiver-box {
        margin-left: 0;
        flex-wrap: wrap;
      }
      .manual-receiver-input {
        width: 100%;
      }
      .manual-copy-btn {
        width: 100%;
        justify-content: center;
      }
    }
    @media (max-width: 420px) {
      .manual-method-grid {
        grid-template-columns: 1fr;
      }
      .manual-method-option {
        padding: 0.44rem 0.48rem;
        gap: 0.38rem;
      }
      .manual-method-option__logo {
        width: 1.68rem;
        height: 1.68rem;
      }
      .manual-method-option__logo .payment-logo-image,
      .manual-method-option__logo .payment-logo-fallback {
        width: 1rem;
        height: 1rem;
      }
      .manual-method-option__label {
        font-size: 0.75rem;
        max-width: calc(100% - 2.05rem);
      }
    }
    @media (max-width: 360px) {
      .hero-section.inl-p-0056 {
        padding-top: 2.15rem !important;
        padding-bottom: 2.15rem !important;
      }
      .inl-p-0065 {
        width: 56px;
        height: 56px;
        border-radius: 0.8rem;
      }
      .inl-p-0066 {
        font-size: 1.45rem;
        line-height: 1.2;
      }
      .hero-section .d-flex.gap-2.flex-wrap {
        gap: 0.38rem !important;
      }
      .hero-section .badge {
        font-size: 0.68rem;
        padding: 0.32rem 0.52rem !important;
      }
      .container.py-5 {
        padding-top: 1.85rem !important;
        padding-bottom: 1.85rem !important;
      }
      .inl-p-0084 .card-body,
      .inl-p-0099 .card-body,
      .inl-p-0105 .card-body {
        padding: 0.95rem !important;
      }
      .inl-p-0106 {
        width: 40px;
        height: 40px;
      }
      #applicationForm .form-label {
        font-size: 0.84rem;
      }
      #applicationForm .form-control,
      #applicationForm .form-select {
        font-size: 0.9rem;
        padding: 0.5rem 0.66rem;
      }
      #applicationForm .btn.inl-p-0114 {
        font-size: 0.9rem;
        padding-top: 0.72rem !important;
        padding-bottom: 0.72rem !important;
      }
      #applicationModal .modal-dialog {
        margin: 0.45rem;
      }
      #applicationModal .modal-content {
        border-radius: 0.82rem !important;
      }
      #applicationModal .modal-body {
        padding-left: 0.78rem;
        padding-right: 0.78rem;
      }
      #applicationModal .form-check.p-3 {
        padding: 0.62rem !important;
      }
      .gateway-option {
        min-width: 2.6rem;
        min-height: 2.6rem;
        justify-content: center;
      }
      .manual-payment-theme {
        padding: 0.65rem;
      }
      .manual-method-option {
        padding: 0.4rem 0.44rem;
        border-radius: 0.68rem;
      }
      .manual-method-option__label {
        font-size: 0.72rem;
        letter-spacing: 0.01em;
      }
      .manual-receiver-input {
        font-size: 0.84rem;
      }
      .manual-copy-btn {
        font-size: 0.76rem;
      }
    }
  </style>
  <script>
{% if form_fields and form_fields|length > 0 %}
const form = document.getElementById('applicationForm');
const serviceNameForMessage = {{ service.name|json_encode|raw }};
const notifyUser = (message, type = 'info', duration = 4000) => {
    if (typeof window.showMessage === 'function') {
        return window.showMessage(message, type, duration);
    }

    if (typeof window.showToast === 'function') {
        return window.showToast(message, type, duration);
    }

    if (typeof window.Swal !== 'undefined' && typeof window.Swal.fire === 'function') {
        const iconMap = {
            success: 'success',
            danger: 'error',
            error: 'error',
            warning: 'warning',
            info: 'info'
        };
        return window.Swal.fire({
            toast: true,
            position: 'top-end',
            icon: iconMap[type] || 'info',
            title: String(message),
            showConfirmButton: false,
            timer: Number(duration) > 0 ? Number(duration) : 3000
        });
    }

    console[type === 'danger' || type === 'error' ? 'error' : 'log'](message);
    return Promise.resolve();
};

if (form) {
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalSubmitContent = submitBtn ? submitBtn.innerHTML : '';

    const submitApplication = async () => {
        if (!submitBtn) return;

        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

        const formData = new FormData(form);

        try {
            const response = await fetch('/services/apply', {
                method: 'POST',
                body: formData
            });

            const data = await response.json();

            if (data.success) {
                submitBtn.innerHTML = '<i class="bi bi-check me-2"></i>Success!';
                submitBtn.classList.remove('btn-primary');
                submitBtn.classList.add('btn-success');
                const successMessage = `Your application for ${serviceNameForMessage} was submitted successfully. Redirecting to receipt preview...`;
                notifyUser(successMessage, 'success', 5000);
                const redirectUrl = data.receipt_preview_url || data.redirect_url || '/services/my-applications';
                setTimeout(() => window.location.href = redirectUrl, 2000);
            } else {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalSubmitContent;
                notifyUser(data.message || 'Failed to submit the application.', 'danger');
                if (Array.isArray(data.errors)) {
                    data.errors.forEach(err => notifyUser(err, 'danger'));
                }
            }
        } catch (error) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalSubmitContent;
            notifyUser('Something went wrong. Please try again.', 'danger');
            console.error(error);
        }
    };

    {% if service.is_premium %}
    const paymentModalEl = document.getElementById('applicationModal');
    const paymentSubmitBtn = document.getElementById('paymentSubmitBtn');
    const paymentModeRadios = document.querySelectorAll('input[name="payment_mode_step"]');
    const manualSection = document.getElementById('manualPaymentSection');
    const gatewaySection = document.getElementById('gatewayPaymentSection');

    const paymentModeHidden = document.getElementById('payment_mode_hidden');
    const paymentGatewayHidden = document.getElementById('payment_gateway_hidden');
    const paymentSenderHidden = document.getElementById('payment_sender_number_hidden');
    const paymentMethodHidden = document.getElementById('payment_method_hidden');
    const paymentTxIdHidden = document.getElementById('payment_transaction_id_hidden');
    const paymentReceiverHidden = document.getElementById('payment_receiver_account_hidden');
    const paymentInstructionHidden = document.getElementById('payment_instruction_message_hidden');
    const paymentAmountHidden = document.getElementById('payment_amount_hidden');
    const paymentMethodModal = document.getElementById('payment_method_modal');
    const manualMethodQuickOptions = document.getElementById('manualMethodQuickOptions');
    const manualPaymentDetails = document.getElementById('manualPaymentDetails');
    const instructionBox = document.getElementById('manualPaymentInstruction');
    const manualMethodHero = document.getElementById('manualMethodHero');
    const manualMethodIcon = document.getElementById('manualMethodIcon');
    const manualMethodTitle = document.getElementById('manualMethodTitle');
    const manualMethodSubtitle = document.getElementById('manualMethodSubtitle');
    const manualStep1Text = document.getElementById('manualStep1Text');
    const manualStep3Text = document.getElementById('manualStep3Text');
    const manualReceiverNumber = document.getElementById('manualReceiverNumber');
    const manualReceiverCopyBtn = document.getElementById('manualReceiverCopyBtn');
    const manualSenderLabel = document.getElementById('manualSenderLabel');
    const manualTxLabel = document.getElementById('manualTxLabel');
    const senderNumberInput = document.getElementById('payment_sender_number_modal');
    const txIdInput = document.getElementById('payment_transaction_id_modal');
    const manualMethodConfig = {{ manual_payment_methods|default({})|json_encode|raw }};
    const manualMethodTheme = {
        bkash: {
            icon: 'bi-wallet2',
            title: 'bKash Send Money',
            subtitle: 'Fast and secure payment transfer',
            step1: 'Use bKash app or *247# and choose "Send Money"',
            senderLabel: 'Your bKash number'
        },
        rocket: {
            icon: 'bi-rocket-takeoff-fill',
            title: 'Rocket Payment',
            subtitle: 'Fast and secure payment transfer',
            step1: 'Use Rocket app or *322# and choose "Send Money"',
            senderLabel: 'Your Rocket number'
        },
        nagad: {
            icon: 'bi-phone',
            title: 'Nagad Send Money',
            subtitle: 'Fast and secure payment transfer',
            step1: 'Use Nagad app or *167# and choose "Send Money"',
            senderLabel: 'Your Nagad number'
        },
        default: {
            icon: 'bi-credit-card',
            title: 'Manual Payment',
            subtitle: 'Select a payment method to view instructions',
            step1: 'Select a method and complete Send Money',
            senderLabel: 'Your sender number'
        }
    };

    const escapeHtml = (input) => {
        const value = String(input ?? '');
        return value
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    };

    const normalizeMethodKey = (method) => String(method || '').trim().toLowerCase();

    const getMethodLabel = (methodKey) => {
        if (!paymentMethodModal || !methodKey) return '';
        const option = Array.from(paymentMethodModal.options || []).find((opt) =>
            String(opt.value || '').trim().toLowerCase() === methodKey
        );
        return String(option?.textContent || '').trim();
    };

    const copyToClipboard = async (text) => {
        if (!text) return false;
        try {
            if (navigator?.clipboard?.writeText) {
                await navigator.clipboard.writeText(text);
                return true;
            }
        } catch (error) {
            // fallback below
        }

        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-9999px';
        document.body.appendChild(textArea);
        textArea.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(textArea);
        return ok;
    };

    const getSelectedPaymentMode = () => {
        return document.querySelector('input[name="payment_mode_step"]:checked')?.value || 'manual';
    };

    const setActiveManualMethodOption = (methodKey) => {
        if (!manualMethodQuickOptions) return;
        const normalized = normalizeMethodKey(methodKey);
        const options = manualMethodQuickOptions.querySelectorAll('.manual-method-option');
        options.forEach((option) => {
            const optionMethod = normalizeMethodKey(option.getAttribute('data-method') || '');
            option.classList.toggle('active', normalized !== '' && optionMethod === normalized);
        });
    };

    const renderManualMethodInstruction = (methodValue) => {
        const method = normalizeMethodKey(methodValue);
        const hasMethod = method !== '';
        const selectedMode = getSelectedPaymentMode();
        const showManualDetails = selectedMode === 'manual' && hasMethod;
        const methodLabel = hasMethod ? (getMethodLabel(method) || method.toUpperCase()) : '';
        const baseTheme = hasMethod && manualMethodTheme[method]
            ? manualMethodTheme[method]
            : manualMethodTheme.default;
        const theme = hasMethod && !manualMethodTheme[method]
            ? {
                ...baseTheme,
                title: `${methodLabel} Send Money`,
                step1: `Use ${methodLabel} app/USSD and choose "Send Money"`,
                senderLabel: `Your ${methodLabel} number`
            }
            : baseTheme;

        if (manualSection) {
            manualSection.setAttribute('data-method', hasMethod && manualMethodTheme[method] ? method : 'default');
        }
        setActiveManualMethodOption(method);

        const cfg = (manualMethodConfig && manualMethodConfig[method]) ? manualMethodConfig[method] : {};
        const receiverNumber = (cfg.receiver_number || '').trim();
        const adminMessage = (cfg.message || '').trim();

        if (paymentReceiverHidden) paymentReceiverHidden.value = receiverNumber;
        if (paymentInstructionHidden) paymentInstructionHidden.value = adminMessage;

        if (manualPaymentDetails) {
            manualPaymentDetails.classList.toggle('d-none', !showManualDetails);
        }

        if (manualMethodHero) {
            manualMethodHero.classList.toggle('d-none', !showManualDetails);
        }

        if (manualMethodIcon) {
            manualMethodIcon.className = `bi ${theme.icon || 'bi-credit-card'}`;
        }
        if (manualMethodTitle) manualMethodTitle.textContent = theme.title;
        if (manualMethodSubtitle) manualMethodSubtitle.textContent = theme.subtitle;
        if (manualStep1Text) manualStep1Text.textContent = theme.step1;
        if (manualStep3Text) {
            manualStep3Text.textContent = hasMethod
                ? `Provide TrxID and your ${methodLabel} number`
                : 'Provide TrxID and your sender number';
        }
        if (manualSenderLabel) {
            manualSenderLabel.innerHTML = `${escapeHtml(theme.senderLabel)} <span class="text-danger">*</span>`;
        }
        if (manualTxLabel) {
            manualTxLabel.innerHTML = 'TrxID <span class="text-danger">*</span>';
        }
        if (senderNumberInput) {
            senderNumberInput.placeholder = '01XXXXXXXXXX';
        }
        if (txIdInput) {
            txIdInput.placeholder = 'e.g. TX1234567';
        }
        if (manualReceiverNumber) {
            manualReceiverNumber.value = receiverNumber || 'Receiver number is not configured';
        }
        if (manualReceiverCopyBtn) {
            manualReceiverCopyBtn.disabled = !receiverNumber;
        }

        if (!showManualDetails) {
            if (instructionBox) {
                instructionBox.classList.add('d-none');
                instructionBox.innerHTML = '';
            }
            return;
        }

        if (!instructionBox) return;

        const notes = [];
        if (!receiverNumber) {
            notes.push('Receiver number for this method is not configured yet.');
        }
        if (adminMessage) {
            notes.push(escapeHtml(adminMessage));
        }

        if (!notes.length) {
            instructionBox.classList.add('d-none');
            instructionBox.innerHTML = '';
            return;
        }

        instructionBox.classList.remove('d-none');
        instructionBox.innerHTML = notes.map((line) => `<div>${line}</div>`).join('');
    };

    const togglePaymentSections = () => {
        const selectedMode = getSelectedPaymentMode();
        if (selectedMode === 'gateway') {
            manualSection?.classList.add('d-none');
            gatewaySection?.classList.remove('d-none');
        } else {
            manualSection?.classList.remove('d-none');
            gatewaySection?.classList.add('d-none');
        }

        renderManualMethodInstruction(paymentMethodModal?.value || '');
    };

    const syncPaymentDataToMainForm = () => {
        const selectedMode = document.querySelector('input[name="payment_mode_step"]:checked')?.value || 'manual';

        if (selectedMode === 'gateway') {
            const gateway = document.getElementById('payment_gateway_selected')?.value?.trim() || '';
            const amount = document.getElementById('payment_gateway_amount_modal')?.value?.trim() || '';
            const reference = document.getElementById('payment_gateway_ref_modal')?.value?.trim() || '';

            if (!gateway) return { ok: false, message: 'Please select a payment gateway' };
            if (!amount || Number(amount) <= 0) return { ok: false, message: 'Please enter a valid payable amount' };

            if (paymentModeHidden) paymentModeHidden.value = 'gateway';
            if (paymentGatewayHidden) paymentGatewayHidden.value = gateway;
            if (paymentSenderHidden) paymentSenderHidden.value = '';
            if (paymentMethodHidden) paymentMethodHidden.value = gateway;
            if (paymentTxIdHidden) paymentTxIdHidden.value = reference || 'PENDING_GATEWAY';
            if (paymentReceiverHidden) paymentReceiverHidden.value = '';
            if (paymentInstructionHidden) paymentInstructionHidden.value = '';
            if (paymentAmountHidden) paymentAmountHidden.value = amount;

            return { ok: true };
        }

        const senderNumber = document.getElementById('payment_sender_number_modal')?.value?.trim() || '';
        const method = document.getElementById('payment_method_modal')?.value?.trim() || '';
        const transactionId = document.getElementById('payment_transaction_id_modal')?.value?.trim() || '';
        const amount = document.getElementById('payment_amount_modal')?.value?.trim() || '';

        if (!method) return { ok: false, message: 'Payment method is required' };
        if (!senderNumber) return { ok: false, message: 'Sender number is required' };
        if (!transactionId) return { ok: false, message: 'Transaction ID is required' };
        if (!amount || Number(amount) <= 0) return { ok: false, message: 'Please enter a valid paid amount' };

        const cfg = (manualMethodConfig && manualMethodConfig[method]) ? manualMethodConfig[method] : {};
        const receiverNumber = (cfg.receiver_number || '').trim();
        const adminMessage = (cfg.message || '').trim();

        if (paymentModeHidden) paymentModeHidden.value = 'manual';
        if (paymentGatewayHidden) paymentGatewayHidden.value = '';
        if (paymentSenderHidden) paymentSenderHidden.value = senderNumber;
        if (paymentMethodHidden) paymentMethodHidden.value = method;
        if (paymentTxIdHidden) paymentTxIdHidden.value = transactionId;
        if (paymentReceiverHidden) paymentReceiverHidden.value = receiverNumber;
        if (paymentInstructionHidden) paymentInstructionHidden.value = adminMessage;
        if (paymentAmountHidden) paymentAmountHidden.value = amount;

        return { ok: true };
    };

    paymentModeRadios.forEach((radio) => {
        radio.addEventListener('change', togglePaymentSections);
    });

    if (manualReceiverCopyBtn) {
        manualReceiverCopyBtn.addEventListener('click', async () => {
            const numberToCopy = manualReceiverNumber?.value?.trim() || '';
            if (!numberToCopy || numberToCopy === 'Receiver number is not configured') {
                notifyUser('Receiver number is not configured yet.', 'danger');
                return;
            }

            const copied = await copyToClipboard(numberToCopy);
            if (copied) {
                notifyUser('Receiver number copied.', 'success');
            } else {
                notifyUser('Could not copy number. Please copy manually.', 'danger');
            }
        });
    }

    // Gateway logo selection handling
    const gatewayOptions = document.getElementById('gatewayOptions');
    const paymentGatewaySelected = document.getElementById('payment_gateway_selected');
    if (gatewayOptions) {
        gatewayOptions.addEventListener('click', (ev) => {
            const btn = ev.target.closest && ev.target.closest('.gateway-option');
            if (!btn) return;
            const key = String(btn.getAttribute('data-key') || '').trim();
            if (!key) return;
            // Toggle active class
            Array.from(gatewayOptions.querySelectorAll('.gateway-option')).forEach((b) => b.classList.remove('active'));
            btn.classList.add('active');
            if (paymentGatewaySelected) paymentGatewaySelected.value = key;
            notifyUser(`Selected gateway: ${btn.getAttribute('data-label') || key}`, 'success');
        });
    }

    if (paymentMethodModal) {
        paymentMethodModal.addEventListener('change', (event) => {
            renderManualMethodInstruction(event.target?.value || '');
        });
        renderManualMethodInstruction(paymentMethodModal.value || '');
    }

    if (manualMethodQuickOptions && paymentMethodModal) {
        manualMethodQuickOptions.addEventListener('click', (event) => {
            const option = event.target.closest && event.target.closest('.manual-method-option');
            if (!option) return;

            const method = normalizeMethodKey(option.getAttribute('data-method') || '');
            if (!method) return;

            const matchedSelectOption = Array.from(paymentMethodModal.options || []).find((opt) =>
                normalizeMethodKey(opt.value || '') === method
            );
            const finalValue = matchedSelectOption ? String(matchedSelectOption.value || '') : method;
            paymentMethodModal.value = finalValue;
            renderManualMethodInstruction(finalValue);
        });
    }

    togglePaymentSections();

    if (paymentModalEl) {
        paymentModalEl.addEventListener('shown.bs.modal', () => {
            renderManualMethodInstruction(paymentMethodModal?.value || '');
            togglePaymentSections();
            // Ensure a gateway is preselected visually when opening modal
            if (gatewaySection && gatewaySection.classList.contains('d-none') === false) {
                const sel = document.getElementById('payment_gateway_selected');
                const opts = document.querySelectorAll('#gatewayOptions .gateway-option');
                if (sel && !sel.value && opts && opts.length) {
                    opts[0].classList.add('active');
                    sel.value = opts[0].getAttribute('data-key') || '';
                }
            }
        });
    }

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (typeof bootstrap === 'undefined' || !paymentModalEl) {
            notifyUser('Payment step is unavailable right now. Please refresh and try again.', 'danger');
            return;
        }

        const modal = bootstrap.Modal.getOrCreateInstance(paymentModalEl);
        modal.show();
    });

    if (paymentSubmitBtn) {
        paymentSubmitBtn.addEventListener('click', async () => {
            const syncResult = syncPaymentDataToMainForm();
            if (!syncResult.ok) {
                notifyUser(syncResult.message || 'Payment information is invalid', 'danger');
                return;
            }

            if (typeof bootstrap !== 'undefined' && paymentModalEl) {
                bootstrap.Modal.getOrCreateInstance(paymentModalEl).hide();
            }

            await submitApplication();
        });
    }
    {% else %}
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        await submitApplication();
    });
    {% endif %}
}
{% endif %}

  </script>
{% endblock %}
