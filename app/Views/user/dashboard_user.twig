{# ============================
FILE: templates/dashboard_user.twig
============================ #}
{% extends "layout.twig" %}
{% import "_macros/dashboard_macros.twig" as ui %}
{% block title %}User Dashboard{% endblock %}
{% block content %}
  <div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div class="d-flex align-items-center gap-3">
        <img src="{{ user.photo_url|default("/assets/profile-placeholder.png") }}"
             class="rounded-circle"
             width="60"
             height="60"
             alt="Profile">
        <div>
          <h1 class="h3 mb-1">Hello, {{ user.full_name|default(user.username|title) }}</h1>
          <div class="text-muted">Track your applications and updates</div>
        </div>
      </div>
      <div>
        <a href="/applications/new" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Application</a>
      </div>
    </div>
    <div class="mb-4 d-flex flex-wrap gap-2">
      <a href="/user/settings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-gear me-1"></i>Settings
      </a>
      <a href="/user/devices" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-phone me-1"></i>My Devices
      </a>
      <a href="/logout" class="btn btn-outline-danger btn-sm">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
      </a>
    </div>
    {# User Roles & Permissions Alert #}
    {% if user_roles and user_roles|length > 0 %}
      <div class="alert alert-info alert-dismissible fade show rounded-4 mb-4"
           role="alert">
        <div class="d-flex align-items-start justify-content-between">
          <div>
            <h6 class="alert-heading mb-2">
              <i class="bi bi-badge-check me-2"></i>Your Role(s)
            </h6>
            <div class="d-flex flex-wrap gap-2">
              {% for role in user_roles %}
                <span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle">
                  <i class="bi bi-shield-check me-1"></i>{{ role.name|replace({"_": " "}) |title }}
                </span>
              {% endfor %}
            </div>
          </div>
          <button type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                  aria-label="Close"></button>
        </div>
      </div>
    {% endif %}
    {# Personal Stats #}
    <div class="row g-3 mb-4 dashboard-stats">
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <div class="text-muted">
              <i class="bi bi-file-earmark-text me-1"></i> Total Applications
            </div>
            <div class="fs-3 fw-bold">{{ mystats.total|default(0) }}</div>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <div class="text-muted">
              <i class="bi bi-clock-history me-1"></i> Pending
            </div>
            <div class="fs-3 fw-bold">{{ mystats.pending|default(0) }}</div>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <div class="text-muted">
              <i class="bi bi-check-circle me-1"></i> Approved
            </div>
            <div class="fs-3 fw-bold">{{ mystats.approved|default(0) }}</div>
          </div>
        </div>
      </div>
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
          <div class="card-body">
            <div class="text-muted">
              <i class="bi bi-x-circle me-1"></i> Rejected
            </div>
            <div class="fs-3 fw-bold">{{ mystats.rejected|default(0) }}</div>
          </div>
        </div>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-12 col-xxl-8">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
            <h5 class="mb-0">My Recent Applications</h5>
            <a href="/applications" class="btn btn-sm btn-outline-primary">View all</a>
          </div>
          <div class="card-body p-0">
            {% if my_applications is not empty %}
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Type</th>
                      <th>Status</th>
                      <th>Updated</th>
                      <th class="text-end">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for app in my_applications %}
                      <tr>
                        <td>#{{ app.id }}</td>
                        <td class="text-nowrap">{{ app.certificate_type|title }}</td>
                        <td>{{ ui.status_badge(app.status) }}</td>
                        <td class="text-muted small">{{ app.updated_at|date("d M, Y h:i A") }}</td>
                        <td class="text-end">
                          <a href="/applications/{{ app.id }}"
                             class="btn btn-sm btn-outline-secondary">View</a>
                          {% if app.status == 'pending' %}
                            <a href="/applications/{{ app.id }}/edit" class="btn btn-sm btn-primary">Update</a>
                          {% endif %}
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% else %}
              <div class="p-4">{{ ui.empty_state('No applications yet', 'Start by creating a new application.') }}</div>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="col-12 col-xxl-4">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0">Profile Completion</h6>
          </div>
          <div class="card-body">
            {% set pct = profile.completeness|default(0) %}
            <div class="progress mb-2 progress-sm">
              <div class="progress-bar"
                   role="progressbar"
                   style="width: {{ pct }}%"
                   aria-valuenow="{{ pct }}"
                   aria-valuemin="0"
                   aria-valuemax="100"></div>
            </div>
            <div class="small text-muted">{{ pct }}% complete</div>
            <div class="d-grid gap-2 mt-3">
              {% if profile.needs_photo %}
                <a href="/profile" class="btn btn-outline-secondary btn-sm">Add Profile Photo</a>
              {% endif %}
              {% if profile.needs_phone %}<a href="/profile" class="btn btn-outline-secondary btn-sm">Verify Phone</a>{% endif %}
            </div>
          </div>
        </div>
        <!-- Services Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
              <i class="bi bi-award-fill me-2 text-warning"></i> Services
            </h6>
            <span class="badge bg-primary rounded-pill">Quick Access</span>
          </div>
          <div class="card-body">
            <p class="small text-muted mb-3">Explore and apply for exclusive services tailored to your needs.</p>
            <div class="d-grid gap-2">
              <a href="/services" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-search me-1"></i> Browse Services
              </a>
              <a href="/services/my-applications" class="btn btn-outline-info btn-sm">
                <i class="bi bi-clipboard-check me-1"></i> My Applications
              </a>
            </div>
          </div>
        </div>
        <!-- Security Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-header bg-white border-0 py-3">
            <h6 class="mb-0">
              <i class="bi bi-shield-check me-2"></i> Account Security
            </h6>
          </div>
          <div class="card-body">
            <p class="small text-muted mb-3">Enhance your account security with two-factor authentication.</p>
            <div class="d-grid gap-2">
              <a href="/user/security/2fa" class="btn btn-outline-success btn-sm">
                <i class="bi bi-shield-lock me-1"></i> Manage 2FA
              </a>
              <a href="/profile/password" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-key me-1"></i> Change Password
              </a>
            </div>
          </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0">Notices</h6>
            <a href="/notices" class="small">View all</a>
          </div>
          <div class="card-body">
            {% if notices is not empty %}
              <ul class="list-unstyled mb-0">
                {% for n in notices %}
                  <li class="mb-3">
                    <div class="fw-semibold">{{ n.title }}</div>
                    <div class="text-muted small">{{ n.published_at|date("d M, Y") }}</div>
                    <div class="small">{{ n.excerpt }}</div>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              {{ ui.empty_state('No notices', 'Announcements from the office will appear here.') }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
{% block scripts %}
  {{ parent() }}
  <script>// You can add user-specific interactions here if needed</script>
{% endblock %}
