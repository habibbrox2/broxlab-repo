{# =========================================================
Modern Advanced Comments Component (Isolated Styles)
Features:
- Markdown Support with Live Preview
- Emoji Picker
- Reaction/Like System
- Nested Replies
- Real-time Character Counter
- Smooth Animations
- Dark/Light Mode Compatible
- Mobile Responsive
- ✨ ISOLATED STYLES - Won't affect other pages
========================================================= #}
<div class="modern-comments-section">
  <!-- Header with Stats -->
  <div class="comments-header mb-4">
    <div class="d-flex align-items-center justify-content-between">
      <h4 class="fw-bold mb-0">
        <i class="bi bi-chat-dots-fill comments-text-gradient me-2"></i>
        <span class="comments-gradient-text">Comments</span>
      </h4>
      <div class="comments-count badge comments-bg-gradient-primary rounded-pill px-3 py-2">
        <i class="bi bi-chat-left-text-fill me-1"></i>
        <span id="total-comments">{{ comments|length }}</span>
        <span class="ms-1">{{ comments|length == 1 ? 'Comment' : 'Comments' }}</span>
      </div>
    </div>
  </div>
  <!-- Feedback Alert -->
  <div id="comment-feedback"
       class="alert alert-dismissible fade d-none"
       role="alert">
    <i class="bi bi-info-circle-fill me-2"></i>
    <span id="feedback-text"></span>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <!-- Loading Spinner -->
  <div id="comment-loading" class="text-center my-4 d-none">
    <div class="modern-spinner">
      <div class="spinner-ring"></div>
      <div class="spinner-ring"></div>
      <div class="spinner-ring"></div>
    </div>
    <p class="text-muted mt-2 small">Processing your comment...</p>
  </div>
  <!-- Comment Form Section -->
  <div class="comment-form-wrapper card border-0 shadow-hover rounded-4 mb-5 overflow-hidden">
    <div class="card-header comments-bg-gradient-light border-0 p-4">
      <h6 class="fw-bold mb-0">
        <i class="bi bi-pencil-square text-success me-2"></i>
        Share Your Thoughts
      </h6>
    </div>
    <div class="card-body p-4">
      <form id="commentForm" class="modern-comment-form">
        <input type="hidden" name="content_type" value="{{ content_type }}">
        <input type="hidden" name="content_id" value="{{ content_id }}">
        <input type="hidden" name="parent_id" value="" id="parent_id_field">
        <input type="hidden" name="_token" value="{{ csrf_token }}">
        <!-- User Info (Guest Only) -->
        {% if not auth_user.is_authenticated %}
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <div class="comments-input-group-modern">
                <i class="bi bi-person-fill comments-input-icon"></i>
                <input type="text"
                       name="guest_name"
                       class="comments-form-control comments-form-control-modern"
                       placeholder="Your Name *"
                       id="guest_name_input"
                       required>
              </div>
            </div>
            <div class="col-md-6">
              <div class="comments-input-group-modern">
                <i class="bi bi-envelope-fill comments-input-icon"></i>
                <input type="email"
                       name="guest_email"
                       class="comments-form-control comments-form-control-modern"
                       placeholder="Your Email (Optional)">
              </div>
            </div>
          </div>
        {% else %}
          <!-- Logged-in user: use profile info, no input fields -->
          <input type="hidden" name="user_id" value="{{ auth_user.id }}">
        {% endif %}
        <!-- Reply Info Banner -->
        <div id="reply-banner"
             class="alert alert-info border-0 rounded-3 d-none mb-3">
          <div class="d-flex align-items-center justify-content-between">
            <span>
              <i class="bi bi-reply-fill me-2"></i>
              Replying to <strong id="reply-to-name"></strong>
            </span>
            <button type="button"
                    class="btn btn-sm btn-link text-decoration-none"
                    id="cancel-reply">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
        <!-- Main Textarea -->
        <div class="textarea-wrapper mb-3">
          <textarea name="content"
                    id="comment-textarea"
                    class="comments-form-control comments-form-control-modern"
                    rows="5"
                    placeholder="Write your comment... (Markdown supported 📝)"
                    maxlength="2000"
                    required></textarea>
          <!-- Live Preview Toggle -->
          <div class="preview-toggle">
            <button type="button"
                    class="btn btn-sm btn-link text-muted"
                    id="toggle-preview">
              <i class="bi bi-eye-fill me-1"></i>Preview
            </button>
          </div>
        </div>
        <!-- Markdown Preview Panel -->
        <div id="markdown-preview" class="markdown-preview-panel d-none mb-3">
          <div class="preview-header">
            <small class="text-muted">
              <i class="bi bi-eye-fill me-1"></i>Preview
            </small>
          </div>
          <div class="preview-content" id="preview-content">
            <!-- Rendered markdown will appear here -->
          </div>
        </div>
        <!-- Toolbar -->
        <div class="comment-toolbar d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
          <div class="toolbar-buttons d-flex gap-2">
            <!-- Emoji Button -->
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill emoji-trigger"
                    title="Add Emoji">
              <i class="bi bi-emoji-smile"></i>
            </button>
            <!-- Markdown Buttons -->
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill md-btn"
                    data-md="**text**"
                    title="Bold">
              <i class="bi bi-type-bold"></i>
            </button>
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill md-btn"
                    data-md="_text_"
                    title="Italic">
              <i class="bi bi-type-italic"></i>
            </button>
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill md-btn"
                    data-md="`code`"
                    title="Code">
              <i class="bi bi-code"></i>
            </button>
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill md-btn"
                    data-md="[link](url)"
                    title="Link">
              <i class="bi bi-link-45deg"></i>
            </button>
            <button type="button"
                    class="btn btn-sm btn-light-hover rounded-pill md-btn"
                    data-md="> quote"
                    title="Quote">
              <i class="bi bi-blockquote-right"></i>
            </button>
          </div>
          <!-- Character Counter -->
          <div class="char-counter">
            <small class="text-muted">
              <span id="char-count" class="fw-bold text-primary">0</span>
              <span class="text-muted">/2000</span>
            </small>
          </div>
        </div>
        <!-- Emoji Picker Panel -->
        <div id="emoji-picker" class="emoji-picker-panel d-none">
          <div class="emoji-picker-header">
            <small class="text-muted">Pick an emoji</small>
          </div>
          <div class="emoji-grid">
            {% for emoji in ['😀','😃','😄','😁','😅','😂','🤣','😊','😇','🙂','😉','😌','😍','🥰','😘','😗','😙','😚','🤗','🤩','🤔','🤨','😐','😑','😶','🙄','😏','😣','😥','😮','🤐','😯','😪','😫','😴','😌','😛','😜','😝','🤤','😒','😓','😔','😕','🙃','🤑','😲','☹️','🙁','😖','😞','😟','😤','😢','😭','😦','😧','😨','😩','🤯','😬','😰','😱','🥵','🥶','😳','🤪','😵','🥴','😠','😡','🤬','👍','👎','👌','✌️','🤞','🤟','🤘','🤙','👈','👉','👆','👇','☝️','✋','🤚','🖐','🖖','👋','🤙','💪','🙏','✍️','💅','🤳','💃','🕺','👯','🧘','🏃','🚶','🧍','🧎','💻','📱','⌨️','🖱','🖥','💾','💿','📀','🎮','🎯','🎲','🎰','🎳','🎪','🎨','🎬','🎤','🎧','🎼','🎹','🥁','🎷','🎺','🎸','🎻','🎭','🎪','🎨','🎬','🎤','🎧','🎼','🎹','🥁','💕','❤️','💔','💖','💗','💓','💞','💝','💘','❣️','💟','🔥','✨','💫','⭐','🌟','💥','💯','🎉','🎊','🎈','🎁','🏆','🥇','🥈','🥉','🏅','🎖'] %}
              <span class="emoji-item" data-emoji="{{ emoji }}">{{ emoji }}</span>
            {% endfor %}
          </div>
        </div>
        <!-- Submit Buttons -->
        <div class="d-flex gap-2">
          <button type="submit"
                  class="btn btn-gradient-primary rounded-pill px-4 py-2 fw-bold">
            <i class="bi bi-send-fill me-2"></i>
            <span id="submit-text">Post Comment</span>
          </button>
          <button type="reset"
                  class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold"
                  id="cancel-btn">
            <i class="bi bi-x-lg me-2"></i>Clear
          </button>
        </div>
      </form>
    </div>
  </div>
  <!-- Comments List -->
  <div id="comments-list-container">
    {% if comments|length > 0 %}
      <div id="comments-list" class="comments-list">
        {% for comment in comments %}{{ _self.render_comment(comment, user) }}{% endfor %}
      </div>
    {% else %}
      <div class="empty-state text-center py-5">
        <div class="empty-icon mb-3">
          <i class="bi bi-chat-dots-fill fs-1 text-muted opacity-50"></i>
        </div>
        <h5 class="text-muted mb-2">No comments yet</h5>
        <p class="text-muted">Be the first to share your thoughts!</p>
      </div>
    {% endif %}
  </div>
</div>
{# =========================================================
Recursive Comment Macro
========================================================= #}
{% macro render_comment(comment, current_user) %}
  <div class="comment-item modern-card"
       data-id="{{ comment.id }}"
       data-author="{{ comment.username ?: comment.guest_name ?: 'Guest' }}">
    <div class="comment-inner">
      <!-- Avatar & Header -->
      <div class="d-flex gap-3">
        <div class="comment-avatar">
          <div class="avatar-circle">
            {% if comment.user_avatar %}
              <img src="{{ comment.user_avatar }}" alt="Avatar" class="avatar-img">
            {% else %}
              <span class="avatar-initial">{{ (comment.username ?: comment.guest_name ?: 'G')|slice(0, 1) |upper }}</span>
            {% endif %}
          </div>
        </div>
        <div class="flex-grow-1">
          <!-- Header -->
          <div class="comment-header mb-2">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
              <div>
                <strong class="comment-author">{{ comment.username ?: comment.guest_name ?: 'Guest' }}</strong>
                {% if comment.user_role == 'admin' %}
                  <span class="badge bg-danger rounded-pill ms-2 admin-badge">
                    <i class="bi bi-shield-lock-fill"></i> Admin
                  </span>
                {% endif %}
                <div class="comment-date text-muted small">
                  <i class="bi bi-clock-history me-1"></i>
                  {{ comment.created_at|date("M d, Y \\a\\t H:i") }}
                </div>
              </div>
            </div>
          </div>
          <!-- Comment Content (View Mode) -->
          <div class="comment-content-view">
            <div class="comment-text markdown-content"
                 data-raw="{{ comment.content|e }}">
              {% if comment.content_html %}
                {{ comment.content_html|raw }}
              {% else %}
                {{ comment.content|e }}
              {% endif %}
            </div>
          </div>
          <!-- Comment Edit Mode -->
          <div class="comment-edit-mode d-none">
            <textarea class="comments-form-control comments-form-control-modern edit-textarea mb-2"
                      rows="4">{{ comment.content|e }}</textarea>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-success rounded-pill save-edit-btn">
                <i class="bi bi-check2-circle me-1"></i>Save
              </button>
              <button class="btn btn-sm btn-secondary rounded-pill cancel-edit-btn">
                <i class="bi bi-x-lg me-1"></i>Cancel
              </button>
            </div>
          </div>
          <!-- Reaction Bar -->
          <div class="reaction-bar mt-3">
            <div class="reaction-wrapper position-relative">
              <button class="reaction-trigger-btn" data-comment-id="{{ comment.id }}">
                <span class="reaction-icon">👍</span>
                <span class="reaction-label">React</span>
              </button>
              <!-- Reaction Panel (Hover) -->
              <div class="reaction-panel-popup">
                {% for reaction in ['👍','❤️','🔥','😂','😮','😢','🎉','💯'] %}
                  <button class="reaction-option"
                          data-reaction="{{ reaction }}"
                          title="{{ reaction }}">{{ reaction }}</button>
                {% endfor %}
              </div>
            </div>
            <!-- Reaction Summary -->
            {% if comment.reactions %}
              <div class="reactions-summary">
                {% for emoji, count in comment.reactions %}<span class="reaction-badge">{{ emoji }} {{ count }}</span>{% endfor %}
              </div>
            {% endif %}
          </div>
          <!-- Action Buttons -->
          <div class="comment-actions mt-3">
            <button class="action-btn reply-btn"
                    data-comment-id="{{ comment.id }}"
                    data-author="{{ comment.username ?: comment.guest_name }}">
              <i class="bi bi-reply-fill me-1"></i>Reply
            </button>
            {% if current_user and (current_user.id == comment.user_id or current_user.role == 'admin') %}
              <button class="action-btn edit-comment-btn">
                <i class="bi bi-pencil-fill me-1"></i>Edit
              </button>
              <button class="action-btn text-danger delete-comment-btn">
                <i class="bi bi-trash-fill me-1"></i>Delete
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
    <!-- Nested Replies -->
    {% if comment.replies|length > 0 %}
      <div class="replies-container">
        <div class="replies-list">
          {% for reply in comment.replies %}{{ _self.render_comment(reply, current_user) }}{% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
{% endmacro %}
{# =========================================================
External Dependencies
========================================================= #}
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
{# =========================================================
ISOLATED STYLES - Only affects .modern-comments-section
========================================================= #}
{# =========================================================
JavaScript - Enhanced with Better Error Handling
========================================================= #}
<script>
document.addEventListener('DOMContentLoaded', function() {

    // ==========================================
    // VARIABLES & ELEMENTS
    // ==========================================
    const form = document.getElementById('commentForm');
    const textarea = document.getElementById('comment-textarea');
    const charCount = document.getElementById('char-count');
    const commentsList = document.getElementById('comments-list');
    const feedbackDiv = document.getElementById('comment-feedback');
    const feedbackText = document.getElementById('feedback-text');
    const loadingDiv = document.getElementById('comment-loading');
    const emojiPicker = document.getElementById('emoji-picker');
    const emojiTrigger = document.querySelector('.emoji-trigger');
    const previewPanel = document.getElementById('markdown-preview');
    const previewContent = document.getElementById('preview-content');
    const togglePreviewBtn = document.getElementById('toggle-preview');
    const replyBanner = document.getElementById('reply-banner');
    const replyToName = document.getElementById('reply-to-name');
    const cancelReplyBtn = document.getElementById('cancel-reply');
    const parentIdField = document.getElementById('parent_id_field');
    const submitText = document.getElementById('submit-text');
    const cancelBtn = document.getElementById('cancel-btn');
    const totalCommentsSpan = document.getElementById('total-comments');

    let currentParentId = null;
    let isLoggedIn = {{ user.is_authenticated ? 'true' : 'false' }};
    let currentUserId = {{ user.id ?? 'null' }};

    // ==========================================
    // CHARACTER COUNTER
    // ==========================================
    textarea.addEventListener('input', function() {
        const length = this.value.length;
        charCount.textContent = length;

        if (length > 1800) {
            charCount.classList.add('text-danger');
            charCount.classList.remove('text-primary');
        } else {
            charCount.classList.add('text-primary');
            charCount.classList.remove('text-danger');
        }
    });

    // ==========================================
    // EMOJI PICKER
    // ==========================================
    emojiTrigger.addEventListener('click', function(e) {
        e.preventDefault();
        emojiPicker.classList.toggle('d-none');
    });

    // Close emoji picker when clicking outside
    document.addEventListener('click', function(e) {
        if (!emojiTrigger.contains(e.target) && !emojiPicker.contains(e.target)) {
            emojiPicker.classList.add('d-none');
        }
    });

    // Insert emoji on click
    emojiPicker.addEventListener('click', function(e) {
        if (e.target.classList.contains('emoji-item')) {
            const emoji = e.target.dataset.emoji;
            const cursorPos = textarea.selectionStart;
            const textBefore = textarea.value.substring(0, cursorPos);
            const textAfter = textarea.value.substring(cursorPos);

            textarea.value = textBefore + emoji + textAfter;
            textarea.focus();
            textarea.setSelectionRange(cursorPos + emoji.length, cursorPos + emoji.length);

            // Update character count
            charCount.textContent = textarea.value.length;

            emojiPicker.classList.add('d-none');
        }
    });

    // ==========================================
    // MARKDOWN BUTTONS
    // ==========================================
    document.querySelectorAll('.md-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const markdown = this.dataset.md;
            const cursorPos = textarea.selectionStart;
            const textBefore = textarea.value.substring(0, cursorPos);
            const textAfter = textarea.value.substring(cursorPos);

            textarea.value = textBefore + markdown + textAfter;
            textarea.focus();

            // Place cursor in the middle of markdown syntax
            let newPos = cursorPos + markdown.indexOf('text');
            if (newPos < cursorPos) newPos = cursorPos + markdown.length;
            textarea.setSelectionRange(newPos, newPos);

            charCount.textContent = textarea.value.length;
        });
    });

    // ==========================================
    // MARKDOWN PREVIEW
    // ==========================================
    togglePreviewBtn.addEventListener('click', function(e) {
        e.preventDefault();
        previewPanel.classList.toggle('d-none');

        if (!previewPanel.classList.contains('d-none')) {
            // Render markdown
            const rawText = textarea.value || '_Nothing to preview..._';
            previewContent.innerHTML = DOMPurify.sanitize(marked.parse(rawText));
            this.innerHTML = '<i class="bi bi-pencil-fill me-1"></i>Edit';
        } else {
            this.innerHTML = '<i class="bi bi-eye-fill me-1"></i>Preview';
        }
    });

    // Live preview update
    textarea.addEventListener('input', function() {
        if (!previewPanel.classList.contains('d-none')) {
            const rawText = this.value || '_Nothing to preview..._';
            previewContent.innerHTML = DOMPurify.sanitize(marked.parse(rawText));
        }
    });

    // ==========================================
    // REPLY FUNCTIONALITY
    // ==========================================
    function setupReply(commentId, authorName) {
        currentParentId = commentId;
        parentIdField.value = commentId;
        replyToName.textContent = authorName;
        replyBanner.classList.remove('d-none');
        submitText.textContent = 'Post Reply';

        // Scroll to form
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        textarea.focus();
    }

    cancelReplyBtn.addEventListener('click', function(e) {
        e.preventDefault();
        currentParentId = null;
        parentIdField.value = '';
        replyBanner.classList.add('d-none');
        submitText.textContent = 'Post Comment';
    });

    // ==========================================
    // FORM SUBMISSION
    // ==========================================
    form.addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(form);

        // Show loading
        loadingDiv.classList.remove('d-none');

        fetch('/comment/add', {
            method: 'POST',
            body: formData
        })
        .then(response => response.json())
        .then(data => {
            loadingDiv.classList.add('d-none');

            if (data.success) {
                showFeedback('Comment posted successfully!', 'success');

                // Reset form
                form.reset();
                charCount.textContent = '0';
                previewPanel.classList.add('d-none');
                emojiPicker.classList.add('d-none');

                // Reset reply state
                if (currentParentId) {
                    currentParentId = null;
                    parentIdField.value = '';
                    replyBanner.classList.add('d-none');
                    submitText.textContent = 'Post Comment';
                }

                // Reload page after 1 second
                setTimeout(() => {
                    location.reload();
                }, 1000);

            } else {
                showFeedback(data.message || 'Failed to post comment', 'danger');
            }
        })
        .catch(error => {
            loadingDiv.classList.add('d-none');
            showFeedback('An error occurred. Please try again.', 'danger');
            console.error('Error:', error);
        });
    });

    // Cancel button
    cancelBtn.addEventListener('click', function() {
        charCount.textContent = '0';
        previewPanel.classList.add('d-none');
        emojiPicker.classList.add('d-none');

        if (currentParentId) {
            currentParentId = null;
            parentIdField.value = '';
            replyBanner.classList.add('d-none');
            submitText.textContent = 'Post Comment';
        }
    });

    // ==========================================
    // FEEDBACK MESSAGES
    // ==========================================
    function showFeedback(message, type = 'info') {
        feedbackText.textContent = message;
        feedbackDiv.className = `alert alert-${type} alert-dismissible fade show`;
        feedbackDiv.classList.remove('d-none');

        setTimeout(() => {
            feedbackDiv.classList.add('d-none');
        }, 5000);
    }

    // ==========================================
    // DELEGATED EVENT LISTENERS (Comments List)
    // ==========================================
    if (commentsList) {
        commentsList.addEventListener('click', function(e) {
            const commentItem = e.target.closest('.comment-item');
            if (!commentItem) return;

            const commentId = commentItem.dataset.id;
            const authorName = commentItem.dataset.author;

            // ========== REPLY BUTTON ==========
            if (e.target.closest('.reply-btn')) {
                e.preventDefault();
                setupReply(commentId, authorName);
            }

            // ========== EDIT BUTTON ==========
            if (e.target.closest('.edit-comment-btn')) {
                e.preventDefault();
                const viewMode = commentItem.querySelector('.comment-content-view');
                const editMode = commentItem.querySelector('.comment-edit-mode');

                viewMode.classList.add('d-none');
                editMode.classList.remove('d-none');
            }

            // ========== SAVE EDIT ==========
            if (e.target.closest('.save-edit-btn')) {
                e.preventDefault();
                const editTextarea = commentItem.querySelector('.edit-textarea');
                const newContent = editTextarea.value.trim();

                if (!newContent || newContent.length < 2) {
                    showFeedback('Comment must be at least 2 characters', 'warning');
                    return;
                }

                loadingDiv.classList.remove('d-none');

                fetch('/comment/edit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        comment_id: commentId,
                        content: newContent
                    })
                })
                .then(r => r.json())
                .then(d => {
                    loadingDiv.classList.add('d-none');
                    if (d.success) {
                        showFeedback('Comment updated successfully!', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showFeedback(d.message || 'Failed to edit comment', 'danger');
                    }
                })
                .catch(err => {
                    loadingDiv.classList.add('d-none');
                    showFeedback('Error editing comment', 'danger');
                });
            }

            // ========== CANCEL EDIT ==========
            if (e.target.closest('.cancel-edit-btn')) {
                e.preventDefault();
                const viewMode = commentItem.querySelector('.comment-content-view');
                const editMode = commentItem.querySelector('.comment-edit-mode');

                editMode.classList.add('d-none');
                viewMode.classList.remove('d-none');
            }

            // ========== DELETE BUTTON ==========
            if (e.target.closest('.delete-comment-btn')) {
                e.preventDefault();

                if (!confirm('Are you sure you want to delete this comment?')) {
                    return;
                }

                loadingDiv.classList.remove('d-none');

                fetch('/comment/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ comment_id: commentId })
                })
                .then(r => r.json())
                .then(d => {
                    loadingDiv.classList.add('d-none');
                    if (d.success) {
                        showFeedback('Comment deleted successfully!', 'success');
                        commentItem.style.opacity = '0';
                        commentItem.style.transform = 'scale(0.9)';
                        setTimeout(() => commentItem.remove(), 300);

                        // Update total count
                        const currentCount = parseInt(totalCommentsSpan.textContent);
                        totalCommentsSpan.textContent = currentCount - 1;
                    } else {
                        showFeedback(d.message || 'Failed to delete comment', 'danger');
                    }
                })
                .catch(err => {
                    loadingDiv.classList.add('d-none');
                    showFeedback('Error deleting comment', 'danger');
                });
            }

            // ========== REACTION BUTTONS ==========
            if (e.target.closest('.reaction-option')) {
                e.preventDefault();
                const reactionBtn = e.target.closest('.reaction-option');
                const reaction = reactionBtn.dataset.reaction;

                fetch('/comment/react', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        comment_id: commentId,
                        reaction: reaction
                    })
                })
                .then(r => r.json())
                .then(d => {
                    if (d.success) {
                        // Update reaction summary
                        const reactionBar = commentItem.querySelector('.reaction-bar');
                        let summaryDiv = reactionBar.querySelector('.reactions-summary');

                        if (!summaryDiv) {
                            summaryDiv = document.createElement('div');
                            summaryDiv.className = 'reactions-summary';
                            reactionBar.appendChild(summaryDiv);
                        }

                        // Update with new reaction data
                        if (d.reactions && Object.keys(d.reactions).length > 0) {
                            summaryDiv.innerHTML = Object.entries(d.reactions)
                                .map(([emoji, count]) => `<span class="reaction-badge">${emoji} ${count}</span>`)
                                .join('');
                        } else {
                            summaryDiv.innerHTML = '';
                        }

                        showFeedback('Reaction added!', 'success');
                    } else {
                        showFeedback(d.message || 'Failed to add reaction', 'warning');
                    }
                })
                .catch(err => {
                    showFeedback('Error adding reaction', 'danger');
                    console.error('Reaction error:', err);
                });
            }
        });
    }

    // ==========================================
    // GUEST NAME PERSISTENCE (LocalStorage)
    // ==========================================
    if (!isLoggedIn) {
        const guestNameInput = document.getElementById('guest_name_input');

        if (guestNameInput) {
            // Load saved guest name
            const savedName = localStorage.getItem('guest_name');
            const savedExpiry = localStorage.getItem('guest_name_expiry');

            if (savedName && savedExpiry && Date.now() < parseInt(savedExpiry)) {
                guestNameInput.value = savedName;
            }

            // Save guest name on form submit
            form.addEventListener('submit', function() {
                const guestName = guestNameInput.value.trim();
                if (guestName) {
                    localStorage.setItem('guest_name', guestName);
                    // Expire after 7 days
                    const expiry = Date.now() + (7 * 24 * 60 * 60 * 1000);
                    localStorage.setItem('guest_name_expiry', expiry.toString());
                }
            });
        }
    }

    // ==========================================
    // SMOOTH ANIMATIONS ON LOAD
    // ==========================================
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, { threshold: 0.1 });

    document.querySelectorAll('.comment-item').forEach(item => {
        item.style.opacity = '0';
        item.style.transform = 'translateY(20px)';
        item.style.transition = 'all 0.5s ease';
        observer.observe(item);
    });

    // ==========================================
    // KEYBOARD SHORTCUTS
    // ==========================================
    textarea.addEventListener('keydown', function(e) {
        // Ctrl/Cmd + Enter to submit
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            form.dispatchEvent(new Event('submit'));
        }

        // Ctrl/Cmd + P to toggle preview
        if ((e.ctrlKey || e.metaKey) && e.key === 'p') {
            e.preventDefault();
            togglePreviewBtn.click();
        }
    });

    // ==========================================
    // AUTO-SAVE DRAFT (Optional)
    // ==========================================
    let autoSaveTimer;
    textarea.addEventListener('input', function() {
        clearTimeout(autoSaveTimer);
        autoSaveTimer = setTimeout(() => {
            const draft = this.value;
            if (draft.length > 10) {
                localStorage.setItem('comment_draft_{{ content_type }}_{{ content_id }}', draft);
            }
        }, 2000);
    });

    // Restore draft on page load
    const savedDraft = localStorage.getItem('comment_draft_{{ content_type }}_{{ content_id }}');
    if (savedDraft && !textarea.value) {
        textarea.value = savedDraft;
        charCount.textContent = savedDraft.length;
    }

    // Clear draft on successful submit
    form.addEventListener('submit', function() {
        localStorage.removeItem('comment_draft_{{ content_type }}_{{ content_id }}');
    });

    console.log('✅ Modern Comments System Initialized');
});
</script>
