<script>
    // Public mode ensures Puter will not attempt to sign in by default.
    window.PUTER_PROXY_PUBLIC_ONLY = true;
    (function () {
        const publicOnly = Boolean(window.PUTER_PROXY_PUBLIC_ONLY);
        const badge = document.getElementById('adminAssistantPublicModeBadge');
        const signInBtn = document.getElementById('btnPuterSignIn');
        if (badge) badge.classList.toggle('d-none', !publicOnly);
        if (signInBtn) signInBtn.classList.toggle('d-none', publicOnly);
    })();
</script>
