                <button id="adminAiSend" class="btn btn-primary btn-sm rounded-circle">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Trigger Button (Top Nav or Bottom Right) -->
