        <div class="ai-header-info">
            <h3 class="ai-header-title" id="adminAiTitle">
                <i class="bi bi-robot"></i> Copilot
            </h3>
            <span class="ai-header-context" id="adminAiContextBadge">
                Context: <span class="badge bg-secondary">Global</span>
            </span>
        </div>
        <button id="adminAiClose" class="modern-btn-close ai-close" title="Close Sidebar"></button>
    </div>

    <!-- Body: Chat & Artifacts -->
    <div id="adminAiBody" class="ai-body custom-scrollbar">
        {# Messages & Artifacts injected via ai-admin.js #}
    </div>

    <!-- Slash Menu Prompt (Hidden until '/' is typed) -->
    <div id="adminAiSlashMenu" class="ai-slash-menu d-none">
