                            <option value="high">High</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>Image Model</span>
                        <select id="adminAssistantImageModel">
                            <option value="gpt-image-1.5" selected>gpt-image-1.5</option>
                            <option value="gpt-image-1-mini">gpt-image-1-mini</option>
                            <option value="gpt-image-1">gpt-image-1</option>
                            <option value="dall-e-3">dall-e-3</option>
                            <option value="dall-e-2">dall-e-2</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>Image Ratio</span>
                        <select id="adminAssistantImageAspect">
                            <option value="1:1" selected>1:1</option>
                            <option value="16:9">16:9</option>
                            <option value="9:16">9:16</option>
                            <option value="4:3">4:3</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>TTS Voice</span>
                        <select id="adminAssistantTtsVoice">
                            <option value="alloy" selected>Alloy</option>
                            <option value="ash">Ash</option>
                            <option value="ballad">Ballad</option>
                            <option value="coral">Coral</option>
                            <option value="echo">Echo</option>
                            <option value="nova">Nova</option>
                            <option value="sage">Sage</option>
                            <option value="shimmer">Shimmer</option>
                        </select>
                    </label>
                </div>
                <div class="assistant-feature-actions">
                    <input type="file" id="adminAssistantFileInput" class="d-none" multiple>
                    <input type="file" id="adminAssistantVisionInput" class="d-none" accept="image/*" multiple>
                    <button type="button" id="btnAttachVision" class="assistant-mini-btn">
                        <i class="bi bi-image"></i>
                        <span>Attach Image</span>
                    </button>
                    <button type="button" id="btnGenerateImage" class="assistant-mini-btn">
                        <i class="bi bi-stars"></i>
                        <span>Generate Image</span>
                    </button>
                    <button type="button" id="btnSpeakLastReply" class="assistant-mini-btn">
                        <i class="bi bi-volume-up"></i>
                        <span>Speak Reply</span>
                    </button>
                </div>
                <input type="url" id="adminAssistantImageUrl" class="assistant-inline-input" placeholder="Optional image URL for vision analysis">
                <div id="adminAssistantAttachmentName" class="assistant-attachment-pill d-none"></div>
            </div>
        </div>
        <div id="adminAssistantReasoningBanner" class="assistant-reasoning-banner d-none"></div>

        <div id="assistantMessages" class="admin-assistant-messages">
