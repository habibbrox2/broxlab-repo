{% set assistant_include_manage_chats = assistant_include_manage_chats|default(false) %}
<div id="adminAssistantWrapper" class="admin-assistant-wrapper bb-assistant-admin">
    <div class="assistant-console-stack" aria-label="Assistant Console">
        <div class="assistant-console-menu">
            <button type="button" id="adminAssistantSettingsToggle" class="assistant-console-btn" title="Controls" aria-label="Controls">
                <i class="bi bi-sliders"></i>
            </button>
            <button type="button" id="btnNewChat" class="assistant-console-btn" title="New Chat" aria-label="New Chat">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
            <button type="button" id="btnUploadFiles" class="assistant-console-btn" title="Upload Files" aria-label="Upload Files">
                <i class="bi bi-plus-lg"></i>
            </button>
            <button type="button" id="btnViewUploads" class="assistant-console-btn" title="View Uploads" aria-label="View Uploads">
                <i class="bi bi-folder2-open"></i>
            </button>
            {% if assistant_include_manage_chats %}
            <button type="button" id="btnManageChats" class="assistant-console-btn" title="Manage Chats" aria-label="Manage Chats">
                <i class="bi bi-chat-left-dots"></i>
            </button>
            {% endif %}
        </div>
        <button id="adminAssistantBtn" class="admin-assistant-fab" title="AI Assistant" aria-label="Open AI Assistant">
            <i class="bi bi-robot"></i>
        </button>
    </div>

    <div id="adminAssistantChat" class="admin-assistant-chat hidden d-none">
        <div class="admin-assistant-header">
            <div class="d-flex align-items-center gap-2">
                <div class="bg-primary rounded-circle p-1 d-flex">
                    <i class="bi bi-robot text-white" style="font-size: 1rem;"></i>
                </div>
                <div class="lh-1">
                    <div class="fw-bold small" id="adminAssistantTitle">Brox Assistant</div>
                    <div class="d-flex align-items-center gap-2">
                        <span id="adminAssistantStatusIndicator" class="assistant-status-indicator"></span>
                        <div id="adminAssistantStatus" class="text-white-50" style="font-size: 0.7rem;">Initializing...</div>
                        <span id="adminAssistantPublicModeBadge" class="badge bg-success text-dark small d-none" style="font-weight: 400;">Public</span>
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 ms-auto">
                <div class="assistant-lang-toggle" role="group" aria-label="Language toggle">
                    <button type="button" id="adminAssistantLangBn" class="btn btn-sm btn-light active">Bangla</button>
                    <button type="button" id="adminAssistantLangEn" class="btn btn-sm btn-outline-light">EN</button>
                </div>
                <button type="button" id="btnPuterSignIn" class="btn btn-sm btn-outline-light d-none" title="Sign in to Puter">Sign in</button>
                <button type="button" id="closeAssistant" class="btn-close btn-close-white"></button>
            </div>
        </div>

        <div class="assistant-control-bar">
            <div class="assistant-control-heading">
                <div>
                    <strong>AI Controls</strong>
                    <span>Mode, model, file context, vision, image and speech tools</span>
                </div>
            </div>
            <div class="assistant-control-row">
                <select id="adminAssistantMode" class="assistant-select" aria-label="Assistant mode">
                    <option value="assistant">Admin Assistant</option>
                    <option value="openai">OpenAI Chat</option>
                    <option value="codex">Codex</option>
                    <option value="gpt_oss">GPT-OSS</option>
                    <option value="vision">Vision</option>
                </select>
                <select id="adminAssistantModel" class="assistant-select" aria-label="Assistant model">
                    <option value="">Auto Model</option>
                </select>
            </div>
            <div id="adminAssistantAdvancedPanel" class="assistant-advanced-panel d-none">
                <div class="assistant-chip-row">
                    <label class="assistant-chip">
                        <input type="checkbox" id="adminAssistantStream" checked>
                        <span>Stream</span>
                    </label>
                    <label class="assistant-chip">
                        <input type="checkbox" id="adminAssistantWebSearch">
                        <span>Web Search</span>
                    </label>
                </div>
                <div class="assistant-settings-grid">
                    <label class="assistant-setting">
                        <span>Temperature</span>
                        <input type="range" id="adminAssistantTemperature" min="0" max="2" step="0.1" value="0.7">
                        <strong id="adminAssistantTemperatureValue">0.7</strong>
                    </label>
                    <label class="assistant-setting">
                        <span>Max Tokens</span>
                        <input type="number" id="adminAssistantMaxTokens" min="64" max="8192" step="64" value="1024">
                    </label>
                    <label class="assistant-setting">
                        <span>Reasoning</span>
                        <select id="adminAssistantReasoning">
                            <option value="">Default</option>
                            <option value="minimal">Minimal</option>
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                            <option value="xhigh">XHigh</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>Verbosity</span>
                        <select id="adminAssistantVerbosity">
                            <option value="low">Low</option>
                            <option value="medium" selected>Medium</option>
                            <option value="high">High</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>Image Model</span>
                        <select id="adminAssistantImageModel">
                            <option value="gpt-image-1.5" selected>gpt-image-1.5</option>
                            <option value="gpt-image-1-mini">gpt-image-1-mini</option>
                            <option value="gpt-image-1">gpt-image-1</option>
                            <option value="dall-e-3">dall-e-3</option>
                            <option value="dall-e-2">dall-e-2</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>Image Ratio</span>
                        <select id="adminAssistantImageAspect">
                            <option value="1:1" selected>1:1</option>
                            <option value="16:9">16:9</option>
                            <option value="9:16">9:16</option>
                            <option value="4:3">4:3</option>
                        </select>
                    </label>
                    <label class="assistant-setting">
                        <span>TTS Voice</span>
                        <select id="adminAssistantTtsVoice">
                            <option value="alloy" selected>Alloy</option>
                            <option value="ash">Ash</option>
                            <option value="ballad">Ballad</option>
                            <option value="coral">Coral</option>
                            <option value="echo">Echo</option>
                            <option value="nova">Nova</option>
                            <option value="sage">Sage</option>
                            <option value="shimmer">Shimmer</option>
                        </select>
                    </label>
                </div>
                <div class="assistant-feature-actions">
                    <input type="file" id="adminAssistantFileInput" class="d-none" multiple>
                    <input type="file" id="adminAssistantVisionInput" class="d-none" accept="image/*" multiple>
                    <button type="button" id="btnAttachVision" class="assistant-mini-btn">
                        <i class="bi bi-image"></i>
                        <span>Attach Image</span>
                    </button>
                    <button type="button" id="btnGenerateImage" class="assistant-mini-btn">
                        <i class="bi bi-stars"></i>
                        <span>Generate Image</span>
                    </button>
                    <button type="button" id="btnSpeakLastReply" class="assistant-mini-btn">
                        <i class="bi bi-volume-up"></i>
                        <span>Speak Reply</span>
                    </button>
                </div>
                <input type="url" id="adminAssistantImageUrl" class="assistant-inline-input" placeholder="Optional image URL for vision analysis">
                <div id="adminAssistantAttachmentName" class="assistant-attachment-pill d-none"></div>
            </div>
        </div>
        <div id="adminAssistantReasoningBanner" class="assistant-reasoning-banner d-none"></div>

        <div id="assistantMessages" class="admin-assistant-messages">
            <div id="adminAssistantLoading" class="typing-indicator d-none" aria-live="polite">
                <span id="adminAssistantTypingText">Typing...</span>
                <span class="typing-dots"><span></span><span></span><span></span></span>
            </div>
            <div class="message assistant">
                Hello! I am your AI Assistant. How can I help you manage BroxLab today?
            </div>
        </div>

        <div class="admin-assistant-footer">
            <div class="assistant-footer-meta">
                <span>Assistant Console</span>
                <span>Admin Workspace</span>
            </div>
            <div class="assistant-composer">
                <div class="assistant-input-wrap">
                    <input type="text" id="assistantInput" class="assistant-input" placeholder="Ask me anything...">
                    <button class="assistant-send-btn-modern" type="button" id="sendToAssistant" aria-label="Send">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-assistant-wrapper {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        font-family: "Segoe UI", "Noto Sans Bengali", sans-serif;
    }
    #adminAssistantWrapper .assistant-console-stack {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        position: relative;
        z-index: 2;
    }
    #adminAssistantWrapper .assistant-console-menu {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 8px;
        padding: 8px;
        border: 1px solid #d6dee8;
        border-radius: 10px;
        background: #ffffff;
        opacity: 0;
        pointer-events: none;
        transform: translateY(8px);
        transition: opacity 0.18s ease, transform 0.18s ease;
    }
    #adminAssistantWrapper:hover .assistant-console-menu,
    #adminAssistantWrapper:focus-within .assistant-console-menu {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
    }
    #adminAssistantWrapper .assistant-console-btn,
    .admin-assistant-fab {
        width: 46px;
        height: 46px;
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        background: #ffffff;
        color: #1e293b;
        font-size: 18px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease;
        box-shadow: none;
    }
    #adminAssistantWrapper .assistant-console-btn:hover,
    .admin-assistant-fab:hover {
        background: #f8fafc;
        border-color: #94a3b8;
        color: #0f172a;
    }
    .admin-assistant-chat {
        position: absolute;
        bottom: 62px;
        right: 0;
        width: min(390px, calc(100vw - 32px));
        height: min(620px, calc(100vh - 112px));
        background: #ffffff;
        border-radius: 12px;
        box-shadow: none;
        flex-direction: column;
        overflow: hidden;
        display: flex;
        border: 1px solid #cfd8e3;
    }
    #adminAssistantWrapper .admin-assistant-header {
        background: #1f2937;
        color: #f8fafc;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        border-bottom: 1px solid #374151;
    }
    #adminAssistantWrapper .assistant-control-bar {
        padding: 12px 14px;
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
    }
    #adminAssistantWrapper .assistant-control-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    #adminAssistantWrapper .assistant-control-heading strong {
        display: block;
        color: #111827;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }
    #adminAssistantWrapper .assistant-control-heading span {
        display: block;
        margin-top: 2px;
        color: #6b7280;
        font-size: 0.71rem;
        line-height: 1.4;
    }
    #adminAssistantWrapper .assistant-control-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 8px;
        align-items: center;
        margin-bottom: 10px;
    }
    #adminAssistantWrapper .assistant-select,
    #adminAssistantWrapper .assistant-inline-input,
    #adminAssistantWrapper .assistant-setting input[type="number"],
    #adminAssistantWrapper .assistant-setting select {
        width: 100%;
        min-width: 0;
        border: 1px solid #cfd8e3;
        border-radius: 8px;
        background: #ffffff;
        color: #1e293b;
        padding: 10px 12px;
        font-size: 0.8rem;
        outline: none;
        box-shadow: none;
    }
    #adminAssistantWrapper .assistant-select:focus,
    #adminAssistantWrapper .assistant-inline-input:focus,
    #adminAssistantWrapper .assistant-setting input[type="number"]:focus,
    #adminAssistantWrapper .assistant-setting select:focus {
        border-color: #64748b;
        box-shadow: 0 0 0 3px rgba(148, 163, 184, 0.2);
    }
    #adminAssistantWrapper .assistant-advanced-panel {
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #dbe3ec;
        background: #f8fafc;
        box-shadow: none;
    }
    #adminAssistantWrapper .assistant-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
    }
    #adminAssistantWrapper .assistant-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid #d5dde7;
        background: #ffffff;
        color: #334155;
        font-size: 0.75rem;
        cursor: pointer;
    }
    #adminAssistantWrapper .assistant-chip input {
        accent-color: #334155;
        margin: 0;
    }
    #adminAssistantWrapper .assistant-settings-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }
    #adminAssistantWrapper .assistant-setting {
        display: flex;
        flex-direction: column;
        gap: 6px;
        color: #475569;
        font-size: 0.72rem;
    }
    #adminAssistantWrapper .assistant-setting span {
        font-weight: 600;
        letter-spacing: 0.04em;
        color: #334155;
    }
    #adminAssistantWrapper .assistant-setting strong {
        font-size: 0.72rem;
        color: #0f172a;
    }
    #adminAssistantWrapper .assistant-setting input[type="range"] {
        width: 100%;
        accent-color: #475569;
    }
    #adminAssistantWrapper .assistant-feature-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
        margin-bottom: 10px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
    }
    #adminAssistantWrapper .assistant-mini-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 8px;
        border: 1px solid #d1d9e4;
        background: #ffffff;
        color: #334155;
        font-size: 0.75rem;
        cursor: pointer;
        transition: transform 0.18s ease, background 0.18s ease;
    }
    #adminAssistantWrapper .assistant-mini-btn:hover {
        transform: translateY(-1px);
        background: #f1f5f9;
    }
    #adminAssistantWrapper .assistant-inline-input {
        margin-bottom: 10px;
    }
    #adminAssistantWrapper .assistant-attachment-pill,
    #adminAssistantWrapper .assistant-reasoning-banner {
        margin: 0 14px 10px;
        border-radius: 8px;
        border: 1px solid #d8e0ea;
        background: #f8fafc;
        color: #334155;
        padding: 10px 12px;
        font-size: 0.76rem;
        line-height: 1.5;
    }
    #adminAssistantWrapper .assistant-reasoning-banner {
        white-space: pre-wrap;
        color: #475569;
    }
    #adminAssistantWrapper .admin-assistant-messages {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    #adminAssistantWrapper .message {
        padding: 10px 13px;
        border-radius: 8px;
        font-size: 0.86rem;
        max-width: 88%;
        line-height: 1.55;
        position: relative;
        word-break: break-word;
    }
    #adminAssistantWrapper .message.assistant {
        background: #ffffff;
        color: #1f2937;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #dbe3ec;
        box-shadow: none;
    }
    #adminAssistantWrapper .message.user {
        background: #e2e8f0;
        border: 1px solid #cbd5e1;
        color: #1e293b;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
        box-shadow: none;
    }
    #adminAssistantWrapper .message-time {
        margin-top: 5px;
        font-size: 0.72rem;
        opacity: 0.74;
        color: inherit;
    }
    #adminAssistantWrapper .assistant-message-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 8px;
    }
    #adminAssistantWrapper .assistant-message-action-btn {
        width: 30px;
        height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        border: 1px solid #d6dee8;
        background: #ffffff;
        color: #475569;
        cursor: pointer;
        transition: background 0.18s ease, color 0.18s ease;
    }
    #adminAssistantWrapper .assistant-message-action-btn:hover {
        background: #f1f5f9;
        color: #0f172a;
    }
    #adminAssistantWrapper .assistant-stream-reasoning {
        margin-bottom: 8px;
        padding: 8px 10px;
        border-radius: 8px;
        background: #f8fafc;
        border: 1px dashed #c7d2de;
        color: #475569;
        font-size: 0.72rem;
        white-space: pre-wrap;
    }
    #adminAssistantWrapper .assistant-image-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    #adminAssistantWrapper .assistant-image-card img {
        width: 100%;
        border-radius: 8px;
        border: 1px solid #d6dee8;
        box-shadow: none;
    }
    #adminAssistantWrapper .assistant-image-card a {
        align-self: flex-start;
        color: #334155;
        text-decoration: none;
        font-size: 0.78rem;
        font-weight: 600;
    }
    #adminAssistantWrapper .assistant-lang-toggle {
        display: flex;
        gap: 4px;
        padding: 3px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
    }
    #adminAssistantWrapper .assistant-lang-toggle .btn {
        padding: 4px 9px;
        font-size: 0.72rem;
        line-height: 1.2;
        border-radius: 999px;
        border: none;
    }
    #adminAssistantWrapper .typing-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        font-size: 0.78rem;
        color: #475569;
        width: fit-content;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid #d6dee8;
    }
    #adminAssistantWrapper .typing-dots {
        display: inline-flex;
        gap: 4px;
        align-items: center;
    }
    #adminAssistantWrapper .typing-dots span {
        width: 6px;
        height: 6px;
        background: #64748b;
        border-radius: 50%;
        animation: bounce 1.4s infinite ease-in-out both;
        opacity: 0.65;
    }
    #adminAssistantWrapper .typing-dots span:nth-child(1) {
        animation-delay: -0.32s;
    }
    #adminAssistantWrapper .typing-dots span:nth-child(2) {
        animation-delay: -0.16s;
    }
    #adminAssistantWrapper .typing-indicator.active {
        display: flex !important;
    }
    #adminAssistantWrapper .assistant-status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #dc3545;
        display: inline-block;
        transition: background 0.2s ease;
        margin-right: 6px;
    }
    #adminAssistantWrapper .assistant-status-indicator.ready {
        background: #28a745;
    }
    #adminAssistantWrapper .admin-assistant-footer {
        padding: 14px;
        background: #ffffff;
        border-top: 1px solid #dbe3ec;
    }
    #adminAssistantWrapper .assistant-footer-meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64748b;
    }
    #adminAssistantWrapper .assistant-composer {
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 8px;
        border: 1px solid #d6dee8;
        background: #ffffff;
        padding: 8px;
        box-shadow: none;
    }
    #adminAssistantWrapper .assistant-input-wrap {
        flex: 1;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    #adminAssistantWrapper .assistant-input {
        flex: 1;
        min-width: 0;
        border: none;
        background: transparent;
        color: #0f172a;
        font-size: 0.86rem;
        padding: 6px 2px;
        outline: none;
    }
    #adminAssistantWrapper .assistant-input::placeholder {
        color: #94a3b8;
    }
    #adminAssistantWrapper .assistant-send-btn-modern {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        border-radius: 6px;
        background: #1f2937;
        color: #f8fafc;
        cursor: pointer;
        box-shadow: none;
        transition: background 0.18s ease;
        flex-shrink: 0;
    }
    #adminAssistantWrapper .assistant-send-btn-modern:hover {
        transform: none;
        background: #111827;
    }
    #adminAssistantWrapper .hidden {
        opacity: 0;
        pointer-events: none;
        transform: translateY(10px) scale(0.98);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #adminAssistantChat:not(.hidden) {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0) scale(1);
    }
    @keyframes bounce {
        from {
            transform: translateY(0);
        }
        to {
            transform: translateY(-4px);
        }
    }
    @media (max-width: 576px) {
        .admin-assistant-chat {
            right: 0;
            width: min(100vw - 24px, 368px);
            height: min(72vh, 560px);
        }
        #adminAssistantWrapper .assistant-control-row,
        #adminAssistantWrapper .assistant-settings-grid {
            grid-template-columns: 1fr;
        }
        #adminAssistantWrapper .assistant-feature-actions {
            flex-direction: column;
        }
    }
</style>
<script>
    // Public mode ensures Puter will not attempt to sign in by default.
    window.PUTER_PROXY_PUBLIC_ONLY = true;
    (function () {
        const publicOnly = Boolean(window.PUTER_PROXY_PUBLIC_ONLY);
        const badge = document.getElementById('adminAssistantPublicModeBadge');
        const signInBtn = document.getElementById('btnPuterSignIn');
        if (badge) badge.classList.toggle('d-none', !publicOnly);
        if (signInBtn) signInBtn.classList.toggle('d-none', publicOnly);
    })();
</script>
<script type="module" src="{{ asset('/assets/ai-assistant/bootstrap/admin-assistant.js') }}"></script>
