            <li class="list-group-item list-group-item-action" data-cmd="/summarize">
                <strong><i class="bi bi-body-text"></i> /summarize</strong> <small class="text-muted">Summarize page data</small>
            </li>
            <li class="list-group-item list-group-item-action" data-cmd="/generate-report">
                <strong><i class="bi bi-file-earmark-bar-graph"></i> /generate-report</strong> <small class="text-muted">Create analytics report</small>
            </li>
            <li class="list-group-item list-group-item-action" data-cmd="/query-db">
