{# Premium AI Assistant Shell for Visitors #}
<div id="aiShell" class="ai-chat-shell hidden">
    <div class="ai-header">
        <div class="ai-header-info">
            <div class="ai-header-title" id="aiTitle">Brox Automation</div>
            <div class="ai-header-status" id="aiStatus">Online</div>
        </div>
        <div class="ai-header-actions">
            <div class="ai-lang-toggle">
                <button id="aiLangBn" class="active">BN</button>
                <button id="aiLangEn">EN</button>
            </div>
            <button id="aiClose" class="btn-close btn-close-white ms-2" style="font-size: 0.8rem;"></button>
        </div>
    </div>

    {# Chat History Body #}
    <div id="aiBody" class="ai-body d-none">
        {# Messages injected via assistant.js #}
    </div>

    {# Pre-chat Data Collection (Parity Feature) #}
    <div id="aiPrechat" class="ai-body">
        <div class="ai-prechat">
            <div class="ai-form-group">
                <label for="aiUserName">Your Name</label>
                <input type="text" id="aiUserName" class="ai-input" placeholder="Enter your name...">
            </div>
            <div class="ai-form-group">
                <label for="aiUserTopics">How can we help you?</label>
                <div class="ai-topic-grid">
                    <label class="ai-topic-chip">
                        <input type="checkbox" value="Web Design"> 🎨 Web Design
                    </label>
                    <label class="ai-topic-chip">
                        <input type="checkbox" value="SEO/Marketing"> 🚀 Marketing
                    </label>
                    <label class="ai-topic-chip">
                        <input type="checkbox" value="Software Support"> 🔧 Support
                    </label>
                    <label class="ai-topic-chip">
                        <input type="checkbox" value="Billing/General"> 💳 Billing
                    </label>
                </div>
            </div>
            <button id="aiStartBtn" class="ai-btn-primary">Start Chatting</button>
        </div>
    </div>

    {# Chat Input Footer #}
    <div id="aiFooter" class="ai-footer d-none">
        <div class="ai-composer">
            <input type="text" id="aiInput" placeholder="Ask anything...">
            <button id="aiSend" class="ai-send-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                </svg>
            </button>
        </div>
    </div>
</div>

{# Floating Toggle Button #}
<button id="aiBtn" class="ai-btn-toggle">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
</button>
