<!-- First-Time OAuth User Password Setup Modal -->
<!-- Include this in layout.twig or dashboard.twig -->

<div class="modal fade" id="firstTimePasswordSetupModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-shield-fill me-2"></i> Secure Your Account
                </h5>
            </div>
            <div class="modal-body">
                <div class="alert alert-info alert-dismissible" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Welcome!</strong> To ensure your account security, please set a password. 
                    This will allow you to login with your email and password, in addition to your Google account.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                
                <form id="firstTimePasswordForm">
                    <div class="mb-3">
                        <label for="first_password" class="form-label fw-bold">Create a Strong Password</label>
                        <div class="input-group">
                            <input type="password" class="form-control form-control-lg" id="first_password" name="password" required 
                                   placeholder="Minimum 8 characters with mix of characters">
                            <button class="btn btn-outline-secondary" type="button" id="toggle-first-pwd">
                                <i class="bi bi-eye-fill"></i>
                            </button>
                        </div>
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-check-circle-fill text-success me-1"></i> At least 8 characters<br>
                            <i class="bi bi-check-circle-fill text-success me-1"></i> Uppercase letter (A-Z)<br>
                            <i class="bi bi-check-circle-fill text-success me-1"></i> Lowercase letter (a-z)<br>
                            <i class="bi bi-check-circle-fill text-success me-1"></i> Number (0-9)<br>
                            <i class="bi bi-check-circle-fill text-success me-1"></i> Special character (!@#$%^&* etc)
                        </small>
                    </div>
                    
                    <div class="mb-3">
                        <div class="progress inl-c-0007">
                            <div id="first-strength-bar" class="progress-bar inl-c-0004" role="progressbar"></div>
                        </div>
                        <small id="strength-text" class="text-muted">Password strength: Very Weak</small>
                    </div>
                    
                    <div class="mb-3">
                        <label for="first_confirm_password" class="form-label fw-bold">Confirm Password</label>
                        <input type="password" class="form-control form-control-lg" id="first_confirm_password" name="password_confirm" required 
                               placeholder="Re-enter your password">
                    </div>
                    
                    <div id="password-error" class="alert alert-danger d-none" role="alert"></div>
                    
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                </form>
            </div>
            <div class="modal-footer bg-light">
                <small class="text-muted">Your password is encrypted and secure</small>
                <div class="ms-auto">
                    <button type="button" class="btn btn-secondary" id="skip-password-btn">Skip for Now</button>
                    <button type="submit" form="firstTimePasswordForm" class="btn btn-primary btn-lg">
                        <i class="bi bi-lock-fill me-1"></i> Set Password & Continue
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Show modal if user just signed up via OAuth
document.addEventListener('DOMContentLoaded', function() {
    // Check if password setup flag is set
    const showSetup = {{ show_password_setup ? 'true' : 'false' }};
    if (showSetup) {
        setTimeout(() => {
            const modal = new bootstrap.Modal(document.getElementById('firstTimePasswordSetupModal'), {
                backdrop: 'static',
                keyboard: false
            });
            modal.show();
        }, 500);
    }
    
    setupFirstTimePasswordHandlers();
});

function setupFirstTimePasswordHandlers() {
    const passwordInput = document.getElementById('first_password');
    const toggleBtn = document.getElementById('toggle-first-pwd');
    const skipBtn = document.getElementById('skip-password-btn');
    const form = document.getElementById('firstTimePasswordForm');
    
    // Password strength meter
    if (passwordInput) {
        passwordInput.addEventListener('input', function() {
            updateFirstPasswordStrength(this.value);
        });
    }
    
    // Toggle password visibility
    if (toggleBtn) {
        toggleBtn.addEventListener('click', function() {
            const input = document.getElementById('first_password');
            if (input.type === 'password') {
                input.type = 'text';
                this.innerHTML = '<i class="bi bi-eye-slash-fill"></i>';
            } else {
                input.type = 'password';
                this.innerHTML = '<i class="bi bi-eye-fill"></i>';
            }
        });
    }
    
    // Skip button
    if (skipBtn) {
        skipBtn.addEventListener('click', function() {
            bootstrap.Modal.getInstance(document.getElementById('firstTimePasswordSetupModal')).hide();
            // Mark that user skipped password setup
            fetch('/api/auth/skip-password-setup', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: new URLSearchParams({
                    csrf_token: document.querySelector('input[name="csrf_token"]').value
                })
            }).catch(err => console.error('Error:', err));
        });
    }
    
    // Form submission
    if (form) {
        form.addEventListener('submit', handleFirstTimePasswordSubmit);
    }
}

function updateFirstPasswordStrength(password) {
    let strength = 0;
    const checks = {
        length: password.length >= 8,
        lowercase: /[a-z]/.test(password),
        uppercase: /[A-Z]/.test(password),
        number: /[0-9]/.test(password),
        special: /[!@#$%^&*()_+\-=\[\]{};:'"",.<>?\/\\]/.test(password)
    };
    
    // Calculate strength
    Object.values(checks).forEach(check => {
        if (check) strength += 20;
    });
    
    // Update visual indicators
    const checkmarks = document.querySelectorAll('#firstTimePasswordForm small i');
    checkmarks.forEach((mark, idx) => {
        const li = mark.parentElement;
        if (idx === 0 && checks.length) {
            li.style.color = '#198754';
        } else if (idx === 1 && checks.uppercase) {
            li.style.color = '#198754';
        } else if (idx === 2 && checks.lowercase) {
            li.style.color = '#198754';
        } else if (idx === 3 && checks.number) {
            li.style.color = '#198754';
        } else if (idx === 4 && checks.special) {
            li.style.color = '#198754';
        } else {
            li.style.color = '#999';
        }
    });
    
    // Update strength bar
    const strengthBar = document.getElementById('first-strength-bar');
    const strengthText = document.getElementById('strength-text');
    
    strengthBar.style.width = strength + '%';
    
    if (strength < 40) {
        strengthBar.className = 'progress-bar bg-danger';
        strengthText.textContent = 'Password strength: Very Weak ⚠️';
    } else if (strength < 60) {
        strengthBar.className = 'progress-bar bg-warning';
        strengthText.textContent = 'Password strength: Weak';
    } else if (strength < 80) {
        strengthBar.className = 'progress-bar bg-info';
        strengthText.textContent = 'Password strength: Good';
    } else {
        strengthBar.className = 'progress-bar bg-success';
        strengthText.textContent = 'Password strength: Strong ✓';
    }
}

function handleFirstTimePasswordSubmit(e) {
    e.preventDefault();
    
    const password = document.getElementById('first_password').value;
    const passwordConfirm = document.getElementById('first_confirm_password').value;
    const errorDiv = document.getElementById('password-error');
    
    // Clear previous error
    errorDiv.classList.add('d-none');
    
    // Validation
    if (!password || !passwordConfirm) {
        showPasswordError('Both password fields are required');
        return;
    }
    
    if (password !== passwordConfirm) {
        showPasswordError('Passwords do not match');
        return;
    }
    
    if (password.length < 8) {
        showPasswordError('Password must be at least 8 characters');
        return;
    }
    
    const hasLower = /[a-z]/.test(password);
    const hasUpper = /[A-Z]/.test(password);
    const hasNumber = /[0-9]/.test(password);
    const hasSpecial = /[!@#$%^&*()_+\-=\[\]{};:'"",.<>?\/\\]/.test(password);
    
    if (!hasLower || !hasUpper || !hasNumber || !hasSpecial) {
        showPasswordError('Password must contain uppercase, lowercase, number, and special character');
        return;
    }
    
    // Submit
    const formData = new FormData(e.target);
    
    fetch('/api/oauth/set-password', {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Close modal
            bootstrap.Modal.getInstance(document.getElementById('firstTimePasswordSetupModal')).hide();
            
            // Show success message
            showSuccessNotification('Password set successfully! You can now login with your email and password.');
            
            // Reload or redirect
            setTimeout(() => {
                location.reload();
            }, 2000);
        } else {
            showPasswordError(data.error || 'Failed to set password');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showPasswordError('An error occurred. Please try again.');
    });
}

function showPasswordError(message) {
    const errorDiv = document.getElementById('password-error');
    errorDiv.textContent = message;
    errorDiv.classList.remove('d-none');
}

function showSuccessNotification(message) {
    // You can use your existing notification system or create a simple alert
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert alert-success alert-dismissible fade show';
    alertDiv.setAttribute('role', 'alert');
    alertDiv.innerHTML = `
        <i class="bi bi-check-circle-fill me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.insertBefore(alertDiv, document.body.firstChild);
}
</script>


