{% extends "admin/layout.twig" %}

{% block title %}Device Control Logs{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="admin-page-header mb-4">
        <div class="admin-page-title"><i class="bi bi-cpu me-2"></i>Device Control Logs</div>
        <div class="admin-page-subtitle">Telegram-triggered remote device command history and delivery status.</div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Total Devices</div>
                    <div class="h4 mb-0">{{ summary.total|default(0) }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Online</div>
                    <div class="h4 text-success mb-0">{{ summary.online|default(0) }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Offline</div>
                    <div class="h4 text-secondary mb-0">{{ summary.offline|default(0) }}</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="small text-muted">Disabled</div>
                    <div class="h4 text-danger mb-0">{{ summary.disabled|default(0) }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Recent Commands</strong>
            <form method="get" class="d-flex gap-2">
                <select name="limit" class="form-select form-select-sm">
                    <option value="50" {% if limit == 50 %}selected{% endif %}>50</option>
                    <option value="100" {% if limit == 100 %}selected{% endif %}>100</option>
                    <option value="200" {% if limit == 200 %}selected{% endif %}>200</option>
                    <option value="500" {% if limit == 500 %}selected{% endif %}>500</option>
                </select>
                <button class="btn btn-sm btn-primary" type="submit">Apply</button>
            </form>
        </div>
        <div class="card-body p-0">
            {% if commands is not empty %}
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#ID</th>
                                <th>Device</th>
                                <th>Command</th>
                                <th>Status</th>
                                <th>Response</th>
                                <th>Created</th>
                                <th>Delivered</th>
                                <th>Executed</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in commands %}
                                <tr>
                                    <td class="font-monospace">{{ row.id }}</td>
                                    <td>{{ row.device_name|default('Device #' ~ row.device_id) }}</td>
                                    <td><code>{{ row.command }}</code></td>
                                    <td>
                                        {% set status = row.status|default('queued') %}
                                        {% if status == 'completed' %}
                                            <span class="badge bg-success">{{ status }}</span>
                                        {% elseif status == 'failed' %}
                                            <span class="badge bg-danger">{{ status }}</span>
                                        {% elseif status == 'delivered' %}
                                            <span class="badge bg-info text-dark">{{ status }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ status }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="small text-muted">{{ row.response_text|default('') }}</td>
                                    <td class="small">{{ row.created_at|default('') }}</td>
                                    <td class="small">{{ row.delivered_at|default('') }}</td>
                                    <td class="small">{{ row.executed_at|default('') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="p-4 text-center text-muted">No command history found yet.</div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
