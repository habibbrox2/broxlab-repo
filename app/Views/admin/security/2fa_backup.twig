{% extends "admin/layout.twig" %}
{% block title %}Backup Codes - Two-Factor Authentication{% endblock %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <!-- Header -->
        <div class="admin-panel-card border-0 shadow-sm mb-4">
          <div class="card-body bg-gradient p-4 inl-a-0042">
            <h1 class="text-white mb-2">
              <i class="bi bi-shield-lock"></i> Backup Codes
            </h1>
            <p class="text-white-50 mb-0">Save your recovery codes for emergency access</p>
          </div>
        </div>
        <!-- Warning Alert -->
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <div class="d-flex align-items-start">
            <i class="bi bi-exclamation-triangle-fill mt-1 me-3 fs-5"></i>
            <div>
              <strong class="d-block mb-2">Important!</strong>
              <p class="mb-0">
                These codes will only be displayed once. Save them in a secure location immediately.
                You'll need these codes if you lose access to your authenticator app.
              </p>
            </div>
          </div>
        </div>
        <!-- Codes Display Card -->
        <div class="admin-panel-card border-2 border-warning shadow-sm mb-4">
          <div class="card-header bg-light border-warning">
            <h5 class="mb-0">
              <i class="bi bi-file-text"></i> Your Backup Codes
            </h5>
          </div>
          <div class="card-body p-4">
            <p class="text-muted small mb-3">
              <i class="bi bi-info-circle"></i> Each code can be used only once for authentication
            </p>
            <!-- Codes Container -->
            <div class="backup-codes-container mb-4 inl-a-0043">
              <div class="row g-3">
                {% for code in backup_codes %}
                  <div class="col-md-6">
                    <div class="code-box p-3 bg-white border rounded inl-a-0044">
                      <code class="d-block fw-bold inl-a-0045">
                        {{ code }}
                      </code>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
            <!-- Action Buttons -->
            <div class="row gap-2 mb-4">
              <div class="col-md-6">
                <button type="button"
                        class="modern-btn modern-btn-info w-100"
                        onclick="copyAllBackupCodes(this)">
                  <i class="bi bi-files"></i> Copy All Codes
                </button>
              </div>
              <div class="col-md-6">
                <button type="button"
                        class="modern-btn modern-btn-secondary w-100"
                        onclick="window.print()">
                  <i class="bi bi-printer"></i> Print Codes
                </button>
              </div>
            </div>
            <hr>
            <!-- Storage Tips -->
            <div class="admin-panel-card bg-light border-0 mb-4">
              <div class="card-header bg-info text-white">
                <h6 class="mb-0">
                  <i class="bi bi-lock"></i> Safe Storage Recommendations
                </h6>
              </div>
              <div class="admin-panel-card-body">
                <p class="small mb-3">Recommended ways to save these codes:</p>
                <div class="row g-2">
                  <div class="col-md-6">
                    <div class="p-2 bg-white rounded border border-success">
                      <p class="mb-1">
                        <strong class="text-success">✓ Good</strong>
                      </p>
                      <small>
                        <ul class="mb-0 ps-3">
                          <li>Password-protected encrypted file</li>
                          <li>Printed and stored securely</li>
                          <li>Password manager</li>
                        </ul>
                      </small>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="p-2 bg-white rounded border border-danger">
                      <p class="mb-1">
                        <strong class="text-danger">✗ Avoid</strong>
                      </p>
                      <small>
                        <ul class="mb-0 ps-3">
                          <li>Plain text files</li>
                          <li>Cloud storage (unencrypted)</li>
                          <li>Sharing via email</li>
                        </ul>
                      </small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- How to Use -->
            <div class="admin-panel-card bg-light border-0 mb-4">
              <div class="card-header bg-success text-white">
                <h6 class="mb-0">
                  <i class="bi bi-question-circle"></i> How to Use These Codes
                </h6>
              </div>
              <div class="admin-panel-card-body">
                <p class="small mb-3">If you lose access to your authenticator app:</p>
                <ol class="small">
                  <li class="mb-2">Go to the login page</li>
                  <li class="mb-2">Enter your email and password</li>
                  <li class="mb-2">When asked for a 2FA code, use one of your backup codes instead</li>
                  <li class="mb-2">After logging in, set up a new authenticator</li>
                  <li>Generate new backup codes</li>
                </ol>
                <div class="alert alert-warning small mb-0 mt-3">
                  <strong><i class="bi bi-exclamation-circle"></i> Remember:</strong> Each backup code can only be used once!
                </div>
              </div>
            </div>
            <!-- Regenerate Modal Trigger -->
            <div class="alert alert-info" role="alert">
              <strong><i class="bi bi-lightbulb"></i> Tip:</strong>
              If you've used some codes or want to regenerate them for security, you can create new ones below.
            </div>
          </div>
        </div>
        <!-- Regenerate Button -->
        <div class="admin-panel-card border-0 shadow-sm">
          <div class="card-body p-4">
            <h6 class="card-title mb-3">
              <i class="bi bi-arrow-repeat"></i> Regenerate Backup Codes
            </h6>
            <p class="text-muted small mb-3">Generate a new set of backup codes. Your old codes will no longer be valid.</p>
            <button type="button"
                    class="modern-btn modern-btn-warning"
                    data-bs-toggle="modal"
                    data-bs-target="#regenerateModal">
              <i class="bi bi-arrow-repeat"></i> Generate New Codes
            </button>
          </div>
        </div>
        <!-- Back Button -->
        <div class="mt-4">
          <a href="/admin/security/2fa" class="modern-btn modern-btn-white">
            <i class="bi bi-arrow-left"></i> Back to 2FA Settings
          </a>
        </div>
      </div>
    </div>
  </div>
  <!-- Regenerate Modal -->
  <div class="modal fade"
       id="regenerateModal"
       tabindex="-1"
       aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-warning">
          <h5 class="modal-title text-theme-strong">
            <i class="bi bi-arrow-repeat"></i> Generate New Backup Codes
          </h5>
          <button type="button"
                  class="btn-close"
                  data-bs-dismiss="modal"
                  aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-warning" role="alert">
            <strong>Warning:</strong> Your current backup codes will be invalidated. Make sure to save the new codes before closing this page.
          </div>
          <form id="regenerateForm">
            <div class="mb-3">
              <label for="password" class="form-label">Confirm Your Password</label>
              <input type="password"
                     class="form-control"
                     id="password"
                     name="password"
                     required
                     placeholder="Enter your password">
              <small class="text-muted d-block mt-1">We need your password to confirm this important action</small>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button"
                  class="modern-btn modern-btn-secondary"
                  data-bs-dismiss="modal">Cancel</button>
          <button type="button"
                  class="modern-btn modern-btn-warning"
                  onclick="regenerateBackupCodes(this)">
            <i class="bi bi-arrow-repeat"></i> Generate New Codes
          </button>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
