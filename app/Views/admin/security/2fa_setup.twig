{% extends "admin/layout.twig" %}
{% block content %}
  <input type="hidden" id="global-csrf-token" value="{{ csrf_token }}">
  <div class="container-fluid py-4">
    <div class="row">
      <div class="col-lg-8 offset-lg-2">
        <div class="admin-panel-card">
          <div class="admin-panel-card-header border-primary">
            <h4 class="mb-0">
              <i class="bi bi-qr-code me-2"></i> Setup Two-Factor Authentication
            </h4>
          </div>
          <div class="admin-panel-card-body">
            <div class="alert alert-info">
              <i class="bi bi-info-circle me-2"></i>
              Follow these steps to enable two-factor authentication on your admin account
            </div>
            <div class="row mt-5">
              <!-- Step 1: Download App -->
              <div class="col-md-6 mb-5">
                <div class="step-card">
                  <div class="step-number">1</div>
                  <h5 class="mt-4 mb-3">
                    <i class="bi bi-google text-danger me-2"></i> Download Authenticator App
                  </h5>
                  <p class="text-muted small">Download one of these free authenticator apps to your phone:</p>
                  <ul class="small">
                    <li>Google Authenticator</li>
                    <li>Microsoft Authenticator</li>
                    <li>Authy</li>
                  </ul>
                </div>
              </div>
              <!-- Step 2: Scan QR Code -->
              <div class="col-md-6 mb-5">
                <div class="step-card">
                  <div class="step-number">2</div>
                  <h5 class="mt-4 mb-3">
                    <i class="bi bi-qr-code text-primary me-2"></i> Scan QR Code
                  </h5>
                  <p class="text-muted small mb-3">Open your authenticator app and scan this QR code:</p>
                  <div class="text-center">
                    {% if qr_image %}
                      <img src="{{ qr_image }}" alt="QR Code" class="img-fluid inl-a-0046">
                    {% else %}
                      <div class="alert alert-warning">Could not generate QR code</div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
            <!-- Manual Entry Option -->
            <div class="row mt-5">
              <div class="col-md-12 mb-5">
                <div class="alert alert-info">
                  <h6 class="mb-3">
                    <i class="bi bi-keyboard me-2"></i> Can't scan? Enter manually
                  </h6>
                  <p class="small mb-2">Enter this secret key in your authenticator app:</p>
                  <div class="input-group">
                    <input type="text"
                           class="form-control"
                           value="{{ secret }}"
                           readonly
                           id="secretKey">
                    <button class="modern-btn modern-btn-white" onclick="copySecret(this)">
                      <i class="bi bi-copy me-1"></i> Copy
                    </button>
                  </div>
                </div>
              </div>
            </div>
            <!-- Verify Code -->
            <div class="row mt-5">
              <div class="col-md-6 offset-md-3">
                <div class="step-card">
                  <div class="step-number">3</div>
                  <h5 class="mt-4 mb-3">
                    <i class="bi bi-check-circle text-success me-2"></i> Verify Code
                  </h5>
                  <p class="text-muted small mb-4">Enter the 6-digit code from your authenticator app to confirm:</p>
                  <form id="verifyTwoFAForm">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                    <div class="mb-3">
                      <input type="text"
                             class="form-control form-control-lg text-center inl-a-0047"
                             name="code"
                             id="authCode"
                             maxlength="6"
                             placeholder="000000"
                             inputmode="numeric"
                             required>
                      <small class="form-text text-muted d-block mt-2">Enter the 6-digit code (numbers only)</small>
                    </div>
                    <div id="verifyAlert"></div>
                    <button type="button"
                            class="modern-btn modern-btn-primary btn-lg w-100"
                            id="verifyBtn">
                      <i class="bi bi-check me-2"></i> Verify & Enable 2FA
                    </button>
                  </form>
                  <button class="modern-btn modern-btn-link text-muted mt-3 w-100"
                          onclick="goBack()">Cancel</button>
                </div>
              </div>
            </div>
            <!-- Important Notes -->
            <div class="alert alert-warning mt-5">
              <h6 class="mb-3">
                <i class="bi bi-exclamation-circle me-2"></i> Important
              </h6>
              <ul class="small mb-0">
                <li>Save your backup codes in a safe place</li>
                <li>You'll need a code every time you log in</li>
                <li>Keep your authenticator app updated</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
