{% extends "admin/layout.twig" %}
{% block title %}AI Knowledge Base{% endblock %}
{% set breadcrumbs = breadcrumbs ?? [] %}
{% block content %}
<div class="container-fluid py-4">
    <div class="admin-page-header mb-4">
        <div class="admin-page-title"><i class="bi bi-book"></i> AI Knowledge Base</div>
        <div class="admin-page-subtitle">Upload and manage knowledge slices used to ground AI responses.</div>
    </div>

    <div id="alertContainer"></div>

    <div class="row mb-3">
        <div class="col-md-4">
            <input type="text" class="form-control" id="kbSearch" placeholder="Search knowledge base...">
        </div>
        <div class="col-md-3">
            <select class="form-select" id="kbFilterType">
                <option value="">All Types</option>
                <option value="text">Text</option>
                <option value="pdf">PDF</option>
                <option value="url">URL</option>
                <option value="document">Document</option>
            </select>
        </div>
        <div class="col-md-2">
            <span class="badge bg-primary" id="kbCount">0 items</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Knowledge Slices</h5>
            <button class="btn btn-primary btn-sm" id="btnAddSlice"><i class="bi bi-plus-lg"></i> Add Slice</button>
        </div>
        <div class="card-body">
            <div id="kbList"></div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="kbModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Knowledge Slice</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <form id="kbForm">
                <input type="hidden" name="id" id="kb_id" value="0">
                <div class="mb-3">
                    <label class="form-label">Title <span class="text-danger">*</span></label>
                    <input class="form-control" name="title" id="kb_title" required placeholder="e.g., Company Policies">
                </div>
                <div class="mb-3">
                    <label class="form-label">Source Type</label>
                    <select class="form-select" name="source_type" id="kb_source_type">
                        <option value="text">Text</option>
                        <option value="pdf">PDF Document</option>
                        <option value="url">Web URL</option>
                        <option value="document">Other Document</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Content <span class="text-danger">*</span></label>
                    <textarea class="form-control" name="content" id="kb_content" rows="10" required placeholder="Enter the knowledge content here..."></textarea>
                    <small class="text-muted">For PDFs/URLs, you may paste extracted text content for AI context. Full file/URL support coming soon.</small>
                </div>
                <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" class="btn btn-primary" id="kbSaveBtn">Save</button>
          </div>
        </div>
      </div>
    </div>

</div>
{% endblock %}

{% block scripts %}
<script src="/ai/js/ai-knowledge-manager.js?v=2"></script>
{% endblock %}
