{% extends "admin/layout.twig" %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-shield-check me-2"></i>
        Manage Roles
      </div>
      <div class="admin-page-subtitle">Role management</div>
    </div>
    <div class="row mb-4">
      <div class="col-md-8">
        <h1 class="h3 mb-0">
          <i class="bi bi-shield-lock me-2"></i>Manage Roles
        </h1>
      </div>
      <div class="col-md-4 text-end">
        <a href="/admin/roles/create" class="modern-btn modern-btn-primary">
          <i class="bi bi-plus-circle me-2"></i>Create New Role
        </a>
      </div>
    </div>
    <div class="admin-panel-card border-0 shadow-sm">
      <div class="admin-panel-card-body">
        <!-- Search & Filter Form -->
        <div class="border-bottom px-4 py-3 mb-3">
          <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
              <label class="form-label small text-muted mb-1">Search</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                <input type="text"
                       name="search"
                       value="{{ pagination.search|default("") }}"
                       class="form-control form-control-sm"
                       placeholder="Search by name...">
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label small text-muted mb-1">Sort By</label>
              <select name="sort" class="form-select form-select-sm">
                <option value="name" {% if pagination.sort == 'name' %}selected{% endif %}>Name</option>
                <option value="id" {% if pagination.sort == 'id' %}selected{% endif %}>ID</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label small text-muted mb-1">Limit</label>
              <select name="limit" class="form-select form-select-sm">
                <option value="10">10 items</option>
                <option value="20" selected>20 items</option>
                <option value="50">50 items</option>
                <option value="100">100 items</option>
              </select>
            </div>
            <div class="col-md-3 text-end">
              <button type="submit" class="modern-btn modern-btn-primary btn-sm">
                <i class="bi bi-funnel me-1"></i> Apply
              </button>
            </div>
          </form>
        </div>
        {% if roles|length > 0 %}
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Role Name</th>
                  <th>Description</th>
                  <th>Permissions</th>
                  <th>Type</th>
                  <th>Created</th>
                  <th class="text-center">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for role in roles %}
                  <tr>
                    <td>
                      <div class="fw-semibold">{{ role.name|upper }}</div>
                    </td>
                    <td>
                      <small class="text-muted">{{ role.description|default("N/A") }}</small>
                    </td>
                    <td>
                      <span class="badge bg-info">{{ role.permission_count }} permissions</span>
                    </td>
                    <td>
                      {% if role.is_super_admin %}
                        <span class="badge bg-danger">Super Admin</span>
                      {% else %}
                        <span class="badge bg-secondary">Standard</span>
                      {% endif %}
                    </td>
                    <td>
                      <small class="text-muted">{{ role.created_at|date("M d, Y") }}</small>
                    </td>
                    <td class="text-center">
                      <a href="/admin/roles/{{ role.id }}"
                         class="modern-btn btn-sm btn-primary-outline"
                         title="View">
                        <i class="bi bi-eye"></i>
                      </a>
                      {% if not role.is_super_admin %}
                        <a href="/admin/roles/{{ role.id }}/edit"
                           class="modern-btn btn-sm btn-outline-warning"
                           title="Edit">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST"
                              action="/admin/roles/{{ role.id }}/delete"
                              class="delete-btn-inline"
                              onsubmit="return confirm('Delete this role?')">
                          <button type="submit"
                                  class="modern-btn btn-sm btn-danger-outline"
                                  title="Delete">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      {% else %}
                        <span class="text-muted small">Cannot modify</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <!-- Pagination -->
          {% include "admin/partials/pagination.twig" %}
        {% else %}
          <div class="alert alert-info text-center py-4">
            <i class="bi bi-info-circle me-2"></i>
            <strong>No roles found.</strong> <a href="/admin/roles/create">Create one now</a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
