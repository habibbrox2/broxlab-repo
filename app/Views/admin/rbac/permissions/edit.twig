{% extends "admin/layout.twig" %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="row mb-4">
      <div class="col">
        <h1 class="h3 mb-0">
          <a href="/admin/permissions" class="text-decoration-none text-theme-strong">
            <i class="bi bi-key me-2"></i>Permissions
          </a>
          <span class="text-muted">/</span>
          <span>Edit: <code>{{ permission.name }}</code></span>
        </h1>
      </div>
    </div>
    <div class="row">
      <div class="col-lg-5 mx-auto">
        <div class="admin-panel-card border-0 shadow-sm">
          <div class="card-header bg-light border-bottom">
            <h5 class="mb-0">Permission Details</h5>
          </div>
          <div class="admin-panel-card-body">
            <form method="POST" action="/admin/permissions/{{ permission.id }}/update">
              <div class="mb-3">
                <label for="name" class="form-label">Permission Name *</label>
                <input type="text"
                       class="form-control"
                       id="name"
                       name="name"
                       value="{{ permission.name }}"
                       placeholder="e.g., post.create"
                       required>
                <small class="text-muted">Format: module.action</small>
              </div>
              <div class="mb-3">
                <label for="module" class="form-label">Module *</label>
                <div class="input-group">
                  <input type="text"
                         class="form-control"
                         id="module"
                         name="module"
                         value="{{ permission.module }}"
                         placeholder="e.g., post"
                         list="modulesList"
                         required>
                  <datalist id="modulesList">
                    {% for module in modules %}<option value="{{ module }}">{% endfor %}
                    </datalist>
                  </div>
                </div>
                <div class="mb-3">
                  <label for="description" class="form-label">Description</label>
                  <textarea class="form-control"
                            id="description"
                            name="description"
                            rows="3"
                            placeholder="What does this permission allow?">{{ permission.description }}</textarea>
                </div>
                <div class="alert alert-light border">
                  <small>
                    <strong>Created:</strong> {{ permission.created_at|date("M d, Y H:i") }}
                    <br>
                    <strong>Updated:</strong>
                    {% if permission.updated_at %}
                      {{ permission.updated_at|date("M d, Y H:i") }}
                    {% else %}
                      Never
                    {% endif %}
                  </small>
                </div>
                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Update Permission
                  </button>
                  <a href="/admin/permissions" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                  </a>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  {% endblock %}
