{% extends 'admin/layout.twig' %}

{% block title %}Deploy Tools - BroxBhai Admin{% endblock %}

{% block styles %}
<style>
    .unavailable-container {
        text-align: center;
        padding: 60px 20px;
        max-width: 600px;
        margin: 0 auto;
    }
    
    .unavailable-icon {
        font-size: 64px;
        color: #ffc107;
        margin-bottom: 20px;
    }
    
    .unavailable-title {
        font-size: 24px;
        font-weight: 600;
        color: #495057;
        margin-bottom: 15px;
    }
    
    .unavailable-message {
        color: #6c757d;
        font-size: 16px;
        line-height: 1.6;
        margin-bottom: 30px;
    }
    
    .feature-list {
        text-align: left;
        background: #f8f9fa;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 30px;
    }
    
    .feature-list h5 {
        color: #495057;
        margin-bottom: 15px;
        font-weight: 600;
    }
    
    .feature-list ul {
        margin: 0;
        padding-left: 20px;
    }
    
    .feature-list li {
        color: #6c757d;
        margin-bottom: 8px;
    }
    
    .action-buttons {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn-primary {
        background: #0d6efd;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 500;
    }
    
    .btn-outline-secondary {
        border: 2px solid #6c757d;
        color: #6c757d;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 500;
    }
    
    .btn-outline-secondary:hover {
        background: #6c757d;
        color: white;
    }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="unavailable-container">
        <div class="unavailable-icon">
            <i class="bi bi-tools"></i>
        </div>
        
        <h1 class="unavailable-title">Deploy Tools Currently Unavailable</h1>
        
        <p class="unavailable-message">
            The deployment tools feature is currently under maintenance or not yet implemented. 
            Our team is working hard to bring you this functionality soon!
        </p>
        
        <div class="feature-list">
            <h5>Coming Soon - Deployment Features:</h5>
            <ul>
                <li>One-click application deployment</li>
                <li>Automated build and test workflows</li>
                <li>Environment configuration management</li>
                <li>Deployment history and rollback</li>
                <li>Server health monitoring</li>
            </ul>
        </div>
        
        <div class="action-buttons">
            <a href="/admin/dashboard" class="btn btn-primary">
                <i class="bi bi-house-door me-2"></i>
                Back to Dashboard
            </a>
            <a href="/admin/settings" class="btn btn-outline-secondary">
                <i class="bi bi-gear me-2"></i>
                Settings
            </a>
        </div>
    </div>
</div>
{% endblock %}
