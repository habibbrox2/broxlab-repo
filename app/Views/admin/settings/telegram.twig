{% extends "admin/layout.twig" %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header pb-0">
                    <h6>Telegram Bot Settings</h6>
                </div>
                <div class="card-body">
                    <form action="/admin/telegram-settings/update" method="POST">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <div class="form-group">
                            <label for="bot_token">Bot Token</label>
                            <input type="password" class="form-control" id="bot_token" name="bot_token" value="{{ settings.bot_token }}">
                        </div>
                        <div class="form-group">
                            <label for="admin_chat_id">Telegram Admin Chat ID</label>
                            <input type="text" class="form-control" id="admin_chat_id" name="admin_chat_id" value="{{ settings.admin_chat_id }}" placeholder="e.g. 123456789">
                            <small class="text-muted">Chat ID to forward incoming SMS and system alerts to.</small>
                        </div>
                        <div class="form-group">
                            <label for="public_https_url">Public HTTPS URL</label>
                            <input type="url" class="form-control" id="public_https_url" name="public_https_url" value="{{ settings.public_https_url }}" placeholder="https://your-domain.com">
                            <small class="text-muted">Your public domain URL. The endpoint path <code>/api/telegram/webhook</code> will be appended automatically.</small>
                        </div>
                        <div class="form-group">
                            <label for="webhook_url">Webhook Endpoint URL</label>
                            <input type="text" class="form-control" id="webhook_url" name="webhook_url" value="{{ settings.webhook_url }}" readonly>
                        </div>
                        <div class="form-group">
                            <label for="webhook_secret">Webhook Secret Token</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="webhook_secret" name="webhook_secret" value="{{ settings.webhook_secret }}">
                                <button type="button" class="btn btn-outline-secondary" id="generate_webhook_secret">Generate Secret</button>
                                <button type="button" class="btn btn-outline-secondary" id="copy_webhook_secret">Copy</button>
                            </div>
                            <small class="text-muted">Use only letters, numbers, underscore, or hyphen.</small>
                        </div>
                        <div class="form-group">
                            <label for="set_webhook_api_url">Telegram setWebhook URL</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="set_webhook_api_url" value="{{ settings.set_webhook_api_url }}" readonly>
                                <button type="button" class="btn btn-outline-secondary" id="copy_set_webhook_url">Copy URL</button>
                            </div>
                            <small class="text-muted">Preview: <code>https://api.telegram.org/bot&lt;TOKEN&gt;/setWebhook?url=&lt;PUBLIC_HTTPS_URL&gt;/api/telegram/webhook&secret_token=&lt;SAME_SECRET&gt;</code></small>
                        </div>
                        <button type="submit" class="btn btn-primary mt-4">Save Configuration</button>
                        <button type="submit" class="btn btn-success mt-4 ms-2" formaction="/admin/telegram-settings/set-webhook" id="set_webhook_submit">Set Webhook Now</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const botTokenInput = document.getElementById('bot_token');
        const publicUrlInput = document.getElementById('public_https_url');
        const webhookUrlInput = document.getElementById('webhook_url');
        const setWebhookUrlInput = document.getElementById('set_webhook_api_url');
        const copySetWebhookBtn = document.getElementById('copy_set_webhook_url');
        const setWebhookSubmitBtn = document.getElementById('set_webhook_submit');
        const secretInput = document.getElementById('webhook_secret');
        const generateBtn = document.getElementById('generate_webhook_secret');
        const copyBtn = document.getElementById('copy_webhook_secret');
        if (!secretInput || !generateBtn || !copyBtn) return;

        const ALPHABET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-';
        const TOKEN_LENGTH = 48;

        function generateToken(length) {
            const chars = [];
            if (window.crypto && window.crypto.getRandomValues) {
                const bytes = new Uint8Array(length);
                window.crypto.getRandomValues(bytes);
                for (let i = 0; i < length; i++) {
                    chars.push(ALPHABET[bytes[i] % ALPHABET.length]);
                }
            } else {
                for (let i = 0; i < length; i++) {
                    chars.push(ALPHABET[Math.floor(Math.random() * ALPHABET.length)]);
                }
            }
            return chars.join('');
        }

        function normalizeBaseUrl(value) {
            return String(value || '').trim().replace(/\/+$/, '');
        }

        function buildWebhookUrl(baseUrl) {
            if (!baseUrl) return '';
            return baseUrl + '/api/telegram/webhook';
        }

        function buildSetWebhookUrl(botToken, webhookUrl, secretToken) {
            const cleanToken = String(botToken || '').trim();
            const cleanWebhookUrl = String(webhookUrl || '').trim();
            const cleanSecret = String(secretToken || '').trim();
            if (!cleanToken || !cleanWebhookUrl) return '';

            const params = new URLSearchParams();
            params.set('url', cleanWebhookUrl);
            if (cleanSecret) {
                params.set('secret_token', cleanSecret);
            }

            return 'https://api.telegram.org/bot' + cleanToken + '/setWebhook?' + params.toString();
        }

        function refreshWebhookPreview() {
            const baseUrl = normalizeBaseUrl(publicUrlInput ? publicUrlInput.value : '');
            const webhookUrl = buildWebhookUrl(baseUrl);
            const setWebhookUrl = buildSetWebhookUrl(botTokenInput ? botTokenInput.value : '', webhookUrl, secretInput.value);

            if (webhookUrlInput) {
                webhookUrlInput.value = webhookUrl;
            }

            if (setWebhookUrlInput) {
                setWebhookUrlInput.value = setWebhookUrl;
            }

            if (setWebhookSubmitBtn) {
                setWebhookSubmitBtn.disabled = !setWebhookUrl;
            }
        }

        generateBtn.addEventListener('click', function () {
            secretInput.value = generateToken(TOKEN_LENGTH);
            secretInput.dispatchEvent(new Event('input', { bubbles: true }));
            secretInput.focus();
            secretInput.select();
            refreshWebhookPreview();
        });

        copyBtn.addEventListener('click', async function () {
            if (!secretInput.value) return;

            try {
                await navigator.clipboard.writeText(secretInput.value);
                copyBtn.textContent = 'Copied';
                setTimeout(function () { copyBtn.textContent = 'Copy'; }, 1200);
            } catch (e) {
                secretInput.focus();
                secretInput.select();
            }
        });

        if (copySetWebhookBtn && setWebhookUrlInput) {
            copySetWebhookBtn.addEventListener('click', async function () {
                if (!setWebhookUrlInput.value) return;

                try {
                    await navigator.clipboard.writeText(setWebhookUrlInput.value);
                    copySetWebhookBtn.textContent = 'Copied';
                    setTimeout(function () { copySetWebhookBtn.textContent = 'Copy URL'; }, 1200);
                } catch (e) {
                    setWebhookUrlInput.focus();
                    setWebhookUrlInput.select();
                }
            });
        }

        if (publicUrlInput) {
            publicUrlInput.addEventListener('input', refreshWebhookPreview);
            publicUrlInput.addEventListener('change', refreshWebhookPreview);
        }

        if (botTokenInput) {
            botTokenInput.addEventListener('input', refreshWebhookPreview);
            botTokenInput.addEventListener('change', refreshWebhookPreview);
        }

        secretInput.addEventListener('input', refreshWebhookPreview);
        secretInput.addEventListener('change', refreshWebhookPreview);
        refreshWebhookPreview();
    })();
</script>
{% endblock %}
