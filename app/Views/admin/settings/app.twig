{% extends "admin/layout.twig" %}
{% block title %}App Settings{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4 settings-page app-settings-page">
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-gear"></i>
        App Settings
      </div>
      <div class="admin-page-subtitle">Configure application preferences and security controls</div>
    </div>
    <div class="admin-panel-card">
      <div class="admin-panel-card-body">
        <form method="post"
              action="{{ admin_dir|default("/admin") }}/app-settings"
              class="needs-validation"
              enctype="multipart/form-data">
          <!-- Nav Tabs -->
          <ul class="nav nav-tabs mb-3" id="appSettingsTabs" role="tablist">
            {% set tabs = {
              "general": "General",
              "contact": "Contact",
              "seo": "SEO",
              "social": "Social Media",
              "email": "Email / SMTP",
              "security": "Security",
              "payments": "Payments",
              "api": "API / Integrations",
              "cache": "Cache",
              "security_controls": "Security Controls"
            } %}
            {% for key, label in tabs %}
              <li class="nav-item">
                <button class="nav-link {% if loop.first %}active{% endif %}"
                        data-bs-toggle="tab"
                        data-bs-target="#{{ key }}"
                        type="button">{{ label }}</button>
              </li>
            {% endfor %}
          </ul>
          <div class="tab-content" id="appSettingsTabsContent">
            <!-- General -->
            <div class="tab-pane fade show active" id="general">
              <div class="mb-3">
                <label class="form-label">Site Name</label>
                <input type="text"
                       class="form-control"
                       name="site_name"
                       placeholder="Enter your site name"
                       value="{{ settings.site_name|default("") }}"
                       required>
              </div>
              <!-- Site Logo -->
              <div class="mb-3">
                <label class="form-label">Site Logo</label>
                <div class="mb-2 d-flex align-items-center">
                  {% if settings.site_logo|default('') %}
                    <img id="logoPreview"
                         src="{{ settings.site_logo|default("") }}"
                         alt="Logo"
                         class="image-preview">
                    <button type="button"
                            id="removeLogoBtn"
                            class="modern-btn modern-btn-danger modern-btn-sm ms-3"
                            aria-label="Remove site logo">
                      <i class="fa fa-trash" aria-hidden="true"></i> Remove
                      <span class="visually-hidden">Remove site logo</span>
                    </button>
                  {% else %}
                    <img id="logoPreview"
                         src=""
                         alt="Logo Preview"
                         class="image-preview d-none">
                  {% endif %}
                </div>
                <input type="hidden" name="remove_site_logo" id="remove_site_logo" value="0">
                <input type="text"
                       class="form-control mb-2"
                       name="site_logo"
                       placeholder="/assets/logo/logo.png"
                       value="{{ settings.site_logo|default("") }}">
                <input type="file"
                       class="form-control"
                       id="siteLogoUpload"
                       name="site_logo_file"
                       accept="image/*">
              </div>
              <!-- Favicon -->
              <div class="mb-3">
                <label class="form-label">Favicon</label>
                <div class="mb-2">
                  {% set favicon_url = settings.favicon|default('/assets/logo/favicon.ico') %}
                  <img id="faviconPreview"
                       src="{{ favicon_url }}"
                       alt="Favicon"
                       class="favicon-preview">
                </div>
                <input type="text"
                       class="form-control mb-2"
                       name="favicon"
                       placeholder="/assets/logo/favicon.ico"
                       value="{{ settings.favicon|default("/assets/logo/favicon.ico") }}">
                <input type="file"
                       class="form-control"
                       id="faviconUpload"
                       name="favicon_file"
                       accept="image/*">
              </div>
              <div class="mb-3">
                <label class="form-label">Default Language</label>
                <input type="text"
                       class="form-control"
                       name="default_language"
                       placeholder="e.g., en, fr, es"
                       value="{{ settings.default_language|default("en") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Timezone</label>
                <select class="form-select" name="timezone">
                  {% for tz, label in timezones|default([]) %}
                    <option value="{{ tz }}"
                            {% if settings.timezone|default('UTC') == tz %}selected{% endif %}>{{ label }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="form-check form-switch mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       name="maintenance_mode"
                       {% if settings.maintenance_mode|default(false) %}checked{% endif %}>
                <label class="form-check-label">Maintenance Mode</label>
              </div>
              <hr class="my-4">
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                <div>
                  <h6 class="mb-1">Public Header Menu</h6>
                  <p class="text-muted mb-0 small">Manage main public navbar links (max 8). Internal paths only.</p>
                </div>
              </div>
              {% if not public_nav_column_available|default(false) %}
                <div class="alert alert-warning small">
                  <i class="bi bi-exclamation-triangle me-1"></i>
                  <strong>Database column missing:</strong> `app_settings.public_nav_json` not found. Menu input will not be saved until migration is applied.
                </div>
              {% endif %}
              <input type="hidden" name="public_nav_submitted" value="1">
              <div class="table-responsive">
                <table class="table table-sm align-middle">
                  <thead>
                    <tr>
                      <th class="inl-a-0007">Label</th>
                      <th class="inl-a-0008">URL</th>
                      <th class="inl-a-0008">Icon</th>
                      <th class="inl-a-0008">Match</th>
                      <th class="inl-a-0009">Order</th>
                      <th class="inl-a-0010">Enabled</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in public_nav_rows|default([]) %}
                      <tr>
                        <td>
                          <input type="text"
                                 class="form-control form-control-sm"
                                 name="public_nav_label[{{ loop.index0 }}]"
                                 value="{{ row.label|default("") }}"
                                 maxlength="40"
                                 placeholder="Home">
                        </td>
                        <td>
                          <input type="text"
                                 class="form-control form-control-sm"
                                 name="public_nav_url[{{ loop.index0 }}]"
                                 value="{{ row.url|default("") }}"
                                 placeholder="/mobiles">
                        </td>
                        <td>
                          <input type="text"
                                 class="form-control form-control-sm"
                                 name="public_nav_icon[{{ loop.index0 }}]"
                                 value="{{ row.icon|default("") }}"
                                 placeholder="bi-house-door-fill">
                        </td>
                        <td>
                          <input type="text"
                                 class="form-control form-control-sm"
                                 name="public_nav_match[{{ loop.index0 }}]"
                                 value="{{ row.match|default("") }}"
                                 placeholder="/mobiles">
                        </td>
                        <td>
                          <input type="number"
                                 class="form-control form-control-sm"
                                 name="public_nav_order[{{ loop.index0 }}]"
                                 value="{{ row.order|default((loop.index * 10) ) }}">
                        </td>
                        <td>
                          <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   value="1"
                                   name="public_nav_enabled[{{ loop.index0 }}]"
                                   {% if row.enabled|default(false) %}checked{% endif %}>
                          </div>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
            <!-- Contact -->
            <div class="tab-pane fade" id="contact">
              <div class="mb-3">
                <label class="form-label">Contact Email</label>
                <input type="email"
                       class="form-control"
                       name="contact_email"
                       placeholder="contact@example.com"
                       value="{{ settings.contact_email|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Phone</label>
                <input type="text"
                       class="form-control"
                       name="contact_phone"
                       placeholder="+1 234 567 890"
                       value="{{ settings.contact_phone|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Address</label>
                <textarea class="form-control"
                          name="contact_address"
                          placeholder="123 Main St, City, Country">{{ settings.contact_address|default('') }}</textarea>
              </div>
            </div>
            <!-- SEO -->
            <div class="tab-pane fade" id="seo">
              <div class="mb-3">
                <label class="form-label">Meta Title</label>
                <input type="text"
                       class="form-control"
                       name="meta_title"
                       placeholder="Enter meta title"
                       value="{{ settings.meta_title|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Meta Description</label>
                <textarea class="form-control"
                          name="meta_description"
                          placeholder="Enter meta description">{{ settings.meta_description|default('') }}</textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Meta Keywords</label>
                <textarea class="form-control"
                          name="meta_keywords"
                          placeholder="keyword1, keyword2, keyword3">{{ settings.meta_keywords|default('') }}</textarea>
              </div>
            </div>
            <!-- Social Media -->
            <div class="tab-pane fade" id="social">
              <div class="mb-3">
                <label class="form-label">Twitter URL</label>
                <input type="text"
                       class="form-control"
                       name="social_twitter"
                       placeholder="https://twitter.com/yourprofile"
                       value="{{ settings.social_twitter|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Instagram URL</label>
                <input type="text"
                       class="form-control"
                       name="social_instagram"
                       placeholder="https://instagram.com/yourprofile"
                       value="{{ settings.social_instagram|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">YouTube URL</label>
                <input type="text"
                       class="form-control"
                       name="social_youtube"
                       placeholder="https://youtube.com/@yourchannel"
                       value="{{ settings.social_youtube|default("") }}">
              </div>
            </div>
            <!-- Email / SMTP -->
            <div class="tab-pane fade" id="email">
              <div class="alert alert-info mb-3">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Email Templates:</strong>
                <a href="{{ admin_dir|default("/admin") }}/email-templates"
                   class="alert-link">Manage email templates</a>
                for welcome, verification, password reset, and other emails.
              </div>
              <div class="mb-3">
                <label class="form-label">SMTP Host</label>
                <input type="text"
                       class="form-control"
                       name="smtp_host"
                       placeholder="smtp.example.com"
                       value="{{ settings.smtp_host|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">SMTP Port</label>
                <input type="number"
                       class="form-control"
                       name="smtp_port"
                       placeholder="587"
                       value="{{ settings.smtp_port|default(587) }}">
              </div>
              <div class="mb-3">
                <label class="form-label">SMTP Username</label>
                <input type="text"
                       class="form-control"
                       name="smtp_username"
                       placeholder="username@example.com"
                       value="{{ settings.smtp_username|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">SMTP Password</label>
                <input type="password"
                       class="form-control"
                       name="smtp_password"
                       placeholder="Enter SMTP password"
                       value="{{ settings.smtp_password|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">SMTP Encryption</label>
                <select class="form-select" name="smtp_encryption">
                  <option value=""
                          {% if settings.smtp_encryption|default('') == '' %}selected{% endif %}>None</option>
                  <option value="ssl"
                          {% if settings.smtp_encryption|default('') == 'ssl' %}selected{% endif %}>SSL</option>
                  <option value="tls"
                          {% if settings.smtp_encryption|default('') == 'tls' %}selected{% endif %}>TLS</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">From Email</label>
                <input type="email"
                       class="form-control"
                       name="mail_from_address"
                       placeholder="noreply@example.com"
                       value="{{ settings.mail_from_address|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">From Name</label>
                <input type="text"
                       class="form-control"
                       name="mail_from_name"
                       placeholder="Your Company Name"
                       value="{{ settings.mail_from_name|default("") }}">
              </div>
              <hr>
              <div class="mb-3">
                <label class="form-label">Send Test Email</label>
                <div class="input-group">
                  <input type="email"
                         class="form-control"
                         id="testEmailRecipient"
                         name="test_email"
                         placeholder="recipient@example.com"
                         value="{{ settings.mail_from_address|default("") }}">
                  <button class="modern-btn modern-btn-white"
                          id="sendTestEmailBtn"
                          type="button">Send Test</button>
                </div>
                <small class="text-muted">Sends a test email using current SMTP settings.</small>
              </div>
            </div>
            <!-- Security -->
            <div class="tab-pane fade" id="security">
              <!-- 2FA Alert -->
              <div class="alert alert-info mb-4" role="alert">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Two-Factor Authentication (2FA)</strong>
                <br>
                <small>Enable 2FA to add an extra layer of security for all users. Users can manage their 2FA settings from their profile.</small>
              </div>
              <div class="form-check form-switch mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       name="allow_user_registration"
                       {% if settings.allow_user_registration|default(false) %}checked{% endif %}>
                <label class="form-check-label">Allow User Registration</label>
              </div>
              <div class="form-check form-switch mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       name="require_email_verification"
                       {% if settings.require_email_verification|default(false) %}checked{% endif %}>
                <label class="form-check-label">Require Email Verification</label>
              </div>
              <!-- 2FA Settings Card -->
              <div class="admin-panel-card mb-3">
                <div class="admin-panel-card-body">
                  <h6 class="admin-panel-card-title mb-3">
                    <i class="bi bi-shield-lock me-2 text-success"></i> Two-Factor Authentication Settings
                  </h6>
                  <div class="form-check form-switch mb-3">
                    <input class="form-check-input"
                           type="checkbox"
                           name="enable_2fa"
                           {% if settings.enable_2fa|default(false) %}checked{% endif %}
                           id="enable_2fa">
                    <label class="form-check-label" for="enable_2fa">
                      <strong>Enable 2FA for All Users</strong>
                      <br>
                      <small class="text-muted">Users will need to set up 2FA when enabled</small>
                    </label>
                  </div>
                  <div class="d-grid gap-2 mb-3">
                    <a href="/user/security/2fa"
                       class="modern-btn modern-btn-primary modern-btn-sm"
                       target="_blank">
                      <i class="bi bi-arrow-up-right me-1"></i> View User 2FA Interface
                    </a>
                  </div>
                  <hr>
                  <div class="mb-3">
                    <label class="form-label">
                      <strong>Require 2FA for Admins Only</strong>
                    </label>
                    <p class="small text-muted mb-2">
                      Make 2FA mandatory only for admin accounts while keeping it optional for regular users.
                    </p>
                    <button type="button"
                            class="modern-btn modern-btn-success modern-btn-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#require2faAdminModal">
                      <i class="bi bi-gear me-1"></i> Configure Admin 2FA
                    </button>
                  </div>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Max Login Attempts</label>
                <input type="number"
                       class="form-control"
                       name="max_login_attempts"
                       placeholder="5"
                       value="{{ settings.max_login_attempts|default(5) }}">
              </div>
            </div>
            <!-- Payments -->
            <div class="tab-pane fade" id="payments">
              <div class="mb-3">
                <label class="form-label">Currency Code</label>
                <input type="text"
                       class="form-control"
                       name="currency_code"
                       placeholder="USD, EUR, GBP"
                       value="{{ settings.currency_code|default("USD") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Currency Symbol</label>
                <input type="text"
                       class="form-control"
                       name="currency_symbol"
                       placeholder="$, €, £"
                       value="{{ settings.currency_symbol|default("$") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Payment Gateway</label>
                <input type="text"
                       class="form-control"
                       name="payment_gateway"
                       placeholder="Stripe, PayPal, etc."
                       value="{{ settings.payment_gateway|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">Payment Mode</label>
                <select class="form-select" name="payment_mode">
                  <option value="sandbox"
                          {% if settings.payment_mode|default('sandbox') == 'sandbox' %}selected{% endif %}>
                    Sandbox
                  </option>
                  <option value="live"
                          {% if settings.payment_mode|default('sandbox') == 'live' %}selected{% endif %}>Live</option>
                </select>
              </div>
              <hr>
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <h6 class="fw-bold mb-0">Service Payment Methods</h6>
                <button type="button"
                        class="modern-btn modern-btn-white modern-btn-sm"
                        id="addPaymentMethodBtn">
                  <i class="bi bi-plus-circle me-1"></i>Add Method
                </button>
              </div>
              <p class="small text-muted mb-3">
                Add/remove methods here. Users will see this list in manual and gateway payment step.
              </p>
              <div id="paymentMethodsBuilder">
                {% for method in payment_method_list|default([]) %}
                  {% set method_key = method.key|default('') %}
                  {% set method_label = method.label|default('') %}
                  {% set method_data = manual_payment_methods[method_key]|default({}) %}
                  <div class="payment-method-row border rounded-3 p-3 mb-3">
                    <div class="d-flex justify-content-end mb-2">
                      <button type="button"
                              class="btn btn-sm btn-outline-danger remove-payment-method-btn">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                    <div class="row g-2">
                      <div class="col-md-4">
                        <label class="form-label">Method Key</label>
                        <input type="text"
                               class="form-control payment-method-key"
                               name="service_payment_method_key[]"
                               placeholder="e.g. bkash"
                               value="{{ method_key }}">
                        <small class="text-muted">Use lowercase letters, numbers, underscore.</small>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Method Label</label>
                        <input type="text"
                               class="form-control payment-method-label"
                               name="service_payment_method_label[]"
                               placeholder="e.g. bKash"
                               value="{{ method_label }}">
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Receiver Account Number</label>
                        <input type="text"
                               class="form-control"
                               name="service_payment_receiver_number[]"
                               placeholder="Receiver account number"
                               value="{{ method_data.receiver_number|default("") }}">
                      </div>
                      <div class="col-12">
                        <label class="form-label">Instruction Message</label>
                        <textarea class="form-control"
                                  name="service_payment_message[]"
                                  rows="2"
                                  placeholder="Method specific message for users">{{ method_data.message|default('') }}</textarea>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
            <!-- API / Integrations -->
            <div class="tab-pane fade" id="api">
              <div class="mb-3">
                <label class="form-label">Google Analytics ID</label>
                <input type="text"
                       class="form-control"
                       name="google_analytics_id"
                       placeholder="UA-XXXXXXXXX-X"
                       value="{{ settings.google_analytics_id|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">reCAPTCHA Site Key</label>
                <input type="text"
                       class="form-control"
                       name="recaptcha_site_key"
                       placeholder="Enter site key"
                       value="{{ settings.recaptcha_site_key|default("") }}">
              </div>
              <div class="mb-3">
                <label class="form-label">reCAPTCHA Secret Key</label>
                <input type="text"
                       class="form-control"
                       name="recaptcha_secret_key"
                       placeholder="Enter secret key"
                       value="{{ settings.recaptcha_secret_key|default("") }}">
              </div>
            </div>
            <!-- Cache -->
            <div class="tab-pane fade" id="cache">
              <div class="form-check form-switch mb-3">
                <input class="form-check-input"
                       type="checkbox"
                       name="enable_cache"
                       {% if settings.enable_cache|default(false) %}checked{% endif %}>
                <label class="form-check-label">Enable Cache</label>
              </div>
              <div class="mb-3">
                <label class="form-label">Cache Driver</label>
                <select class="form-select" name="cache_driver">
                  <option value="file"
                          {% if settings.cache_driver|default('file') == 'file' %}selected{% endif %}>File</option>
                  <option value="redis"
                          {% if settings.cache_driver|default('file') == 'redis' %}selected{% endif %}>Redis</option>
                  <option value="memcached"
                          {% if settings.cache_driver|default('file') == 'memcached' %}selected{% endif %}>
                    Memcached
                  </option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Cache Lifetime (seconds)</label>
                <input type="number"
                       class="form-control"
                       name="cache_lifetime"
                       placeholder="3600"
                       value="{{ settings.cache_lifetime|default(3600) }}">
              </div>
            </div>
            <div class="tab-pane fade" id="security_controls">
              <div class="row mb-4 security-settings-actions">
                <div class="col-12 text-end">
                  <div class="d-flex gap-2 justify-content-end">
                    <button type="button"
                            class="modern-btn modern-btn-white modern-btn-sm"
                            id="btnExport"
                            title="Export settings">
                      <i class="bi bi-download me-1"></i>Export
                    </button>
                    <button type="button"
                            class="modern-btn modern-btn-white modern-btn-sm"
                            id="btnImport"
                            title="Import settings">
                      <i class="bi bi-upload me-1"></i>Import
                    </button>
                    <button type="button"
                            class="modern-btn modern-btn-white modern-btn-sm"
                            id="btnReset"
                            title="Reset to defaults">
                      <i class="bi bi-arrow-clockwise me-1"></i>Reset
                    </button>
                  </div>
                </div>
              </div>
              <div id="settingsAlert" class="inl-a-0001">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  <strong id="alertMessage"></strong>
                  <button type="button" class="modern-btn-close" data-bs-dismiss="alert"></button>
                </div>
              </div>
              <div class="mb-4 security-settings-tabs-wrap">
                <ul class="nav nav-tabs border-0 security-settings-tabs"
                    role="tablist"
                    id="securityControlTabs">
                  {% for category, category_settings in settings_by_category %}
                    <li class="nav-item" role="presentation">
                      <button class="nav-link {% if loop.first %}active{% endif %}"
                              id="security-{{ category }}-tab"
                              data-bs-toggle="tab"
                              data-bs-target="#sec-cat-{{ category }}"
                              type="button"
                              role="tab">
                        <i class="bi bi-shield-fill me-2"></i>{{ category_labels[category] }}
                      </button>
                    </li>
                  {% endfor %}
                </ul>
              </div>
              <div class="tab-content" id="securityControlTabsContent">
                {% for category, category_settings in settings_by_category %}
                  <div class="tab-pane fade {% if loop.first %}show active{% endif %}"
                       id="sec-cat-{{ category }}"
                       role="tabpanel">
                    <div class="settings-form" data-category="{{ category }}">
                      {% if category_settings|length > 0 %}
                        <div class="row">
                          {% for key, setting in category_settings %}
                            <div class="col-md-6 mb-4">
                              <div class="admin-panel-card shadow-sm h-100">
                                <div class="admin-panel-card-body">
                                  <h6 class="mb-2 text-primary font-monospace" title="Setting key">
                                    {{ key }}
                                    {% if setting.is_sensitive %}
                                      <span class="badge bg-danger ms-2" title="Sensitive setting">
                                        <i class="bi bi-exclamation-triangle-fill"></i>
                                      </span>
                                    {% endif %}
                                  </h6>
                                  <p class="text-muted small mb-3">{{ setting.description }}</p>
                                  {% if setting.setting_type == 'boolean' %}
                                    <div class="form-check form-switch">
                                      <input class="form-check-input setting-input"
                                             type="checkbox"
                                             id="security-setting-{{ key }}"
                                             name="settings[{{ key }}]"
                                             data-key="{{ key }}"
                                             data-type="boolean"
                                             {% if setting.value %}checked{% endif %}>
                                      <label class="form-check-label" for="security-setting-{{ key }}">
                                        {% if setting.value %}
                                          Enabled
                                        {% else %}
                                          Disabled
                                        {% endif %}
                                      </label>
                                    </div>
                                  {% elseif setting.setting_type == 'integer' %}
                                    <input type="number"
                                           class="form-control setting-input"
                                           id="security-setting-{{ key }}"
                                           name="settings[{{ key }}]"
                                           data-key="{{ key }}"
                                           data-type="integer"
                                           value="{{ setting.value }}"
                                           placeholder="Enter value">
                                  {% elseif setting.setting_type == 'json' %}
                                    <textarea class="form-control setting-input font-monospace"
                                              id="security-setting-{{ key }}"
                                              name="settings[{{ key }}]"
                                              data-key="{{ key }}"
                                              data-type="json"
                                              rows="4"
                                              placeholder="Enter JSON">{{ setting.value|json_encode(constant('JSON_PRETTY_PRINT')) }}</textarea>
                                  {% else %}
                                    <input type="text"
                                           class="form-control setting-input"
                                           id="security-setting-{{ key }}"
                                           name="settings[{{ key }}]"
                                           data-key="{{ key }}"
                                           data-type="string"
                                           value="{{ setting.value }}"
                                           placeholder="Enter value">
                                  {% endif %}
                                  <div class="mt-3">
                                    <button type="button"
                                            class="modern-btn modern-btn-primary modern-btn-sm save-single-setting"
                                            data-key="{{ key }}"
                                            data-category="{{ category }}"
                                            data-input-id="security-setting-{{ key }}">
                                      <i class="bi bi-save me-1"></i>Save
                                    </button>
                                    <button type="button"
                                            class="modern-btn modern-btn-white modern-btn-sm reset-single-setting inl-a-0001"
                                            data-key="{{ key }}">
                                      <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                                    </button>
                                  </div>
                                  <small class="text-muted d-block mt-2">
                                    Last updated: <span class="updated-at" data-key="{{ key }}">{{ setting.updated_at }}</span>
                                  </small>
                                </div>
                              </div>
                            </div>
                          {% endfor %}
                        </div>
                      {% else %}
                        <div class="alert alert-info">
                          <i class="bi bi-info-circle-fill me-2"></i>No settings available in this category.
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
          <button type="submit" class="modern-btn modern-btn-primary">
            <i class="bi bi-save me-1"></i>Save Settings
          </button>
        </form>
      </div>
    </div>
  </div>
  <!-- 2FA Admin Configuration Modal -->
  <div class="modal fade"
       id="require2faAdminModal"
       tabindex="-1"
       aria-labelledby="require2faAdminModalLabel"
       aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-success text-white">
          <h5 class="modal-title" id="require2faAdminModalLabel">
            <i class="bi bi-shield-lock me-2"></i> Admin 2FA Configuration
          </h5>
          <button type="button"
                  class="modern-btn-close btn-close-white"
                  data-bs-dismiss="modal"
                  aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Configure whether 2FA is required for admin accounts only.</p>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input"
                   type="checkbox"
                   id="require2faAdmin"
                   name="require_2fa_for_admin"
                   {% if require_2fa_for_admin|default(false) %}checked{% endif %}>
            <label class="form-check-label" for="require2faAdmin">
              <strong>Require 2FA for Admins Only</strong>
            </label>
          </div>
          <div class="alert alert-info" role="alert">
            <small>
              <strong>Note:</strong> When enabled, only admin accounts will be required to use 2FA.
              Regular users can optionally enable it from their profile settings.
            </small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button"
                  class="modern-btn modern-btn-white"
                  data-bs-dismiss="modal">Cancel</button>
          <button type="button"
                  class="modern-btn modern-btn-primary"
                  id="save2faAdminBtn">
            <i class="bi bi-check-circle me-1"></i> Save Configuration
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <i class="bi bi-upload me-2 text-primary"></i>Import Settings
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="importForm" enctype="multipart/form-data">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <div class="mb-3">
              <label for="settingsFile" class="form-label">
                <i class="bi bi-file-earmark-json me-1 text-primary"></i>Select JSON File
              </label>
              <input class="form-control"
                     type="file"
                     id="settingsFile"
                     name="settings_file"
                     accept=".json"
                     required>
              <small class="text-muted d-block mt-2">Upload a previously exported settings file</small>
            </div>
            <div class="alert alert-warning" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i>
              <strong>Warning:</strong> Importing will overwrite current settings. Make sure to export current settings first.
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button"
                  class="modern-btn modern-btn-white"
                  data-bs-dismiss="modal">Cancel</button>
          <button type="button"
                  class="modern-btn modern-btn-primary"
                  id="confirmImport">Import Settings</button>
        </div>
      </div>
    </div>
  </div>
  <div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-danger text-white">
          <h5 class="modal-title">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>Reset All Settings
          </h5>
          <button type="button"
                  class="btn-close btn-close-white"
                  data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            <strong>Critical Action!</strong> This will reset all security settings to their default values.
          </div>
          <p>This action cannot be undone. Please make sure you have exported your current settings before proceeding.</p>
          <p class="mb-0">
            Type <strong class="text-danger">RESET_ALL_SETTINGS</strong> to confirm:
          </p>
          <input type="text"
                 class="form-control mt-2"
                 id="resetConfirmation"
                 placeholder="Type confirmation text">
        </div>
        <div class="modal-footer">
          <button type="button"
                  class="modern-btn modern-btn-white"
                  data-bs-dismiss="modal">Cancel</button>
          <button type="button"
                  class="modern-btn modern-btn-danger"
                  id="confirmReset"
                  disabled>Reset All Settings</button>
        </div>
      </div>
    </div>
  </div>
  <script>
document.addEventListener('DOMContentLoaded', function () {
    const builder = document.getElementById('paymentMethodsBuilder');
    const addBtn = document.getElementById('addPaymentMethodBtn');

    if (!builder || !addBtn) {
        return;
    }

    const slugifyMethodKey = (value) => {
        return String(value || '')
            .toLowerCase()
            .trim()
            .replace(/[^a-z0-9_]+/g, '_')
            .replace(/^_+|_+$/g, '');
    };

    const bindRowEvents = (row) => {
        const removeBtn = row.querySelector('.remove-payment-method-btn');
        const keyInput = row.querySelector('.payment-method-key');
        const labelInput = row.querySelector('.payment-method-label');

        if (removeBtn) {
            removeBtn.addEventListener('click', function () {
                const rows = builder.querySelectorAll('.payment-method-row');
                if (rows.length <= 1) {
                    return;
                }
                row.remove();
            });
        }

        if (labelInput && keyInput) {
            labelInput.addEventListener('blur', function () {
                if (keyInput.value.trim() === '') {
                    keyInput.value = slugifyMethodKey(labelInput.value);
                }
            });
        }

        if (keyInput) {
            keyInput.addEventListener('blur', function () {
                keyInput.value = slugifyMethodKey(keyInput.value);
            });
        }
    };

    const createRow = () => {
        const row = document.createElement('div');
        row.className = 'payment-method-row border rounded-3 p-3 mb-3';
        row.innerHTML = `
            <div class="d-flex justify-content-end mb-2">
                <button type="button" class="btn btn-sm btn-outline-danger remove-payment-method-btn">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Method Key</label>
                    <input type="text" class="form-control payment-method-key" name="service_payment_method_key[]" placeholder="e.g. custom_gateway">
                    <small class="text-muted">Use lowercase letters, numbers, underscore.</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Method Label</label>
                    <input type="text" class="form-control payment-method-label" name="service_payment_method_label[]" placeholder="e.g. Custom Gateway">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Receiver Account Number</label>
                    <input type="text" class="form-control" name="service_payment_receiver_number[]" placeholder="Receiver account number">
                </div>
                <div class="col-12">
                    <label class="form-label">Instruction Message</label>
                    <textarea class="form-control" name="service_payment_message[]" rows="2" placeholder="Method specific message for users"></textarea>
                </div>
            </div>
        `;
        bindRowEvents(row);
        return row;
    };

    builder.querySelectorAll('.payment-method-row').forEach(bindRowEvents);

    addBtn.addEventListener('click', function () {
        builder.appendChild(createRow());
    });
});
  </script>
{% endblock %}
