{% extends "admin/layout.twig" %}

{% block content %}
<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header pb-0">
                    <h6>Feature Flags (Super Admin)</h6>
                </div>
                <div class="card-body px-0 pt-0 pb-2">
                    <div class="table-responsive p-0">
                        <table class="table align-items-center mb-0">
                            <thead>
                                <tr>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Feature</th>
                                    <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 ps-2">Status</th>
                                    <th class="text-center text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Super Admin Only</th>
                                    <th class="text-secondary opacity-7"></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for feature in features %}
                                <tr>
                                    <td>
                                        <p class="text-xs font-weight-bold mb-0">{{ feature.feature_key }}</p>
                                    </td>
                                    <td>
                                        <span class="badge badge-sm bg-gradient-{{ feature.enabled ? 'success' : 'secondary' }}">
                                            {{ feature.enabled ? 'Enabled' : 'Disabled' }}
                                        </span>
                                    </td>
                                    <td class="align-middle text-center">
                                        <span class="text-secondary text-xs font-weight-bold">{{ feature.super_admin_only ? 'Yes' : 'No' }}</span>
                                    </td>
                                    <td class="align-middle">
                                        <form method="POST" action="/admin/feature-flags/toggle" class="d-inline">
                                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                            <input type="hidden" name="id" value="{{ feature.id }}">
                                            <button type="submit" class="btn btn-link text-secondary font-weight-bold text-xs">
                                                Toggle
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
