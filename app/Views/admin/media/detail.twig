{% extends "admin/layout.twig" %}
{% block title %}{{ media.filename }} - Media Details{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4" data-media-detail="true">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-image me-2"></i>
        Media Details
      </div>
      <div class="admin-page-subtitle">Media file information</div>
    </div>
    <!-- Header -->
    <div class="row mb-4">
      <div class="col-md-8">
        <h1>
          <i class="bi bi-image-fill"></i> Media Details
        </h1>
      </div>
      <div class="col-md-4 text-end">
        <a href="/admin/media" class="modern-btn modern-btn-white">
          <i class="bi bi-arrow-left"></i> Back to Library
        </a>
      </div>
    </div>
    <div class="row g-4">
      <!-- Media Preview -->
      <div class="col-lg-6">
        <div class="admin-panel-card shadow-sm">
          <div class="admin-panel-card-header">
            <h5 class="mb-0">Media Preview</h5>
          </div>
          <div class="admin-panel-card-body p-0">
            <div class="ratio ratio-16x9 bg-light">
              {% if media.media_type == 'image' %}
                <img src="{{ media_url }}"
                     alt="{{ media.title }}"
                     class="img-fluid w-100 h-100 inl-a-0014">
              {% elseif media.media_type == 'video' %}
                <video controls class="w-100 h-100 inl-a-0014">
                  <source src="{{ media_url }}" type="{{ media.mime_type }}">
                  Your browser does not support the video tag.
                </video>
              {% elseif media.media_type == 'audio' %}
                <audio controls class="w-100 inl-a-0015">
                  <source src="{{ media_url }}" type="{{ media.mime_type }}">
                  Your browser does not support the audio tag.
                </audio>
              {% else %}
                <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted">
                  <div class="text-center">
                    <i class="bi bi-file-earmark inl-a-0016"></i>
                    <p class="mt-3 mb-0">{{ media.media_type|upper }} File</p>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
        <!-- Thumbnail Preview (if exists) -->
        {% if thumbnail_url %}
          <div class="admin-panel-card shadow-sm mt-3">
            <div class="admin-panel-card-header">
              <h5 class="mb-0">Thumbnail</h5>
            </div>
            <div class="admin-panel-card-body p-2">
              <img src="{{ thumbnail_url }}"
                   alt="Thumbnail"
                   class="img-fluid w-100 rounded">
            </div>
          </div>
        {% endif %}
      </div>
      <!-- Media Information -->
      <div class="col-lg-6">
        <!-- Basic Info -->
        <div class="admin-panel-card shadow-sm mb-3">
          <div class="admin-panel-card-header">
            <h5 class="mb-0">Basic Information</h5>
          </div>
          <div class="admin-panel-card-body">
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>Media Type:</strong>
              </div>
              <div class="col-sm-8">
                <span class="badge bg-primary text-uppercase">{{ media.media_type }}</span>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>File Size:</strong>
              </div>
              <div class="col-sm-8">{{ media.file_size|filesizeformat }}</div>
            </div>
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>MIME Type:</strong>
              </div>
              <div class="col-sm-8">
                <code class="bg-light p-2 rounded">{{ media.mime_type }}</code>
              </div>
            </div>
            {% if media.width and media.height %}
              <div class="row mb-3">
                <div class="col-sm-4">
                  <strong>Dimensions:</strong>
                </div>
                <div class="col-sm-8">{{ media.width }} × {{ media.height }} pixels</div>
              </div>
            {% endif %}
            <div class="row mb-3">
              <div class="col-sm-4">
                <strong>Original Name:</strong>
              </div>
              <div class="col-sm-8">
                <small>{{ media.original_name }}</small>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-4">
                <strong>Uploaded:</strong>
              </div>
              <div class="col-sm-8">{{ media.created_at|date("d M Y H:i") }}</div>
            </div>
          </div>
        </div>
        <!-- Edit Information Form -->
        <div class="admin-panel-card shadow-sm mb-3">
          <div class="admin-panel-card-header">
            <h5 class="mb-0">Edit Information</h5>
          </div>
          <div class="admin-panel-card-body">
            <form method="POST" action="/admin/media/{{ media.id }}/update">
              <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text"
                       id="title"
                       name="title"
                       class="form-control"
                       value="{{ media.title }}"
                       required>
              </div>
              <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="description" class="form-control" rows="4">{{ media.description }}</textarea>
              </div>
              <button type="submit" class="modern-btn modern-btn-primary w-100">
                <i class="bi bi-check"></i> Save Changes
              </button>
            </form>
          </div>
        </div>
        <!-- File Path -->
        <div class="admin-panel-card shadow-sm mb-3">
          <div class="admin-panel-card-header">
            <h5 class="mb-0">File Path</h5>
          </div>
          <div class="admin-panel-card-body">
            <code class="bg-light p-3 rounded d-block text-break">{{ media_url }}</code>
            <button type="button"
                    class="modern-btn btn-sm btn-primary-outline mt-2"
                    onclick="copyToClipboard('{{ media_url }}')">
              <i class="bi bi-clipboard"></i> Copy URL
            </button>
          </div>
        </div>
        <!-- Danger Zone -->
        <div class="admin-panel-card shadow-sm border-danger mb-3">
          <div class="admin-panel-card-header bg-light border-danger">
            <h5 class="mb-0 text-danger">
              <i class="bi bi-exclamation-triangle"></i> Danger Zone
            </h5>
          </div>
          <div class="admin-panel-card-body">
            <p class="text-muted mb-3">Delete this media file. This action can be reversed from the trash for 30 days.</p>
            <form method="POST"
                  action="/admin/media/{{ media.id }}/delete"
                  onsubmit="return confirm('Are you sure? This media will be moved to trash.');">
              <button type="submit" class="modern-btn modern-btn-primary w-100">
                <i class="bi bi-trash"></i> Delete Media
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
