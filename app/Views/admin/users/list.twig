{% extends "admin/layout.twig" %}
{% block title %}Users{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-people"></i>
        Users Management
      </div>
      <div class="admin-page-subtitle">Manage all system users</div>
    </div>
    <div class="d-flex justify-content-end mb-4">
      <a href="/admin/users/create" class="modern-btn modern-btn-primary">
        <i class="bi bi-person-plus me-1"></i> Create User
      </a>
    </div>
    <!-- Card -->
    <div class="admin-panel-card">
      <div class="admin-panel-card-header">
        <h6 class="admin-panel-card-title mb-0">
          <i class="bi bi-people me-2"></i> Users List
        </h6>
      </div>
      <div class="admin-panel-card-body">
        <!-- Search & Filter Form -->
        <div class="border-bottom px-3 py-3 mb-3">
          <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
              <label class="form-label small text-muted mb-1">Search</label>
              <div class="input-group input-group-sm">
                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                <input type="text"
                       name="search"
                       value="{{ pagination.search|default("") }}"
                       class="form-control form-control-sm"
                       placeholder="Search by username, email, or name...">
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label small text-muted mb-1">Status</label>
              <select name="status" class="form-select form-select-sm">
                <option value="">All Status</option>
                <option value="active"
                        {% if pagination.status == 'active' %}selected{% endif %}>Active</option>
                <option value="inactive"
                        {% if pagination.status == 'inactive' %}selected{% endif %}>Inactive</option>
                <option value="pending"
                        {% if pagination.status == 'pending' %}selected{% endif %}>Pending</option>
                <option value="banned"
                        {% if pagination.status == 'banned' %}selected{% endif %}>Banned</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label small text-muted mb-1">Limit</label>
              <select name="limit" class="form-select form-select-sm">
                <option value="10">10 items</option>
                <option value="20" selected>20 items</option>
                <option value="50">50 items</option>
                <option value="100">100 items</option>
              </select>
            </div>
            <div class="col-md-3 text-end">
              <button type="submit" class="modern-btn modern-btn-primary btn-sm">
                <i class="bi bi-funnel me-1"></i> Apply
              </button>
            </div>
          </form>
        </div>
        <div class="admin-heavy-table-view table-container">
          <table class="table">
            <thead>
              <tr>
                <th>
                  <i class="bi bi-person-badge"></i> ID
                </th>
                <th>
                  <i class="bi bi-person"></i> Username
                </th>
                <th>
                  <i class="bi bi-envelope"></i> Email
                </th>
                <th>
                  <i class="bi bi-shield-check"></i> Roles
                </th>
                <th>
                  <i class="bi bi-toggle-on"></i> Status
                </th>
                <th class="text-center">
                  <i class="bi bi-gear"></i> Actions
                </th>
              </tr>
            </thead>
            <tbody>
              {% for user in users %}
                <tr>
                  <td class="fw-bold">{{ user.id }}</td>
                  <td>
                    <strong>{{ user.username }}</strong>
                    {% if user.first_name or user.last_name %}
                      <br>
                      <small class="text-muted">{{ user.first_name }} {{ user.last_name }}</small>
                    {% endif %}
                  </td>
                  <td>
                    <small>{{ user.email }}</small>
                  </td>
                  <td>
                    {% set roles = [] %}
                    {% if user.roles is iterable %}
                      {% for r in user.roles %}
                        {% if r is iterable %}
                          {% set roles = roles|merge([r.name|default('')]) %}
                        {% else %}
                          {% set roles = roles|merge([r]) %}
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                    {% if roles|length > 0 %}
                      <div class="d-flex flex-wrap gap-1">
                        {% for role in roles %}
                          {% if role %}
                            <span class="badge bg-{{ role|role_color|default("secondary") }}">
                              <i class="bi bi-shield-check me-1"></i>
                              {{ role|replace({"_": " "}) |title }}
                            </span>
                          {% endif %}
                        {% endfor %}
                      </div>
                    {% else %}
                      <span class="text-muted">No roles assigned</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if user.status == 'active' %}
                      <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                    {% elseif user.status == 'inactive' %}
                      <span class="badge bg-secondary"><i class="bi bi-ban"></i> Inactive</span>
                    {% elseif user.status == 'pending' %}
                      <span class="badge bg-warning text-surface-dark"><i class="bi bi-hourglass-split"></i> Pending</span>
                    {% elseif user.status == 'banned' %}
                      <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> Banned</span>
                    {% else %}
                      <span class="badge bg-secondary">{{ user.status }}</span>
                    {% endif %}
                  </td>
                  <td class="text-center">
                    <a href="/admin/users/edit?id={{ user.id }}"
                       class="modern-btn btn-sm btn-outline-warning me-1"
                       title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form method="POST" action="/admin/users/delete" class="d-inline">
                      <input type="hidden" name="id" value="{{ user.id }}">
                      <button type="submit"
                              class="modern-btn btn-sm btn-outline-danger"
                              title="Delete"
                              onclick="return confirm('Are you sure you want to delete this user?')">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-info-circle me-1"></i> No users found.
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        <div class="admin-heavy-card-view">
          {% if users is not empty %}
            {% for user in users %}
              {% set roles = [] %}
              {% if user.roles is iterable %}
                {% for r in user.roles %}
                  {% if r is iterable %}
                    {% set roles = roles|merge([r.name|default('')]) %}
                  {% else %}
                    {% set roles = roles|merge([r]) %}
                  {% endif %}
                {% endfor %}
              {% endif %}

              <article class="admin-heavy-card">
                <div class="admin-heavy-card-head">
                  <span class="admin-heavy-card-id">#{{ user.id }}</span>
                  {% if user.status == 'active' %}
                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                  {% elseif user.status == 'inactive' %}
                    <span class="badge bg-secondary"><i class="bi bi-ban"></i> Inactive</span>
                  {% elseif user.status == 'pending' %}
                    <span class="badge bg-warning text-surface-dark"><i class="bi bi-hourglass-split"></i> Pending</span>
                  {% elseif user.status == 'banned' %}
                    <span class="badge bg-danger"><i class="bi bi-exclamation-circle"></i> Banned</span>
                  {% else %}
                    <span class="badge bg-secondary">{{ user.status }}</span>
                  {% endif %}
                </div>

                <h6 class="admin-heavy-card-title mb-1">{{ user.username }}</h6>
                {% if user.first_name or user.last_name %}
                  <p class="text-muted small mb-1">{{ user.first_name }} {{ user.last_name }}</p>
                {% endif %}
                <p class="text-muted small mb-2"><i class="bi bi-envelope me-1"></i>{{ user.email }}</p>

                <div class="admin-heavy-card-meta">
                  {% if roles|length > 0 %}
                    <div class="d-flex flex-wrap gap-1">
                      {% for role in roles %}
                        {% if role %}
                          <span class="badge bg-{{ role|role_color|default("secondary") }}">
                            <i class="bi bi-shield-check me-1"></i>{{ role|replace({"_": " "}) |title }}
                          </span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% else %}
                    <span class="text-muted small">No roles assigned</span>
                  {% endif %}
                </div>

                <div class="admin-heavy-card-actions">
                  <a href="/admin/users/edit?id={{ user.id }}"
                     class="modern-btn btn-sm btn-outline-warning"
                     title="Edit">
                    <i class="bi bi-pencil me-1"></i>Edit
                  </a>
                  <form method="POST" action="/admin/users/delete" class="m-0">
                    <input type="hidden" name="id" value="{{ user.id }}">
                    <button type="submit"
                            class="modern-btn btn-sm btn-outline-danger"
                            title="Delete"
                            onclick="return confirm('Are you sure you want to delete this user?')">
                      <i class="bi bi-trash me-1"></i>Delete
                    </button>
                  </form>
                </div>
              </article>
            {% endfor %}
          {% else %}
            <div class="p-4 text-center text-muted">
              <i class="bi bi-info-circle me-1"></i> No users found.
            </div>
          {% endif %}
        </div>
        <!-- Pagination -->
        {% include "admin/partials/pagination.twig" %}
      </div>
    </div>
  </div>
{% endblock %}
