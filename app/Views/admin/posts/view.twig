{% extends "admin/layout.twig" %}
{% block title %}{{ post.title }}{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-file-earmark-text me-2"></i>
        Post Details
      </div>
      <div class="admin-page-subtitle">View post information</div>
    </div>
    <!-- Post Header -->
    <div class="admin-panel-card   mb-4">
      <div class="admin-panel-card-header">
        <h4 class="mb-0">
          <i class="bi bi-file-text me-2"></i>{{ post.title }}
        </h4>
      </div>
      <div class="admin-panel-card-body">
        <p class="mb-1 text-muted">
          <i class="bi bi-person me-1"></i> <strong>{{ post.author }}</strong>
          <span class="mx-2">|</span>
          <i class="bi bi-calendar me-1"></i> {{ post.created_at|date("Y-m-d H:i") }}
        </p>
        <!-- Stats -->
        <p class="small mb-2">
          <span class="badge bg-primary me-2"><i class="bi bi-graph-up me-1"></i>{{ post.impressions }} Impressions</span>
          <span class="badge bg-success me-2"><i class="bi bi-eye me-1"></i>{{ post.views }} Views</span>
          <span class="badge bg-secondary">
            <i class="bi bi-link me-1"></i>
            <a href="/posts/{{ post.slug }}"
               target="_blank"
               class="text-white text-decoration-underline">{{ post.slug }}</a>
          </span>
        </p>
        <!-- Categories -->
        {% if post.categories is defined and post.categories|length > 0 %}
          <p class="mb-2">
            <i class="bi bi-folder2-open text-warning me-1"></i>
            {% for category in post.categories %}
              <span class="badge bg-warning text-surface-dark me-1">{{ category.name }}</span>
            {% endfor %}
          </p>
        {% endif %}
        <!-- Tags -->
        {% if post.tags is defined and post.tags|length > 0 %}
          <p class="mb-0">
            <i class="bi bi-tags text-primary me-1"></i>
            {% for tag in post.tags %}<span class="badge bg-light text-surface-dark border me-1">#{{ tag.name }}</span>{% endfor %}
          </p>
        {% endif %}
      </div>
    </div>
    <!-- Post Content -->
    <div class="admin-panel-card   mb-4">
      <div class="admin-panel-card-body">{{ post.content|raw }}</div>
    </div>
    <!-- Comments Section -->
    <div class="admin-panel-card   mb-4">
      <div class="admin-panel-card-header">
        <h5 class="mb-0">
          <i class="bi bi-chat-dots me-2"></i>Comments & Feedback
        </h5>
      </div>
      <div class="admin-panel-card-body">
        <p class="text-muted">
          <i class="bi bi-info-circle me-1"></i>
          Comments are managed through the main Comments panel.
          <a href="/admin/comments" class="modern-btn btn-sm btn-primary ms-2">
            <i class="bi bi-chat-dots me-1"></i>Go to Comments Management
          </a>
        </p>
        <p class="mb-0">
          <small class="text-muted">
            <i class="bi bi-people me-1"></i>Users can post comments on the public post page at:
            <a href="/posts/{{ post.slug }}" target="_blank" class="text-primary">/posts/{{ post.slug }}</a>
          </small>
        </p>
      </div>
    </div>
    <!-- Back Button -->
    <div class="d-flex justify-content-end">
      <a href="/admin/posts" class="modern-btn modern-btn-white">
        <i class="bi bi-arrow-left me-1"></i> Back to Posts
      </a>
    </div>
  </div>
{% endblock %}
