{% extends 'admin/layout.twig' %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block title %}All Mobiles - Admin{% endblock %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-phone me-2"></i>
        Mobile Devices
      </div>
      <div class="admin-page-subtitle">Manage mobile devices</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h3 mb-0">All Mobiles</h1>
        <small class="text-muted">Full list of mobiles</small>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <a href="/admin/mobiles/insert" class="modern-btn btn-sm btn-success">
          <i class="bi bi-plus-circle me-1"></i> Add Mobile
        </a>
        <form method="get" class="d-flex gap-2 align-items-center">
          <input type="search"
                 name="search"
                 class="form-control form-control-sm"
                 placeholder="Search by brand or model"
                 value="{{ search|default("") }}">
          <select name="per_page" class="form-select form-select-sm">
            {% set cur_per = pagination.per_page|default(50) %}
            {% for opt in [10,25,50,100] %}
              <option value="{{ opt }}" {{ cur_per == opt ? 'selected' : '' }}>{{ opt }} per page
              </option>
            {% endfor %}
          </select>
          <select name="sort" class="form-select form-select-sm">
            {% set cur_sort = sort|default('brand_name') %}
            <option value="brand_name" {{ cur_sort == 'brand_name' ? 'selected' : '' }}>Brand
            </option>
            <option value="model_name" {{ cur_sort == 'model_name' ? 'selected' : '' }}>Model
            </option>
            <option value="release_date"
                    {{ cur_sort == 'release_date' ? 'selected' : '' }}>Release Date
            </option>
            <option value="created_at" {{ cur_sort == 'created_at' ? 'selected' : '' }}>Created
            </option>
          </select>
          <select name="order" class="form-select form-select-sm">
            {% set cur_order = order|default('ASC') %}
            <option value="ASC" {{ cur_order == 'ASC' ? 'selected' : '' }}>Asc
            </option>
            <option value="DESC" {{ cur_order == 'DESC' ? 'selected' : '' }}>Desc
            </option>
          </select>
          <button class="modern-btn btn-sm btn-primary">Apply</button>
        </form>
      </div>
    </div>
    <div class="admin-panel-card mb-4">
      <div class="admin-panel-card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Brand</th>
                <th>Model</th>
                <th>Status</th>
                <th>Release Date</th>
                <th class="text-center">Images</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              {% if mobiles is not empty %}
                {% for m in mobiles %}
                  <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ m.brand_name }}</td>
                    <td>{{ m.model_name }}</td>
                    <td>
                      <span class="badge bg-{% if m.status == 'official' %}primary{% elseif m.status == 'unofficial' %}warning{% else %}secondary{% endif %}">{{ m.status|capitalize }}</span>
                    </td>
                    <td>{{ m.release_date ? m.release_date|date("M d, Y") : 'N/A' }}</td>
                    <td class="text-center">{{ m.image_count|default(0) }}</td>
                    <td class="text-end">
                      <a href="/admin/mobiles/view/{{ m.id }}"
                         class="modern-btn btn-sm btn-outline-secondary"
                         title="View"><i class="bi bi-eye"></i></a>
                      <a href="/admin/mobiles/update/{{ m.id }}"
                         class="modern-btn btn-sm btn-outline-primary"
                         title="Edit"><i class="bi bi-pencil"></i></a>
                      <a href="/admin/mobiles/delete?id={{ m.id }}"
                         class="modern-btn btn-sm btn-outline-danger"
                         title="Delete"><i class="bi bi-trash"></i></a>
                    </td>
                  </tr>
                {% endfor %}
              {% else %}
                <tr>
                  <td colspan="7" class="text-center text-muted py-4">No mobiles found.</td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    {# Pagination #}
    {% set current = pagination.current_page|default(1) %}
    {% set total = pagination.total_pages|default(1) %}
    {% if total > 1 %}
      <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
          <li class="page-item {{ current <= 1 ? 'disabled' }}">
            <a class="page-link"
               href="?page={{ current - 1 }}&per_page={{ pagination.per_page|default(50) }}&search={{ search|url_encode }}&sort={{ sort|default("brand_name") }}&order={{ order|default("ASC") }}"
               aria-label="Previous">
              <span aria-hidden="true">&laquo;</span>
            </a>
          </li>
          {% for p in 1..total %}
            <li class="page-item {{ current == p ? 'active' }}">
              <a class="page-link"
                 href="?page={{ p }}&per_page={{ pagination.per_page|default(50) }}&search={{ search|url_encode }}&sort={{ sort|default("brand_name") }}&order={{ order|default("ASC") }}">{{ p }}</a>
            </li>
          {% endfor %}
          <li class="page-item {{ current >= total ? 'disabled' }}">
            <a class="page-link"
               href="?page={{ current + 1 }}&per_page={{ pagination.per_page|default(50) }}&search={{ search|url_encode }}&sort={{ sort|default("brand_name") }}&order={{ order|default("ASC") }}"
               aria-label="Next">
              <span aria-hidden="true">&raquo;</span>
            </a>
          </li>
        </ul>
      </nav>
    {% endif %}
  </div>
{% endblock %}
