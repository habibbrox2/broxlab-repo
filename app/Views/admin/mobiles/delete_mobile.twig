{% extends 'admin/layout.twig' %}
{% block title %}Delete Mobile{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="admin-panel-card">
      <div class="admin-panel-card-header d-flex align-items-center justify-content-between">
        <h4 class="mb-0">
          <i class="bi bi-trash text-danger me-2"></i>Delete Mobile
        </h4>
        <a href="/admin/mobiles/all" class="modern-btn modern-btn-white btn-sm"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
      </div>
      <div class="admin-panel-card-body">
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="bi bi-exclamation-triangle me-2"></i>
          <strong>Warning!</strong> This action cannot be undone. All associated data (images, specifications, tags, comments) will be permanently deleted.
          <button type="button"
                  class="btn-close"
                  data-bs-dismiss="alert"
                  aria-label="Close"></button>
        </div>
        <div class="admin-panel-card border-danger mb-4">
          <div class="card-body">
            <h5 class="card-title">Mobile Details</h5>
            <table class="table table-sm mb-0">
              <tbody>
                <tr>
                  <th class="inl-a-0026">Brand</th>
                  <td>
                    <strong>{{ mobile.brand_name }}</strong>
                  </td>
                </tr>
                <tr>
                  <th>Model</th>
                  <td>
                    <strong>{{ mobile.model_name }}</strong>
                  </td>
                </tr>
                <tr>
                  <th>Status</th>
                  <td>
                    <span class="badge bg-{% if mobile.status == 'official' %}primary{% elseif mobile.status == 'unofficial' %}warning{% else %}secondary{% endif %}">
                      {{ mobile.status|capitalize }}
                    </span>
                  </td>
                </tr>
                <tr>
                  <th>Release Date</th>
                  <td>{{ mobile.release_date ? mobile.release_date|date("F d, Y") : 'N/A' }}</td>
                </tr>
                <tr>
                  <th>Created</th>
                  <td>{{ mobile.created_at ? mobile.created_at|date("F d, Y H:i") : 'N/A' }}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="alert alert-info">
          <i class="bi bi-info-circle me-2"></i>
          <strong>Are you absolutely sure?</strong> This will delete this mobile device and all its associated data permanently.
        </div>
        <form method="post" id="deleteForm">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="confirmDelete" required>
            <label class="form-check-label" for="confirmDelete">
              I confirm that I want to permanently delete this mobile and all associated data
            </label>
          </div>
          <div class="d-flex gap-2">
            <button type="submit"
                    class="modern-btn modern-btn-danger"
                    id="deleteBtn"
                    disabled>
              <i class="bi bi-trash me-1"></i> Delete Permanently
            </button>
            <a href="/admin/mobiles/all" class="modern-btn modern-btn-white">
              <i class="bi bi-arrow-left me-1"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
