{% extends "admin/layout.twig" %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="service-form-wrapper">
    <div class="container service-form-container">
      <div class="header-glass-card mb-4">
        <div class="d-flex align-items-center justify-content-between gap-3">
          <div class="d-flex align-items-center gap-3">
            <div class="header-icon-badge">
              <i class="bi bi-tag"></i>
            </div>
            <div>
              <h1 class="page-title">Create New Tag</h1>
              <p class="page-subtitle">Add a tag for labeling content</p>
            </div>
          </div>
          <a href="/admin/tags" class="modern-btn modern-btn-secondary">Back to Tags</a>
        </div>
      </div>
      <div class="row g-4">
        <div class="col-lg-6 offset-lg-3">
          <div class="admin-panel-card">
            <div class="admin-panel-card-header">
              <h5 class="admin-panel-card-header-title">
                <i class="bi bi-info-circle-fill"></i> Tag Information
              </h5>
            </div>
            <div class="admin-panel-card-body">
              <!-- original form preserved -->
              <form method="post" action="/admin/tags/create" id="tagForm">
                <!-- Name Field -->
                <div class="mb-4">
                  <label class="modern-form-label">
                    Tag Name
                    <span class="required">*</span>
                  </label>
                  <input type="text"
                         name="name"
                         id="tagName"
                         class="modern-input form-control"
                         placeholder="e.g., JavaScript, PHP, Web Development"
                         required>
                  <div class="form-helper">
                    <i class="bi bi-info-circle me-1"></i> Enter a descriptive tag name
                  </div>
                </div>
                <!-- Slug -->
                <div class="mb-4">
                  <label class="modern-form-label">
                    URL Slug <span class="required">*</span>
                  </label>
                  <div class="modern-input-group">
                    <span class="modern-input-group-text"><i class="bi bi-link"></i></span>
                    <input type="text"
                           name="slug"
                           id="tagSlug"
                           class="modern-input form-control bg-light"
                           placeholder="auto-generated-slug">
                  </div>
                  <div id="slug-feedback" class="form-helper"></div>
                </div>
                <div class="d-flex gap-2 justify-content-end mt-4">
                  <a href="/admin/tags" class="modern-btn modern-btn-secondary">Cancel</a>
                  <button type="submit" class="modern-btn modern-btn-white">
                    <i class="bi bi-check me-1"></i> Create Tag
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
{% block scripts %}{% endblock %}
