{% extends 'admin/layout.twig' %}

{% block title %}AI Article Sources{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-rss me-2"></i>Article Sources</h4>
  <a href="/admin/autoblog/sources/create" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Add Source
  </a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>URL</th>
            <th>Type</th>
            <th>Category</th>
            <th>Interval</th>
            <th>Status</th>
            <th>Last Fetched</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for source in sources %}
          <tr>
            <td>{{ source.id }}</td>
            <td class="fw-semibold">{{ source.name }}</td>
            <td class="text-truncate small" style="max-width: 200px;" title="{{ source.url }}">
              <a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.url }}</a>
            </td>
            <td><span class="badge bg-info text-uppercase">{{ source.type }}</span></td>
            <td>{{ source.category_name ?? '-' }}</td>
            <td>{{ (source.fetch_interval / 60)|round }}m</td>
            <td>
              <a href="/admin/autoblog/sources/toggle?id={{ source.id }}" class="text-decoration-none"
                 title="Click to toggle">
                {% if source.is_active %}
                  <span class="badge bg-success">Active</span>
                {% else %}
                  <span class="badge bg-secondary">Inactive</span>
                {% endif %}
              </a>
            </td>
            <td class="small">
              {% if source.last_fetched_at %}
                {{ source.last_fetched_at|date('M d, H:i') }}
              {% else %}
                <span class="text-muted">Never</span>
              {% endif %}
            </td>
            <td>
              <div class="btn-group btn-group-sm">
                <a href="/admin/autoblog/sources/edit?id={{ source.id }}" class="btn btn-outline-primary" title="Edit">
                  <i class="bi bi-pencil"></i>
                </a>
                <a href="/admin/autoblog/sources/delete?id={{ source.id }}" class="btn btn-outline-danger"
                   title="Delete" onclick="return confirm('Delete this source and all its queued articles?')">
                  <i class="bi bi-trash"></i>
                </a>
              </div>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="9" class="text-center text-muted py-4">
              <i class="bi bi-rss fs-3 d-block mb-2"></i>
              No sources configured yet. Click "Add Source" to get started.
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
