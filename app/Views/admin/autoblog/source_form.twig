{% extends 'admin/layout.twig' %}

{% block title %}{{ isCreate ? 'Add' : 'Edit' }} Article Source{% endblock %}

{% block content %}
<div class="mb-4">
  <h4 class="fw-bold"><i class="bi bi-rss me-2"></i>{{ isCreate ? 'Add New' : 'Edit' }} Article Source</h4>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form method="POST" action="/admin/autoblog/sources/{{ isCreate ? 'create' : 'edit' }}">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      {% if not isCreate and source %}
        <input type="hidden" name="id" value="{{ source.id }}">
      {% endif %}

      <div class="row g-3">
        <div class="col-md-6">
          <label for="name" class="form-label fw-semibold">Source Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="name" name="name"
                 value="{{ source.name ?? '' }}" required placeholder="e.g., TechCrunch">
          <div class="form-text">A friendly name to identify this source</div>
        </div>

        <div class="col-md-6">
          <label for="type" class="form-label fw-semibold">Source Type</label>
          <select class="form-select" id="type" name="type" onchange="toggleSelectorFields()">
            <option value="rss" {{ (source.type ?? 'rss') == 'rss' ? 'selected' }}>RSS/Atom Feed</option>
            <option value="api" {{ (source.type ?? '') == 'api' ? 'selected' }}>JSON API</option>
            <option value="scrape" {{ (source.type ?? '') == 'scrape' ? 'selected' }}>Web Scraping</option>
          </select>
        </div>

        <div class="col-12">
          <label for="url" class="form-label fw-semibold">Source URL <span class="text-danger">*</span></label>
          <div class="input-group">
            <input type="url" class="form-control" id="url" name="url"
                   value="{{ source.url ?? '' }}" required placeholder="https://example.com/feed.xml or https://example.com/articles">
            <button type="button" class="btn btn-outline-info" onclick="detectSelectors()" id="btn-detect-selectors" title="Use AI to detect CSS selectors">
              <i class="bi bi-magic"></i> AI Detect
            </button>
          </div>
          <div class="form-text">Full URL to the RSS feed, Atom feed, API endpoint, or webpage to scrape</div>
        </div>

        <div class="col-md-6">
          <label for="category_id" class="form-label fw-semibold">Default Category</label>
          <select class="form-select" id="category_id" name="category_id">
            <option value="">-- Auto-detect --</option>
            {% for category in categories %}
              <option value="{{ category.id }}" {{ (source.category_id ?? '') == category.id ? 'selected' }}>
                {{ category.name }}
              </option>
            {% endfor %}
          </select>
          <div class="form-text">Category to assign to articles from this source</div>
        </div>

        <div class="col-md-3">
          <label for="fetch_interval" class="form-label fw-semibold">Fetch Interval</label>
          <div class="input-group">
            <input type="number" class="form-control" id="fetch_interval" name="fetch_interval"
                   value="{{ ((source.fetch_interval ?? 600) / 60)|round }}" min="1" max="1440">
            <span class="input-group-text">minutes</span>
          </div>
        </div>

        <div class="col-md-3 d-flex align-items-end">
          <div class="form-check form-switch mb-3">
            <input type="checkbox" class="form-check-input" id="is_active" name="is_active"
                   {{ (source.is_active ?? 1) ? 'checked' }}>
            <label class="form-check-label fw-semibold" for="is_active">Active</label>
          </div>
        </div>
      </div>

      {# Custom CSS Selectors Section #}
      <hr class="my-4">
      
      <h6 class="fw-bold mb-3">
        <i class="bi bi-code-slash me-2"></i>Custom CSS Selectors
        <span class="badge bg-info ms-2" id="selector-badge">Optional</span>
      </h6>
      <p class="text-muted small mb-3">
        Specify custom CSS selectors for web scraping. If left empty, default selectors will be used.
        Click "AI Detect" button to automatically find the best selectors for the URL.
      </p>

      <div id="selector-fields" class="row g-3" style="{{ (source.type ?? '') == 'scrape' ? '' : 'display:none;' }}">
        {# List Page Selectors #}
        <div class="col-12">
          <h6 class="fw-semibold text-primary mb-2">
            <i class="bi bi-list-ul me-1"></i>List Page Selectors
            <small class="text-muted">(for finding article links)</small>
          </h6>
        </div>

        <div class="col-md-6">
          <label for="selector_list_container" class="form-label fw-semibold">Article Container Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_list_container" name="selector_list_container"
                 value="{{ source.selector_list_container ?? '' }}" 
                 placeholder=".article-list, .news-items, article">
          <div class="form-text">CSS selector for the container holding multiple articles</div>
        </div>

        <div class="col-md-6">
          <label for="selector_list_item" class="form-label fw-semibold">Article Item Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_list_item" name="selector_list_item"
                 value="{{ source.selector_list_item ?? '' }}" 
                 placeholder=".article-item, .news-item, .post">
          <div class="form-text">CSS selector for individual article items within the container</div>
        </div>

        <div class="col-md-6">
          <label for="selector_list_title" class="form-label fw-semibold">Title Link Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_list_title" name="selector_list_title"
                 value="{{ source.selector_list_title ?? '' }}" 
                 placeholder="h3 a, .title a, .headline a">
          <div class="form-text">CSS selector for article title links within each item</div>
        </div>

        <div class="col-md-6">
          <label for="selector_list_date" class="form-label fw-semibold">Date Selector (List)</label>
          <input type="text" class="form-control font-monospace" id="selector_list_date" name="selector_list_date"
                 value="{{ source.selector_list_date ?? '' }}" 
                 placeholder="time, .date, .published">
          <div class="form-text">CSS selector for publish date in the list (optional)</div>
        </div>

        {# Article Page Selectors #}
        <div class="col-12 mt-4">
          <h6 class="fw-semibold text-success mb-2">
            <i class="bi bi-file-text me-1"></i>Article Page Selectors
            <small class="text-muted">(for extracting content from individual articles)</small>
          </h6>
        </div>

        <div class="col-md-4">
          <label for="selector_title" class="form-label fw-semibold">Title Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_title" name="selector_title"
                 value="{{ source.selector_title ?? '' }}" 
                 placeholder="h1, .post-title, article h1">
          <div class="form-text">CSS selector for article title</div>
        </div>

        <div class="col-md-4">
          <label for="selector_content" class="form-label fw-semibold">Content Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_content" name="selector_content"
                 value="{{ source.selector_content ?? '' }}" 
                 placeholder="article, .post-content, .entry-content">
          <div class="form-text">CSS selector for main article content</div>
        </div>

        <div class="col-md-4">
          <label for="selector_image" class="form-label fw-semibold">Image Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_image" name="selector_image"
                 value="{{ source.selector_image ?? '' }}" 
                 placeholder="meta[property='og:image'], article img">
          <div class="form-text">CSS selector for featured image</div>
        </div>

        <div class="col-md-4">
          <label for="selector_excerpt" class="form-label fw-semibold">Excerpt Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_excerpt" name="selector_excerpt"
                 value="{{ source.selector_excerpt ?? '' }}" 
                 placeholder="meta[name='description'], .excerpt">
          <div class="form-text">CSS selector for article excerpt/description</div>
        </div>

        <div class="col-md-4">
          <label for="selector_date" class="form-label fw-semibold">Date Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_date" name="selector_date"
                 value="{{ source.selector_date ?? '' }}" 
                 placeholder="time, .date, .published">
          <div class="form-text">CSS selector for publish date</div>
        </div>

        <div class="col-md-4">
          <label for="selector_author" class="form-label fw-semibold">Author Selector</label>
          <input type="text" class="form-control font-monospace" id="selector_author" name="selector_author"
                 value="{{ source.selector_author ?? '' }}" 
                 placeholder=".author, .byline, [rel='author']">
          <div class="form-text">CSS selector for article author</div>
        </div>
      </div>

      <hr class="my-4">

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-lg me-1"></i>{{ isCreate ? 'Add Source' : 'Update Source' }}
        </button>
        <a href="/admin/autoblog/sources" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

{# AI Detection Loading Modal #}
<div class="modal fade" id="aiDetectModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-body text-center py-4">
        <div class="spinner-border text-primary mb-3" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <h5 class="mb-2">AI is analyzing the webpage...</h5>
        <p class="text-muted small">This may take a few seconds</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
  function toggleSelectorFields() {
    var type = document.getElementById('type').value;
    var selectorFields = document.getElementById('selector-fields');
    var badge = document.getElementById('selector-badge');
    
    if (type === 'scrape') {
      selectorFields.style.display = 'flex';
      badge.textContent = 'Optional';
      badge.className = 'badge bg-info ms-2';
    } else if (type === 'api') {
      selectorFields.style.display = 'none';
      badge.textContent = 'N/A';
      badge.className = 'badge bg-secondary ms-2';
    } else {
      selectorFields.style.display = 'none';
      badge.textContent = 'Optional';
      badge.className = 'badge bg-secondary ms-2';
    }
  }

  // Detect selectors using AI
  async function detectSelectors() {
    var url = document.getElementById('url').value.trim();
    
    if (!url) {
      showFlashMessage('Please enter a Source URL first', 'warning');
      return;
    }
    
    if (!url.startsWith('http://') && !url.startsWith('https://')) {
      showFlashMessage('Please enter a valid URL starting with http:// or https://', 'warning');
      return;
    }

    // Show loading modal
    var modal = new bootstrap.Modal(document.getElementById('aiDetectModal'));
    modal.show();

    try {
      var formData = new FormData();
      formData.append('url', url);

      var response = await fetch('/admin/autoblog/api/detect-selectors', {
        method: 'POST',
        body: formData
      });

      var data = await response.json();

      modal.hide();

      if (data.success) {
        // Fill in the detected selectors
        if (data.selectors.list_container) {
          document.getElementById('selector_list_container').value = data.selectors.list_container;
        }
        if (data.selectors.list_item) {
          document.getElementById('selector_list_item').value = data.selectors.list_item;
        }
        if (data.selectors.list_title) {
          document.getElementById('selector_list_title').value = data.selectors.list_title;
        }
        if (data.selectors.list_date) {
          document.getElementById('selector_list_date').value = data.selectors.list_date;
        }
        if (data.selectors.title) {
          document.getElementById('selector_title').value = data.selectors.title;
        }
        if (data.selectors.content) {
          document.getElementById('selector_content').value = data.selectors.content;
        }
        if (data.selectors.image) {
          document.getElementById('selector_image').value = data.selectors.image;
        }
        if (data.selectors.excerpt) {
          document.getElementById('selector_excerpt').value = data.selectors.excerpt;
        }
        if (data.selectors.date) {
          document.getElementById('selector_date').value = data.selectors.date;
        }
        if (data.selectors.author) {
          document.getElementById('selector_author').value = data.selectors.author;
        }

        // Show success message
        showFlashMessage(data.message || 'Selectors detected successfully', 'success');
      } else {
        showFlashMessage(data.message || 'Failed to detect selectors', 'error');
      }
    } catch (error) {
      modal.hide();
      console.error('Error:', error);
      showFlashMessage('An error occurred while detecting selectors. Please try again.', 'error');
    }
  }

  // Flash message helper function
  function showFlashMessage(message, status) {
    if (!Array.isArray(window.__INITIAL_FLASH_QUEUE)) {
      window.__INITIAL_FLASH_QUEUE = [];
    }

    window.__INITIAL_FLASH_QUEUE.push({
      text: message,
      status: status,
      duration: status === 'error' ? 8000 : 5000
    });

    // Trigger SweetAlert2 if available
    if (typeof Swal !== 'undefined') {
      Swal.fire({
        text: message,
        icon: status === 'error' ? 'error' : (status === 'success' ? 'success' : 'info'),
        timer: status === 'error' ? 8000 : 5000,
        showConfirmButton: false,
        toast: true,
        position: 'top-end'
      });
    }
  }

  // Convert fetch_interval from minutes to seconds before submit
  document.querySelector('form').addEventListener('submit', function(e) {
    var intervalInput = document.getElementById('fetch_interval');
    intervalInput.value = parseInt(intervalInput.value || 10) * 60;
  });

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', toggleSelectorFields);
</script>
{% endblock %}
