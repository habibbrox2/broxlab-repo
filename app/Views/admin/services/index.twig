{% extends "admin/layout.twig" %}
{# Admin Services List #}
{% block title %}Manage Services{% endblock %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-card-list"></i>
        Services Management
      </div>
      <div class="admin-page-subtitle">
        <small>Manage your service catalog</small>
      </div>
    </div>
    <div class="d-flex justify-content-end mb-4">
      <a href="/admin/services/create" class="modern-btn modern-btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Create Service
      </a>
    </div>
    <div class="admin-panel-card">
      <div class="admin-panel-card-body p-0">
        {% if services is not empty %}
          <div class="admin-heavy-table-view table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>
                    <input type="checkbox" id="selectAll" class="form-check-input">
                  </th>
                  <th>Name</th>
                  <th>Status</th>
                  <th>Applications</th>
                  <th>Impressions</th>
                  <th>Views</th>
                  <th>Created</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for service in services %}
                  <tr>
                    <td>
                      <input type="checkbox"
                             class="form-check-input service-checkbox"
                             value="{{ service.id }}">
                    </td>
                    <td>
                      <div class="d-flex align-items-center gap-3">
                        <div class="inl-a-0054">
                          {% if service.images is defined and service.images is not empty %}
                            <div id="svcCarousel-{{ service.id }}"
                                 class="carousel slide rounded-2 overflow-hidden"
                                 data-bs-ride="carousel">
                              <div class="carousel-inner">
                                {% for img in service.images %}
                                  <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                                    <img src="{{ img.thumbnail_path|default(img.image_path) |default('/assets/img/no-image.png') }}"
                                         class="d-block w-100 inl-a-0055"
                                         alt="{{ service.name }}">
                                  </div>
                                {% endfor %}
                              </div>
                            </div>
                          {% elseif service.icon %}
                            <div class="bg-light d-flex align-items-center justify-content-center rounded-2 inl-a-0056">
                              <i class="{{ service.icon }} fs-4 text-muted"></i>
                            </div>
                          {% else %}
                            <div class="bg-light d-flex align-items-center justify-content-center rounded-2 inl-a-0056">
                              <i class="bi bi-card-image fs-4 text-muted"></i>
                            </div>
                          {% endif %}
                        </div>
                        <div class="flex-grow-1">
                          <div class="d-flex align-items-center gap-2">
                            <strong>{{ service.name }}</strong>
                            {% if service.is_premium is defined and service.is_premium == 1 %}
                              <span class="badge bg-warning text-surface-dark"> <i class="bi bi-star-fill me-1"></i> Premium</span>
                            {% endif %}
                          </div>
                          <div>
                            <small class="text-muted">{{ service.slug }}</small>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td>
                      <span class="badge {% if service.status == 'active' %}bg-success {% elseif service.status == 'inactive' %}bg-warning {% elseif service.status == 'archived' %}bg-info {% else %}bg-light text-surface-dark{% endif %}">
                        {{ service.status|capitalize }}
                      </span>
                    </td>
                    <td>
                      <span class="badge bg-info">{{ service.total_applications|default(0) }}</span>
                    </td>
                    <td>
                      <span class="badge bg-light text-surface-dark">{{ service.impressions|default(0) |number_format }}</span>
                    </td>
                    <td>
                      <span class="badge bg-light text-surface-dark">{{ service.views|default(0) |number_format }}</span>
                    </td>
                    <td class="text-muted small">{{ service.created_at|date("d M Y") }}</td>
                    <td class="text-end">
                      <a href="/admin/services/details/{{ service.id }}"
                         class="modern-btn btn-sm btn-info">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/admin/services/{{ service.id }}/edit"
                         class="modern-btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <button type="button"
                              class="modern-btn btn-sm btn-danger delete-service"
                              data-id="{{ service.id }}">
                        <i class="bi bi-trash"></i>
                      </button>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>

          <div class="admin-heavy-card-view">
            {% for service in services %}
              <article class="admin-heavy-card">
                <div class="d-flex align-items-start gap-3 mb-2">
                  <div class="inl-a-0054 flex-shrink-0">
                    {% if service.images is defined and service.images is not empty %}
                      {% set firstImage = service.images|first %}
                      <img src="{{ firstImage.thumbnail_path|default(firstImage.image_path) |default('/assets/img/no-image.png') }}"
                           class="d-block w-100 rounded-2 inl-a-0055"
                           alt="{{ service.name }}">
                    {% elseif service.icon %}
                      <div class="bg-light d-flex align-items-center justify-content-center rounded-2 inl-a-0056">
                        <i class="{{ service.icon }} fs-4 text-muted"></i>
                      </div>
                    {% else %}
                      <div class="bg-light d-flex align-items-center justify-content-center rounded-2 inl-a-0056">
                        <i class="bi bi-card-image fs-4 text-muted"></i>
                      </div>
                    {% endif %}
                  </div>

                  <div class="flex-grow-1">
                    <div class="admin-heavy-card-head mb-1">
                      <span class="admin-heavy-card-id">#{{ service.id }}</span>
                      <span class="badge {% if service.status == 'active' %}bg-success{% elseif service.status == 'inactive' %}bg-warning text-surface-dark{% elseif service.status == 'archived' %}bg-info{% else %}bg-light text-surface-dark{% endif %}">
                        {{ service.status|capitalize }}
                      </span>
                    </div>
                    <h6 class="admin-heavy-card-title mb-1">{{ service.name }}</h6>
                    <p class="text-muted small mb-1">{{ service.slug }}</p>
                    {% if service.is_premium is defined and service.is_premium == 1 %}
                      <span class="badge bg-warning text-surface-dark"><i class="bi bi-star-fill me-1"></i>Premium</span>
                    {% endif %}
                  </div>
                </div>

                <div class="admin-heavy-card-meta">
                  <span class="badge bg-info">Apps: {{ service.total_applications|default(0) }}</span>
                  <span class="badge bg-light text-surface-dark">Impr: {{ service.impressions|default(0) |number_format }}</span>
                  <span class="badge bg-light text-surface-dark">Views: {{ service.views|default(0) |number_format }}</span>
                  <span class="text-muted small"><i class="bi bi-calendar-event me-1"></i>{{ service.created_at|date("d M Y") }}</span>
                </div>

                <div class="admin-heavy-card-actions">
                  <a href="/admin/services/details/{{ service.id }}"
                     class="modern-btn btn-sm btn-info">
                    <i class="bi bi-eye me-1"></i>View
                  </a>
                  <a href="/admin/services/{{ service.id }}/edit"
                     class="modern-btn btn-sm btn-warning">
                    <i class="bi bi-pencil me-1"></i>Edit
                  </a>
                  <button type="button"
                          class="modern-btn btn-sm btn-danger delete-service"
                          data-id="{{ service.id }}">
                    <i class="bi bi-trash me-1"></i>Delete
                  </button>
                </div>
              </article>
            {% endfor %}
          </div>
          {# Pagination #}
          {% if pagination.total_pages > 1 %}
            <nav class="d-flex justify-content-between align-items-center p-3 border-top">
              <small class="text-muted">Showing {{ (pagination.current_page - 1) * pagination.limit + 1 }} to {{ min(pagination.current_page * pagination.limit, pagination.total) }} of {{ pagination.total }}</small>
              <ul class="pagination mb-0">
                {% if pagination.has_previous %}
                  <li class="page-item">
                    <a class="page-link" href="/admin/services?page=1">First</a>
                  </li>
                  <li class="page-item">
                    <a class="page-link"
                       href="/admin/services?page={{ pagination.previous_page }}">Previous</a>
                  </li>
                {% endif %}
                {% for page in range(max(1, pagination.current_page - 2), min(pagination.total_pages, pagination.current_page + 2)) %}
                  <li class="page-item {{ page == pagination.current_page ? 'active' }}">
                    <a class="page-link" href="/admin/services?page={{ page }}">{{ page }}</a>
                  </li>
                {% endfor %}
                {% if pagination.has_next %}
                  <li class="page-item">
                    <a class="page-link"
                       href="/admin/services?page={{ pagination.next_page }}">Next</a>
                  </li>
                  <li class="page-item">
                    <a class="page-link"
                       href="/admin/services?page={{ pagination.total_pages }}">Last</a>
                  </li>
                {% endif %}
              </ul>
            </nav>
          {% endif %}
        {% else %}
          <div class="p-5 text-center">
            <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted mb-0">
              No services yet. <a href="/admin/services/create">Create the first one</a>
            </p>
          </div>
        {% endif %}
      </div>
    </div>
    {# Delete Modal #}
    <div class="modal fade" id="deleteModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content border-0 rounded-4 shadow-lg">
          <div class="modal-header border-bottom fw-600">
            <h6 class="modal-title">
              <i class="bi bi-trash3-fill me-2 text-danger"></i>Delete Service
            </h6>
            <button type="button" class="modern-btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <p>Are you sure you want to delete this service? This action cannot be undone.</p>
          </div>
          <div class="modal-footer border-top">
            <button type="button"
                    class="modern-btn modern-btn-secondary btn-sm"
                    data-bs-dismiss="modal">Cancel</button>
            <button type="button"
                    class="modern-btn modern-btn-primary btn-sm"
                    id="confirmDelete">Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
