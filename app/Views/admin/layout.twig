{# Admin panel layout #}
<!DOCTYPE html>
<html lang="en" data-theme="light">

{# ===== Imports ===== #}
{% import '_macros/flash.twig' as flash_macros %}
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{% block title %}{{ title|default('Admin') }}{% endblock %}</title>
    <meta name="robots" content="noindex, nofollow">
    <meta name="csrf-token" content="{{ csrf_token }}">
    {% if auth_user.id %}<meta name="user-id" content="{{ auth_user.id }}">{% endif %}
    {% if auth_user.id %}
    <script>
      // expose the list of permissions the current admin has for client-side checks
      window.ADMIN_PERMISSIONS = {{ getUserPermissions(auth_user.id)|json_encode|raw }};
      // super-admins bypass every permission check
      window.IS_SUPER_ADMIN = {{ auth_user.is_super_admin ? 'true' : 'false' }};
      // expose current user id for RBAC API lookups
      window.AUTH_USER_ID = {{ auth_user.id|default('null') }};
    </script>
    {% endif %}

    <script>
      (function () {
        try {
          var root = document.documentElement;
          var savedTheme = localStorage.getItem('broxbhai-theme') || localStorage.getItem('app-theme');
          var isValidSavedTheme = savedTheme === 'dark' || savedTheme === 'light';
          var resolvedTheme = isValidSavedTheme
            ? savedTheme
            : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

          root.setAttribute('data-theme', resolvedTheme);
          root.style.colorScheme = resolvedTheme;
        } catch (error) {
          // Ignore storage/media-query failures and keep default light theme.
        }
      })();
    </script>

    <link rel="icon" type="image/x-icon" href="{{ app_settings.favicon|default('/assets/logo/favicon.ico') }}">

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Sans+Bengali:wght@100..900&display=swap" rel="stylesheet">

    {# Core styles #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="{{ asset('/assets/css/tailwind.css') }}">
    <link rel="stylesheet" href="{{ asset('/assets/css/1-variables.css') }}">
    <link rel="stylesheet" href="{{ asset('/assets/css/2-base.css') }}">
    <link rel="stylesheet" href="{{ asset('/assets/css/7-dark-mode.css') }}">
    <link rel="stylesheet" href="{{ asset('/assets/css/admin.css') }}">

    {# Icons #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    {# Third-party styles #}
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.0/dist/sweetalert2.min.css" rel="stylesheet">
    
    {# Page-specific styles #}
    {% block stylesheets %}{% endblock %}

</head>
<body data-admin-dir="{{ admin_dir|default('/admin') }}">

  <!-- Header -->
  <header class="navbar navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container-fluid">
      <button class="sidebar-toggle btn btn-dark d-lg-none me-2" type="button">
        <i class="bi bi-list"></i>
      </button>
      <a class="navbar-brand d-flex align-items-center" href="/admin/dashboard">
        <i class="bi bi-speedometer2 me-2"></i> Admin Panel
      </a>
      <div class="d-flex align-items-center ms-auto gap-3 admin-topbar-actions">
        <!-- Admin Notification Bell -->
        <div class="admin-notification-dropdown-wrap brox-notification-wrapper" data-notification-menu>
          {% set admin_unread_count = unread_count|default(0) %}
          <a class="admin-notification-bell"
             href="#"
             id="adminNotificationBell"
             data-notification-bell
             aria-expanded="false"
             title="Notifications">
            <i class="bi bi-bell-fill admin-notification-bell-icon"></i>
            <span id="adminNotificationBadge"
                  data-notification-badge
                  class="admin-notification-badge {% if admin_unread_count <= 0 %}d-none{% endif %}">
              <span id="adminNotificationCount" data-notification-count>{{ admin_unread_count }}</span>
            </span>
          </a>
          <div class="admin-notification-dropdown" data-notification-dropdown aria-labelledby="adminNotificationBell">
            <div class="admin-notification-dropdown-header">
              <h6 class="admin-notification-dropdown-title">
                <i class="bi bi-bell-fill me-2"></i>Notifications
              </h6>
            </div>
            <div id="adminNotificationsList"
                 data-notification-list
                 class="admin-notification-list"
                 data-user-id="{{ auth_user.id|default('') }}">
              {% if notifications is defined and notifications is iterable and notifications|length > 0 %}
                {% for notif in notifications|slice(0, 10) %}
                  <div class="notification-entry admin-notification-entry {% if notif.is_read is defined and notif.is_read == 0 %}bg-light border-start border-primary border-2{% endif %}"
                       data-notification-id="{{ notif.id }}"
                       {% if notif.action_url is defined and notif.action_url %}data-action-url="{{ notif.action_url }}"{% endif %}>
                    <div class="d-flex align-items-start gap-2">
                      <div class="flex-grow-1">
                        <div class="fw-semibold small mb-1 admin-notification-entry-title">{{ notif.title }}</div>
                        <div class="small text-muted mb-1 admin-notification-entry-message">{{ notif.message }}</div>
                        <div class="small text-secondary">{{ notif.created_at|date("n/j/Y, g:i:s A") }}</div>
                      </div>
                      {% if notif.is_read is defined and notif.is_read == 0 %}
                        <button type="button"
                                class="btn btn-sm btn-outline-primary admin-notification-read-btn"
                                data-action="mark-read"
                                data-notification-id="{{ notif.id }}">Read</button>
                      {% endif %}
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="admin-notification-empty text-muted">
                  <i class="bi bi-inbox admin-notification-empty-icon"></i>
                  <p class="admin-notification-empty-text">No notifications yet</p>
                </div>
              {% endif %}
            </div>
            <div class="dropdown-divider admin-notification-divider"></div>
            <a href="/admin/my/notifications" class="dropdown-item admin-notification-view-all">
              <i class="bi bi-arrow-right me-1"></i>View all notifications
            </a>
          </div>
        </div>

        <button
          class="btn btn-dark btn-sm"
          id="broxThemeToggle"
          type="button"
          title="Toggle theme"
          aria-label="Toggle dark mode"
          aria-pressed="false">
          <i class="bi bi-circle-half"></i>
        </button>

        {% if auth_user.is_authenticated %}
        <div class="dropdown admin-user-menu" data-admin-user-menu>
          <a class="d-flex align-items-center text-white text-decoration-none dropdown-toggle admin-user-toggle"
            href="#"
            id="adminUserMenu"
            data-bs-toggle="dropdown"
            data-admin-user-toggle
            aria-expanded="false"
            aria-haspopup="true">
            <img src="{{ auth_user.profile_pic|default('/assets/images/default-avatar.png') }}" alt="Profile"
                class="rounded-circle me-2 admin-user-avatar" style="width:32px; height:32px; object-fit:cover;">
            <div class="d-none d-sm-block text-start admin-user-meta">
              <div class="small">{{ auth_user.username }}</div>
              {% if auth_user.roles is not empty %}
                <div class="small text-info">{{ auth_user.roles|join(', ')|upper }}</div>
              {% endif %}
            </div>
          </a>
          <ul class="dropdown-menu text-small admin-user-dropdown" data-admin-user-dropdown aria-labelledby="adminUserMenu">
            <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/profile"><i class="bi bi-person-circle me-1"></i> Profile</a></li>
            <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/dashboard"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a></li>
            <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/my/notifications"><i class="bi bi-bell me-1"></i> My Notifications</a></li>
            <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/account-settings"><i class="bi bi-gear me-1"></i> Account Settings</a></li>

            {% if auth_user.is_super_admin %}
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/roles"><i class="bi bi-shield-lock me-1"></i> Manage Roles</a></li>
              <li><a class="dropdown-item admin-user-dropdown-item" href="/admin/permissions"><i class="bi bi-key me-1"></i> Manage Permissions</a></li>
            {% endif %}

            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item admin-user-dropdown-item text-danger" href="/logout" data-unified-logout><i class="bi bi-box-arrow-right me-1"></i> Logout</a></li>
          </ul>
        </div>
        {% endif %}

      </div>
    </div>
  </header>

  <div class="container-fluid">
    <div class="row admin-shell-row">

  {% set settings_children = [
      {'name': 'Account Settings', 'url': '/admin/account-settings', 'key': 'account-settings'}
  ] %}
  {% if auth_user.is_super_admin %}
      {% set settings_children = settings_children|merge([
          {'name': 'App Settings', 'url': '/admin/app-settings', 'key': 'app-settings'},
          {'name': 'Telegram Settings', 'url': '/admin/telegram-settings', 'key': 'telegram-settings'},
          {'name': 'Feature Flags', 'url': '/admin/feature-flags', 'key': 'feature-flags'},
          {'name': 'Device Control Logs', 'url': '/admin/device-control', 'key': 'device-control'}
      ]) %}
  {% endif %}

  {% set menu_items = [
      {'name': 'Home', 'icon': 'bi-house-door', 'url': '/', 'key': 'home'},
      {'name': 'Dashboard', 'icon': 'bi-speedometer2', 'url': '/admin/dashboard', 'key': 'dashboard'},
      {'name': 'Analytics', 'icon': 'bi-bar-chart', 'url': '/admin/analytics', 'key': 'analytics'},
      {'name': 'Activity', 'icon': 'bi-activity', 'url': '/admin/log-activity', 'key': 'log-activity'},
      {'name': 'Mobiles', 'icon': 'bi-phone', 'url': '/admin/mobiles/all', 'key': 'mobiles', 'children': [
          {'name': 'All Mobiles', 'url': '/admin/mobiles/all', 'key': 'mobiles-list'},
          {'name': 'Add Mobile', 'url': '/admin/mobiles/insert', 'key': 'add-mobile'}
      ]},
      {'name': 'Posts', 'icon': 'bi-journal-text', 'url': '/admin/posts', 'key': 'posts', 'children': [
          {'name': 'All Posts', 'url': '/admin/posts', 'key': 'all-posts'},
          {'name': 'Add Post', 'url': '/admin/posts/create', 'key': 'add-post'}
      ]},
      {'name': 'AI Auto Content', 'icon': 'bi-robot', 'url': '/admin/autocontent', 'key': 'autocontent', 'children': [
          {'name': 'Dashboard', 'url': '/admin/autocontent', 'key': 'autocontent-dashboard'},
          {'name': 'Sources', 'url': '/admin/autocontent/sources', 'key': 'autocontent-sources'},
          {'name': 'Content Queue', 'url': '/admin/autocontent/queue', 'key': 'autocontent-queue'},
          {'name': 'Settings', 'url': '/admin/autocontent/settings', 'key': 'autocontent-settings'}
      ]},
      {'name': 'Services', 'icon': 'bi-award-fill', 'url': '/admin/services', 'key': 'services', 'children': [
          {'name': 'All Services', 'url': '/admin/services', 'key': 'all-services'},
          {'name': 'Create Service', 'url': '/admin/services/create', 'key': 'create-service'}
      ]},
      {'name': 'Service Applications', 'icon': 'bi-briefcase', 'url': '/admin/applications', 'key': 'applications', 'children': [
          {'name': 'All Applications', 'url': '/admin/applications', 'key': 'all-applications'},
          {'name': 'Pending', 'url': '/admin/applications?status=pending', 'key': 'pending-applications'},
          {'name': 'Approved', 'url': '/admin/applications?status=approved', 'key': 'approved-applications'},
          {'name': 'Rejected', 'url': '/admin/applications?status=rejected', 'key': 'rejected-applications'},
          {'name': 'Receipts', 'url': '/admin/applications/receipts', 'key': 'applications-receipts'}
      ]},
      {'name': 'Pages', 'icon': 'bi-file-earmark-text', 'url': '/admin/pages', 'key': 'pages'},
      {'name': 'Categories', 'icon': 'bi-tags', 'url': '/admin/categories', 'key': 'categories'},
      {'name': 'Tags', 'icon': 'bi-hash', 'url': '/admin/tags', 'key': 'tags'},
      {'name': 'Media Manager', 'icon': 'bi-image', 'url': '/admin/media', 'key': 'media'},
      {'name': 'Notifications', 'icon': 'bi-bell-fill', 'url': '/admin/notifications', 'key': 'notifications', 'children': [
          {'name': 'My Notifications', 'url': '/admin/my/notifications', 'key': 'my-notifications'},
          {'name': 'Dashboard', 'url': '/admin/notifications', 'key': 'notif-dashboard'},
          {'name': 'Send Notification', 'url': '/admin/notifications/send', 'key': 'send-notif'},
          {'name': 'All Notifications', 'url': '/admin/notifications/list', 'key': 'all-notif'},
          {'name': 'Subscribers', 'url': '/admin/notification-subscribers', 'key': 'notif-subscribers'},
          {'name': 'Templates', 'url': '/admin/notification-templates', 'key': 'notification-templates'}
      ]},
      {'name': 'Comments', 'icon': 'bi-chat-left-text', 'url': '/admin/comments', 'key': 'comments'},
      {'name': 'SMS Logs', 'icon': 'bi-chat-square-text', 'url': '/admin/sms-logs', 'key': 'sms-logs'},

      {'name': 'Users', 'icon': 'bi-people', 'url': '/admin/users', 'key': 'users'},
      {'name': 'Roles', 'icon': 'bi-diagram-3', 'url': '/admin/roles', 'key': 'roles'},
      {'name': 'Permissions', 'icon': 'bi-shield-lock', 'url': '/admin/permissions', 'key': 'permissions'},
      {'name': 'Contact Messages', 'icon': 'bi-envelope', 'url': '/admin/contact', 'key': 'contact', 'children': [
          {'name': 'All Messages', 'url': '/admin/contact', 'key': 'all-messages'}
      ]},
      {'name': 'Email Templates', 'icon': 'bi-file-earmark-text', 'url': '/admin/email-templates', 'key': 'email-templates'},
      {'name': 'Settings', 'icon': 'bi-gear', 'url': '/admin/account-settings', 'key': 'settings', 'children': settings_children}
  ] %}

  {% macro render_menu(menu_items, current_page, prefix) %}
    <div class="list-group list-group-flush rounded-0">
      {% for item in menu_items %}
        {% if item.children is defined %}
          {% set is_child_active = false %}
          {% for child in item.children %}
            {% if current_page == child.key %}
              {% set is_child_active = true %}
            {% endif %}
          {% endfor %}

          <a class="list-group-item list-group-item-action d-flex align-items-center {{ is_child_active ? 'active' }}"
            data-bs-toggle="collapse"
            href="#{{ prefix }}-submenu-{{ item.key }}"
            role="button"
            aria-expanded="{{ is_child_active ? 'true' : 'false' }}"
            aria-controls="{{ prefix }}-submenu-{{ item.key }}"
            title="{{ item.name }}">
            <i class="bi {{ item.icon }} me-2"></i>
            <span class="sidebar-label">{{ item.name }}</span>
            <i class="bi bi-chevron-down ms-auto"></i>
          </a>
          <div class="collapse {{ is_child_active ? 'show' }}" id="{{ prefix }}-submenu-{{ item.key }}">
            <div class="list-group list-group-flush ms-3">
              {% for child in item.children %}
                <a href="{{ child.url }}"
                  class="list-group-item list-group-item-action {{ current_page == child.key ? 'active' }}"
                  aria-current="{{ current_page == child.key ? 'page' }}"
                  title="{{ child.name }}">
                  <span class="sidebar-label">{{ child.name }}</span>
                </a>
              {% endfor %}
            </div>
          </div>
        {% else %}
          <a href="{{ item.url }}"
            class="list-group-item list-group-item-action d-flex align-items-center {{ current_page == item.key ? 'active' }}"
            aria-current="{{ current_page == item.key ? 'page' }}"
            title="{{ item.name }}">
            <i class="bi {{ item.icon }} me-2"></i>
            <span class="sidebar-label">{{ item.name }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  {% endmacro %}

  {% import _self as menus %}

  {# Unified Responsive Sidebar #}
  <div class="sidebar col-lg-3 col-xl-2 bg-white shadow-sm">
    <div class="sidebar-header d-lg-none p-3 border-bottom d-flex justify-content-between align-items-center">
      <h5 class="m-0 fw-bold">Menu</h5>
      <button type="button" class="modern-btn-close sidebar-close"></button>
    </div>
    <div class="p-3">
      <div class="d-none d-lg-flex align-items-center justify-content-end mb-2">
        <button
          type="button"
          class="sidebar-mini-toggle btn btn-sm btn-outline-secondary"
          aria-label="Toggle compact sidebar"
          title="Toggle compact sidebar"
          aria-pressed="false"
          aria-expanded="false">
          <i class="bi bi-layout-sidebar-inset-reverse"></i>
        </button>
      </div>
      {{ menus.render_menu(menu_items, current_page, 'main') }}
    </div>
  </div>

      <!-- Main content -->
      <main class="col-12 col-lg-9 col-xl-10 py-4 admin-main">
        {% if skip_auto_breadcrumb is not defined or skip_auto_breadcrumb == false %}
            {% if breadcrumbs is not defined %}
                {% set breadcrumbs = auto_admin_breadcrumbs() %}
            {% endif %}
            {% include 'admin/partials/breadcrumb.twig' %}
        {% endif %}

        {% set flash_data = flash_message|default(flash|default(null)) %}
        {{ flash_macros.render_flash(flash_data) }}
        {% include 'admin/partials/_offline_draft_recover.twig' %}
        
        {% block content %}
        {% endblock %}
      </main>

    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-3 mt-auto">
    &copy; {{ "now"|date("Y") }} Admin Panel. All rights reserved.
  </footer>

  {# Footer scripts #}
  <script src="{{ asset('/assets/js/dist/app-config.js') }}" defer></script>
  <script src="{{ asset('/assets/firebase/v2/dist/firebase-config.js') }}" defer></script>

  <script src="{{ asset('/assets/js/dist/bootstrap-lite.js') }}" defer></script>

  {# SweetAlert2 + global flash handler #}
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.0/dist/sweetalert2.all.min.js"></script>
  <script src="{{ asset('/assets/js/dist/sweetalert2-handler.js') }}" defer></script>

  {# Feature scripts #}
  <script src="{{ asset('/assets/js/dist/datepicker.js') }}" defer></script>

  <script type="module" src="{{ asset('/assets/js/dist/theme-manager.js') }}" defer></script>

  {# Admin scripts #}
  <script src="{{ asset('/assets/js/dist/admin.js') }}" defer></script>
  <script src="{{ asset('/assets/js/dist/activity.js') }}" defer></script>

  {% block scripts %}{% endblock %}

  {# Admin Assistant UI #}
  {% include 'partials/ai-assistant/admin.twig' %}
</body>
</html>
