{% extends 'admin/layout.twig' %}
{% block title %}Device Sync Manager{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4" id="deviceSyncRoot">
    <div class="admin-page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <div class="admin-page-title">
          <i class="bi bi-phone-landscape"></i> Multi-Device Sync Manager
        </div>
        <p class="admin-page-subtitle">Monitor and control sync state across registered devices.</p>
      </div>
      <div class="d-flex gap-2">
        <button class="modern-btn modern-btn-primary btn-sm" onclick="manualSync()">
          <i class="bi bi-arrow-repeat me-1"></i>Manual Sync
        </button>
        <button class="modern-btn modern-btn-outline-secondary btn-sm"
                onclick="refreshDeviceList()">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
      </div>
    </div>
    <div class="row mb-4">
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card">
          <div class="admin-panel-card-body">
            <small class="text-muted">Active Devices</small>
            <h4 class="mb-0" id="activeDevicesCount">0</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card">
          <div class="admin-panel-card-body">
            <small class="text-muted">Pending Sync</small>
            <h4 class="mb-0" id="pendingSyncCount">0</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card">
          <div class="admin-panel-card-body">
            <small class="text-muted">Synced Items</small>
            <h4 class="mb-0" id="syncedItemsCount">0</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card">
          <div class="admin-panel-card-body">
            <small class="text-muted">Sync Rate</small>
            <h4 class="mb-0" id="syncRatePercent">0%</h4>
          </div>
        </div>
      </div>
    </div>
    <div class="row mb-4">
      <div class="col-12">
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="autoSyncToggle">
          <label class="form-check-label" for="autoSyncToggle">Auto sync every 30 seconds</label>
        </div>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-lg-7">
        <div class="admin-panel-card h-100">
          <div class="admin-panel-card-body">
            <h6 class="mb-3">Registered Devices</h6>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Device</th>
                    <th>ID</th>
                    <th>Type</th>
                    <th>Last Active</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="devicesTableBody">
                  <tr>
                    <td colspan="5" class="text-center text-muted py-4">Loading...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="admin-panel-card h-100">
          <div class="admin-panel-card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="mb-0">Sync Logs</h6>
              <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" onclick="filterSyncLog('all')">All</button>
                <button class="btn btn-outline-secondary" onclick="filterSyncLog('sync')">Sync</button>
                <button class="btn btn-outline-secondary" onclick="filterSyncLog('read')">Read</button>
                <button class="btn btn-outline-secondary" onclick="clearSyncLog()">Clear</button>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th>Time</th>
                    <th>Action</th>
                    <th>Notification</th>
                    <th>Device</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="syncLogBody">
                  <tr>
                    <td colspan="5" class="text-center text-muted py-4">Loading...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
