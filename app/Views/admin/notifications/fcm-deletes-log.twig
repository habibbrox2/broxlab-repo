{% extends "admin/layout.twig" %}
{% block title %}FCM Delete Audit Log{% endblock %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="admin-page-header mb-4 d-flex justify-content-between align-items-center">
      <div>
        <div class="admin-page-title">
          <i class="bi bi-file-earmark-text"></i> FCM Delete Audit
        </div>
        <p class="admin-page-subtitle">Recent permanent delete operations for FCM device tokens (most recent first)</p>
      </div>
      <div class="text-end">
        <a href="/admin/notification-fcm-deletes/download"
           class="modern-btn modern-btn-outline-primary btn-sm">Download Raw Log</a>
        <a href="/admin/notification-subscribers" class="modern-btn btn-sm">Back to Subscribers</a>
      </div>
    </div>
    <div class="admin-panel-card">
      <div class="admin-panel-card-body">
        {% if entries is empty %}
          <div class="text-center text-muted py-5">No audit entries found.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-sm table-hover">
              <thead class="table-light">
                <tr>
                  <th>Timestamp</th>
                  <th>Admin ID</th>
                  <th>Device ID</th>
                  <th>IP</th>
                  <th>Raw</th>
                </tr>
              </thead>
              <tbody>
                {% for e in entries %}
                  <tr>
                    <td>{{ e.ts ?: '-' }}</td>
                    <td>{{ e.admin_id ?: '-' }}</td>
                    <td>
                      <code>{{ e.device_id ?: (e.raw ?: '-') }}</code>
                    </td>
                    <td>{{ e.ip ?: '-' }}</td>
                    <td>
                      <small>{{ (e.raw ?: (e|json_encode))|slice(0, 160) }}{{ (e.raw ?: (e|json_encode))|length > 160 ? '...' : '' }}</small>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
