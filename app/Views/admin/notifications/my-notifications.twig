{% extends 'admin/layout.twig' %}
{% block title %}My Notifications{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-bell me-2"></i>
        My Notifications
      </div>
      <div class="admin-page-subtitle">Personal and account-targeted notifications for this admin account.</div>
    </div>
    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-3">
      <a href="/admin/notifications"
         class="modern-btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
      </a>
      <div class="d-flex align-items-center gap-2">
        <span class="badge rounded-pill bg-primary-subtle text-primary">Unread: {{ unread_count|default(0) }}</span>
        {% if unread_count|default(0) > 0 %}
          <button type="button"
                  id="markAllReadBtn"
                  class="modern-btn modern-btn-primary btn-sm">
            <i class="bi bi-check2-all me-1"></i>Mark All Read
          </button>
        {% endif %}
      </div>
    </div>
    <div class="admin-panel-card">
      <div class="admin-panel-card-body p-0">
        {% if notifications is not empty %}
          <div class="list-group list-group-flush">
            {% for notif in notifications %}
              <div class="list-group-item py-3 {% if notif.is_read == 0 %}bg-light{% endif %}"
                   data-notification-id="{{ notif.id }}">
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div class="flex-grow-1">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                      <strong>{{ notif.title|default("Notification") }}</strong>
                      {% if notif.is_read == 0 %}<span class="badge bg-primary">New</span>{% endif %}
                      {% if notif.type is defined and notif.type %}
                        <span class="badge bg-secondary text-uppercase">{{ notif.type }}</span>
                      {% endif %}
                    </div>
                    <div class="text-muted mb-2">{{ notif.message|default("") }}</div>
                    <div class="d-flex flex-wrap gap-2">
                      {% if notif.action_url is defined and notif.action_url %}
                        <a class="modern-btn btn-sm btn-outline-primary"
                           href="{{ notif.action_url }}">
                          <i class="bi bi-arrow-right me-1"></i>Open
                        </a>
                      {% endif %}
                      {% if notif.is_read == 0 %}
                        <button type="button"
                                class="modern-btn btn-sm btn-outline-secondary js-mark-read"
                                data-id="{{ notif.id }}">
                          <i class="bi bi-check-lg me-1"></i>Mark Read
                        </button>
                      {% endif %}
                    </div>
                  </div>
                  <small class="text-muted text-nowrap">{{ notif.created_at|date("d M Y H:i") }}</small>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="p-5 text-center text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            No notifications found.
          </div>
        {% endif %}
      </div>
    </div>
    {% if total_pages|default(1) > 1 %}
      <nav class="mt-3" aria-label="Notification pagination">
        <ul class="pagination mb-0">
          <li class="page-item {% if page|default(1) <= 1 %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ (page|default(1) - 1) > 0 ? (page|default(1) - 1) : 1 }}">Previous</a>
          </li>
          <li class="page-item disabled">
            <span class="page-link">Page {{ page|default(1) }} of {{ total_pages }}</span>
          </li>
          <li class="page-item {% if page|default(1) >= total_pages %}disabled{% endif %}">
            <a class="page-link"
               href="?page={{ (page|default(1) + 1) <= total_pages ? (page|default(1) + 1) : total_pages }}">Next</a>
          </li>
        </ul>
      </nav>
    {% endif %}
  </div>
{% endblock %}
{% block scripts %}
  <script>
  (function () {
    async function postJson(url, payload) {
      const csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrf
        },
        body: JSON.stringify(payload || {})
      });
      return response.json().catch(() => ({ success: false }));
    }

    document.querySelectorAll('.js-mark-read').forEach((button) => {
      button.addEventListener('click', async () => {
        const id = Number(button.dataset.id || 0);
        if (!id) return;

        const data = await postJson('/api/notification/mark-read', { notification_id: id });
        if (data && data.success) {
          window.location.reload();
        }
      });
    });

    const markAllBtn = document.getElementById('markAllReadBtn');
    if (!markAllBtn) return;
    markAllBtn.addEventListener('click', async () => {
      const data = await postJson('/api/notification/mark-all-read', {});
      if (data && data.success) {
        window.location.reload();
      }
    });
  })();
  </script>
{% endblock %}
