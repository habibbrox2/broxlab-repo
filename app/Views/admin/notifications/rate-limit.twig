{% extends "admin/layout.twig" %}
{% block title %}Notification Rate Limit{% endblock %}
{% block content %}
  <div class="container py-4">
    <div class="admin-panel-card">
      <div class="admin-panel-card-header">
        <h5 class="mb-0">Per-Admin Rate Limit</h5>
      </div>
      <div class="admin-panel-card-body">
        <div id="currentLimits" class="mb-3 text-muted">Loading...</div>
        <form id="rateLimitForm">
          <div class="mb-3">
            <label for="hourly" class="form-label">Hourly limit</label>
            <input type="number" class="form-control" id="hourly" name="hourly" min="0" />
          </div>
          <div class="mb-3">
            <label for="daily" class="form-label">Daily limit</label>
            <input type="number" class="form-control" id="daily" name="daily" min="0" />
          </div>
          <div class="d-flex gap-2">
            <button type="button" id="saveBtn" class="btn btn-primary">Save</button>
          </div>
          <div id="rlResult" class="mt-3"></div>
        </form>
      </div>
    </div>
  </div>
  <div id="toast-container" aria-live="polite" class="inl-a-0038"></div>
{% endblock %}
