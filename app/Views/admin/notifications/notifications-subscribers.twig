{% extends "admin/layout.twig" %}
{% block title %}Notification Subscribers{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4" id="notificationSubscribersRoot">
    <div class="admin-page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div>
        <div class="admin-page-title">
          <i class="bi bi-people"></i> Subscribers
        </div>
        <p class="admin-page-subtitle">নোটিফিকেশন অনুমতি দেওয়া ইউজার ও গেস্ট ডিভাইস তালিকা</p>
      </div>
      <div class="d-flex gap-2">
        <a href="/admin/notification-fcm-deletes"
           class="modern-btn modern-btn-outline-secondary btn-sm">Delete Audit</a>
        <button type="button"
                id="revokeAllBtn"
                class="modern-btn modern-btn-warning btn-sm">
          <i class="bi bi-slash-circle me-1"></i> Revoke All (Filtered)
        </button>
        <button type="button"
                id="deleteAllBtn"
                class="modern-btn modern-btn-danger btn-sm">
          <i class="bi bi-trash me-1"></i> Delete All (Filtered)
        </button>
      </div>
    </div>
    <div class="row mb-3">
      <div class="col-lg-8">
        <form id="subsFilterForm" class="row g-2 align-items-center">
          <div class="col-md-3">
            <select id="recipientFilter"
                    name="recipient"
                    class="form-select form-select-sm">
              <option value="all" {{ filters.recipient == 'all' ? 'selected' : '' }}>All
              </option>
              <option value="user" {{ filters.recipient == 'user' ? 'selected' : '' }}>Logged-in Users
              </option>
              <option value="guest" {{ filters.recipient == 'guest' ? 'selected' : '' }}>Guests
              </option>
            </select>
          </div>
          <div class="col-md-3">
            <select id="permissionFilter"
                    name="permission"
                    class="form-select form-select-sm">
              <option value="all" {{ filters.permission == 'all' ? 'selected' : '' }}>Any permission
              </option>
              <option value="granted"
                      {{ filters.permission == 'granted' ? 'selected' : '' }}>Granted
              </option>
              <option value="denied" {{ filters.permission == 'denied' ? 'selected' : '' }}>Denied
              </option>
              <option value="default"
                      {{ filters.permission == 'default' ? 'selected' : '' }}>Default
              </option>
            </select>
          </div>
          <div class="col-md-5">
            <input type="text"
                   id="searchInput"
                   name="search"
                   class="form-control form-control-sm"
                   placeholder="Search by token, device ID, username, email"
                   value="{{ filters.search }}">
          </div>
          <div class="col-md-2">
            <select id="perPage" name="per_page" class="form-select form-select-sm">
              <option value="10" {{ pagination.per_page == 10 ? 'selected' : '' }}>10
              </option>
              <option value="20" {{ pagination.per_page == 20 ? 'selected' : '' }}>20
              </option>
              <option value="50" {{ pagination.per_page == 50 ? 'selected' : '' }}>50
              </option>
              <option value="100" {{ pagination.per_page == 100 ? 'selected' : '' }}>100
              </option>
            </select>
          </div>
          <div class="col-md-2 d-grid">
            <button type="button"
                    class="modern-btn modern-btn-primary btn-sm"
                    onclick="applySubsFilter()">Filter</button>
          </div>
        </form>
      </div>
      <div class="col-lg-4 text-lg-end mt-2 mt-lg-0">
        <small class="text-muted">Total Active Subscribers: <span id="subsTotalCount">{{ pagination.total }}</span></small>
      </div>
    </div>
    <div class="row">
      <div class="col-12">
        <div class="admin-panel-card">
          <div class="admin-panel-card-body">
            <div class="table-responsive">
              <table class="table table-hover table-sm align-middle">
                <thead class="table-light">
                  <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Device ID</th>
                    <th>Device Name</th>
                    <th>Token</th>
                    <th>Permission</th>
                    <th>Type</th>
                    <th>Created</th>
                    <th class="text-end">Action</th>
                  </tr>
                </thead>
                <tbody id="subscribersTableBody">
                  {% if subscribers is empty %}
                    <tr>
                      <td colspan="9" class="text-center text-muted py-4">No subscribers found</td>
                    </tr>
                  {% else %}
                    {% for s in subscribers %}
                      <tr>
                        <td>{{ s.id }}</td>
                        <td>
                          {% if s.user_id %}
                            <strong>{{ s.username ?: s.email ?: ('UID:' ~ s.user_id) }}</strong>
                          {% else %}
                            <span class="text-muted">Guest</span>
                          {% endif %}
                        </td>
                        <td>
                          <small>{{ s.device_id ?: '-' }}</small>
                        </td>
                        <td>
                          <small>{{ s.device_name ?: '-' }}</small>
                        </td>
                        <td>
                          <small>{{ s.token[:40] }}{{ s.token|length > 40 ? '...' : '' }}</small>
                        </td>
                        <td>
                          {% set perm = s.permission ?: 'granted' %}
                          {% set badge = perm == 'granted' ? 'bg-success' : (perm == 'default' ? 'bg-secondary' : 'bg-danger') %}
                          <span class="badge {{ badge }}">{{ perm }}</span>
                        </td>
                        <td>{{ s.device_type ?: '-' }}</td>
                        <td>
                          <small>{{ s.created_at ?: '-' }}</small>
                        </td>
                        <td class="text-end">
                          <div class="d-inline-flex gap-2">
                            <button class="modern-btn modern-btn-danger btn-sm"
                                    onclick="revokeDevice('{{ s.device_id }}', this)">Revoke</button>
                            <button class="modern-btn modern-btn-outline-danger btn-sm"
                                    onclick="deleteDevicePermanent('{{ s.device_id }}', this)">Delete</button>
                          </div>
                        </td>
                      </tr>
                    {% endfor %}
                  {% endif %}
                </tbody>
              </table>
            </div>
            {% if pagination.total_pages > 1 %}
              <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                  {% if pagination.current_page > 1 %}
                    <li class="page-item">
                      <a class="page-link"
                         href="?page=1&recipient={{ filters.recipient }}&permission={{ filters.permission }}&search={{ filters.search|url_encode }}&per_page={{ pagination.per_page }}">First</a>
                    </li>
                    <li class="page-item">
                      <a class="page-link"
                         href="?page={{ pagination.current_page - 1 }}&recipient={{ filters.recipient }}&permission={{ filters.permission }}&search={{ filters.search|url_encode }}&per_page={{ pagination.per_page }}">Prev</a>
                    </li>
                  {% endif %}
                  {% for i in 1..pagination.total_pages %}
                    {% if i == pagination.current_page %}
                      <li class="page-item active">
                        <span class="page-link">{{ i }}</span>
                      </li>
                    {% else %}
                      <li class="page-item">
                        <a class="page-link"
                           href="?page={{ i }}&recipient={{ filters.recipient }}&permission={{ filters.permission }}&search={{ filters.search|url_encode }}&per_page={{ pagination.per_page }}">{{ i }}</a>
                      </li>
                    {% endif %}
                  {% endfor %}
                  {% if pagination.current_page < pagination.total_pages %}
                    <li class="page-item">
                      <a class="page-link"
                         href="?page={{ pagination.current_page + 1 }}&recipient={{ filters.recipient }}&permission={{ filters.permission }}&search={{ filters.search|url_encode }}&per_page={{ pagination.per_page }}">Next</a>
                    </li>
                    <li class="page-item">
                      <a class="page-link"
                         href="?page={{ pagination.total_pages }}&recipient={{ filters.recipient }}&permission={{ filters.permission }}&search={{ filters.search|url_encode }}&per_page={{ pagination.per_page }}">Last</a>
                    </li>
                  {% endif %}
                </ul>
              </nav>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
