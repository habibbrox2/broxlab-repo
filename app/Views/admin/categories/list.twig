{% extends "admin/layout.twig" %}
{% block title %}Admin - Categories{% endblock %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-folder"></i>
        Manage Categories
      </div>
      <div class="admin-page-subtitle">Organize your content with categories</div>
    </div>
    <!-- Main Card -->
    <div class="admin-panel-card">
      <div class="admin-panel-card-header">
        <h6 class="admin-panel-card-title">
          <i class="bi bi-list-check me-2"></i> All Categories
        </h6>
        <a href="/admin/categories/create"
           class="modern-btn modern-btn-primary btn-sm">
          <i class="bi bi-plus-circle me-1"></i> Add New Category
        </a>
      </div>
      <!-- Search & Filter Form -->
      <div class="admin-panel-card-header-secondary border-bottom px-4 py-3">
        <form method="get" class="row g-2 align-items-end">
          <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Search</label>
            <div class="input-group input-group-sm">
              <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
              <input type="text"
                     name="search"
                     value="{{ pagination.search|default("") }}"
                     class="form-control form-control-sm"
                     placeholder="Search by name...">
            </div>
          </div>
          <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Sort By</label>
            <select name="sort" class="form-select form-select-sm">
              <option value="name" {% if pagination.sort == 'name' %}selected{% endif %}>Name</option>
              <option value="id" {% if pagination.sort == 'id' %}selected{% endif %}>ID</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Order</label>
            <select name="order" class="form-select form-select-sm">
              <option value="ASC" {% if pagination.order == 'ASC' %}selected{% endif %}>A-Z</option>
              <option value="DESC" {% if pagination.order == 'DESC' %}selected{% endif %}>Z-A</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small text-muted mb-1">Limit</label>
            <select name="limit" class="form-select form-select-sm">
              <option value="10" {% if pagination.limit == 10 %}selected{% endif %}>10 items</option>
              <option value="20" {% if pagination.limit == 20 %}selected{% endif %}>20 items</option>
              <option value="50" {% if pagination.limit == 50 %}selected{% endif %}>50 items</option>
              <option value="100" {% if pagination.limit == 100 %}selected{% endif %}>100 items</option>
            </select>
          </div>
          <div class="col-md-3 text-end">
            <button type="submit" class="modern-btn modern-btn-primary btn-sm">
              <i class="bi bi-funnel me-1"></i> Apply
            </button>
          </div>
        </form>
      </div>
      <div class="admin-panel-card-body">
        {% if categories is not empty %}
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light border-top border-bottom">
                <tr>
                  <th class="fw-bold text-muted">
                    <i class="bi bi-hash me-1"></i> ID
                  </th>
                  <th class="fw-bold text-muted">
                    <i class="bi bi-folder me-1"></i> Name
                  </th>
                  <th class="fw-bold text-muted">
                    <i class="bi bi-link me-1"></i> URL Slug
                  </th>
                  <th class="fw-bold text-muted text-center">
                    <i class="bi bi-gear me-1"></i> Actions
                  </th>
                </tr>
              </thead>
              <tbody>
                {% for category in categories %}
                  <tr class="border-bottom hover-effect">
                    <td>
                      <span class="badge bg-light text-surface-dark fw-bold">{{ category.id }}</span>
                    </td>
                    <td>
                      <div class="d-flex align-items-center">
                        <i class="bi bi-folder text-primary me-2"></i>
                        <strong>{{ category.name }}</strong>
                      </div>
                    </td>
                    <td>
                      <code class="bg-light px-3 py-2 rounded-2 d-inline-block">{{ category.slug }}</code>
                    </td>
                    <td class="text-center">
                      <div class="modern-btn-group" role="group">
                        <a href="/admin/categories/edit/{{ category.id }}"
                           class="modern-btn btn-sm btn-warning rounded-start-3"
                           title="Edit Category">
                          <i class="bi bi-pencil-fill me-1"></i> Edit
                        </a>
                        <a href="/admin/categories/delete/{{ category.id }}"
                           class="modern-btn btn-sm btn-danger rounded-end-3"
                           title="Delete Category"
                           onclick="return confirm('Are you sure you want to delete this category? This action cannot be undone.')">
                          <i class="bi bi-trash me-1"></i> Delete
                        </a>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="4" class="text-center text-muted py-4">
                      <i class="bi bi-inbox text-muted"></i> No categories found.
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          <!-- Pagination -->
          {% include "admin/partials/pagination.twig" %}
        {% else %}
          <div class="text-center py-5">
            <i class="bi bi-inbox text-muted inl-a-0012"></i>
            <p class="text-muted mt-3 mb-0">
              <strong>No categories found.</strong> Start by creating your first category!
            </p>
            <a href="/admin/categories/create"
               class="modern-btn modern-btn-primary btn-sm mt-3">
              <i class="bi bi-plus me-1"></i> Create First Category
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
