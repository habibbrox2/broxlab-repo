{% extends "admin/layout.twig" %}

{% block content %}
<div class="container-fluid py-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Category Details</h1>
    <div class="d-flex gap-2">
      <a href="/admin/categories/edit/{{ category.id }}" class="btn btn-primary btn-sm">Edit</a>
      <a href="/admin/categories" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="text-muted small">Name</div>
          <div class="fw-semibold">{{ category.name|default('N/A') }}</div>
        </div>
        <div class="col-md-6">
          <div class="text-muted small">Slug</div>
          <div class="fw-semibold">{{ category.slug|default('N/A') }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}