// ==================== LIVE PREVIEW FUNCTIONS ====================
let currentPreviewPreset = null;

function previewPreset(id) {
    console.log('previewPreset called with id:', id);
    var presetId = parseInt(id);
    var preset = null;
    for (var i = 0; i < presets.length; i++) {
        if (presets[i].id == presetId) {
            preset = presets[i];
            break;
        }
    }
    if (!preset) {
        console.error('Preset not found for id:', id);
        return;
    }
    console.log('Found preset for preview:', preset.name);
    
    currentPreviewPreset = preset;
    document.getElementById('preview_url').value = '';
    document.getElementById('preview_type').value = 'list';
    document.getElementById('previewResults').classList.add('d-none');
    document.getElementById('previewError').classList.add('d-none');
    
    new bootstrap.Modal(document.getElementById('previewModal')).show();
}

async function runPreview() {
    const urlInput = document.getElementById('preview_url');
    const url = urlInput.value.trim();
    const previewType = document.getElementById('preview_type').value;
    
    if (!url || !urlInput.checkValidity()) {
        urlInput.classList.add('is-invalid');
        return;
    }
    urlInput.classList.remove('is-invalid');
    
    if (!currentPreviewPreset) {
        await showPresetAlert('No preset selected', 'Preview Error', 'danger');
        return;
    }
    
    // Show loading
    document.getElementById('previewLoading').classList.remove('d-none');
    document.getElementById('previewResults').classList.add('d-none');
    document.getElementById('previewError').classList.add('d-none');
    document.getElementById('btn-preview').disabled = true;
    
    const selectors = previewType === 'list' ? {
        container: currentPreviewPreset.selector_list_container,
        item: currentPreviewPreset.selector_list_item,
        title: currentPreviewPreset.selector_list_title,
        link: currentPreviewPreset.selector_list_link,
        date: currentPreviewPreset.selector_list_date,
        image: currentPreviewPreset.selector_list_image
    } : {
        title: currentPreviewPreset.selector_title,
        content: currentPreviewPreset.selector_content,
        image: currentPreviewPreset.selector_image,
        excerpt: currentPreviewPreset.selector_excerpt,
        date: currentPreviewPreset.selector_date,
        author: currentPreviewPreset.selector_author
    };
    
    try {
        const formData = new FormData();
        formData.append('url', url);
        formData.append('type', previewType);
        formData.append('selectors', JSON.stringify(selectors));
        
        const response = await fetch('/admin/autocontent/api/preview-selectors', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        document.getElementById('previewLoading').classList.add('d-none');
        document.getElementById('btn-preview').disabled = false;
        
        if (data.success) {
            displayPreviewResults(data, previewType);
        } else {
            document.getElementById('previewError').textContent = data.message || 'Failed to fetch preview';
            document.getElementById('previewError').classList.remove('d-none');
        }
    } catch (error) {
        console.error(error);
        document.getElementById('previewLoading').classList.add('d-none');
        document.getElementById('btn-preview').disabled = false;
        document.getElementById('previewError').textContent = 'Error fetching preview: ' + error.message;
        document.getElementById('previewError').classList.remove('d-none');
    }
}

function displayPreviewResults(data, previewType) {
    var extractedDataDiv = document.getElementById('extractedData');
    var selectorMatchesDiv = document.getElementById('selectorMatches');
    var rawHtmlDiv = document.getElementById('rawHtmlPreview');
    
    // Display extracted data
    var extractedHtml = '';
    if (previewType === 'list') {
        if (data.items && data.items.length > 0) {
            extractedHtml = '<ul class="list-group list-group-flush">';
            data.items.slice(0, 5).forEach(function(item, index) {
                var titleHtml = item.title ? '<strong>Title:</strong> ' + escapeHtml(item.title.substring(0, 100)) + '<br>' : '';
                var linkHtml = item.link ? '<strong>Link:</strong> <code>' + escapeHtml(item.link.substring(0, 50)) + '</code><br>' : '';
                var dateHtml = item.date ? '<strong>Date:</strong> ' + escapeHtml(item.date) + '<br>' : '';
                var imageHtml = item.image ? '<strong>Image:</strong> <code>' + escapeHtml(item.image.substring(0, 50)) + '</code>' : '';
                extractedHtml += '<li class="list-group-item px-0">' +
                    '<strong>#' + (index + 1) + '</strong><br>' +
                    titleHtml + linkHtml + dateHtml + imageHtml +
                    '</li>';
            });
            extractedHtml += '</ul>';
            extractedHtml += '<div class="text-muted small mt-2">Found ' + data.items.length + ' items total</div>';
        } else {
            extractedHtml = '<p class="text-muted">No items found with the specified selectors</p>';
        }
    } else {
        if (data.content) {
            extractedHtml = data.content.title ? '<p><strong>Title:</strong> ' + escapeHtml(data.content.title) + '</p>' : '';
            extractedHtml += data.content.excerpt ? '<p><strong>Excerpt:</strong> ' + escapeHtml(data.content.excerpt.substring(0, 200)) + '...</p>' : '';
            extractedHtml += data.content.author ? '<p><strong>Author:</strong> ' + escapeHtml(data.content.author) + '</p>' : '';
            extractedHtml += data.content.date ? '<p><strong>Date:</strong> ' + escapeHtml(data.content.date) + '</p>' : '';
            extractedHtml += data.content.image ? '<p><strong>Image:</strong> <code>' + escapeHtml(data.content.image.substring(0, 100)) + '</code></p>' : '';
            extractedHtml += '<hr><strong>Content Preview:</strong><div class="mt-2 small">' + (data.content.content ? escapeHtml(data.content.content.substring(0, 500)) : 'No content found') + '...</div>';
        } else {
            extractedHtml = '<p class="text-muted">No content found with the specified selectors</p>';
        }
    }
    extractedDataDiv.innerHTML = extractedHtml;
    
    // Display selector match info
    var matchesHtml = '';
    var i, matchStatus;
    if (previewType === 'list') {
        var containerSel = data.selectors.container || 'N/A';
        var itemSel = data.selectors.item || 'N/A';
        var titleSel = data.selectors.title || 'N/A';
        var linkSel = data.selectors.link || 'N/A';
        var dateSel = data.selectors.date || 'N/A';
        var imageSel = data.selectors.image || 'N/A';
        
        var containerStatus = data.matches.container ? 'success' : 'danger';
        var containerText = data.matches.container ? 'Found' : 'Not Found';
        var itemStatus = data.matches.item ? 'success' : 'danger';
        var itemText = data.matches.item ? 'Found' : 'Not Found';
        var titleStatus = data.matches.title ? 'success' : 'danger';
        var titleText = data.matches.title ? 'Found' : 'Not Found';
        var linkStatus = data.matches.link ? 'success' : 'danger';
        var linkText = data.matches.link ? 'Found' : 'Not Found';
        var dateStatus = data.matches.date ? 'success' : 'warning';
        var dateText = data.matches.date ? 'Found' : 'Optional';
        var imageStatus = data.matches.image ? 'success' : 'warning';
        var imageText = data.matches.image ? 'Found' : 'Optional';
        
        matchesHtml = '<ul class="list-unstyled small">' +
            '<li class="mb-2"><strong>Container:</strong> <code>' + escapeHtml(containerSel) + '</code>' +
            ' <span class="badge bg-' + containerStatus + '">' + containerText + '</span></li>' +
            '<li class="mb-2"><strong>Item:</strong> <code>' + escapeHtml(itemSel) + '</code>' +
            ' <span class="badge bg-' + itemStatus + '">' + itemText + '</span></li>' +
            '<li class="mb-2"><strong>Title:</strong> <code>' + escapeHtml(titleSel) + '</code>' +
            ' <span class="badge bg-' + titleStatus + '">' + titleText + '</span></li>' +
            '<li class="mb-2"><strong>Link:</strong> <code>' + escapeHtml(linkSel) + '</code>' +
            ' <span class="badge bg-' + linkStatus + '">' + linkText + '</span></li>' +
            '<li class="mb-2"><strong>Date:</strong> <code>' + escapeHtml(dateSel) + '</code>' +
            ' <span class="badge bg-' + dateStatus + '">' + dateText + '</span></li>' +
            '<li><strong>Image:</strong> <code>' + escapeHtml(imageSel) + '</code>' +
            ' <span class="badge bg-' + imageStatus + '">' + imageText + '</span></li>' +
            '</ul>';
    } else {
        var titleSelD = data.selectors.title || 'N/A';
        var contentSelD = data.selectors.content || 'N/A';
        var imageSelD = data.selectors.image || 'N/A';
        var excerptSelD = data.selectors.excerpt || 'N/A';
        var dateSelD = data.selectors.date || 'N/A';
        var authorSelD = data.selectors.author || 'N/A';
        
        var titleStatusD = data.matches.title ? 'success' : 'danger';
        var titleTextD = data.matches.title ? 'Found' : 'Not Found';
        var contentStatusD = data.matches.content ? 'success' : 'danger';
        var contentTextD = data.matches.content ? 'Found' : 'Not Found';
        var imageStatusD = data.matches.image ? 'success' : 'warning';
        var imageTextD = data.matches.image ? 'Found' : 'Optional';
        var excerptStatusD = data.matches.excerpt ? 'success' : 'warning';
        var excerptTextD = data.matches.excerpt ? 'Found' : 'Optional';
        var dateStatusD = data.matches.date ? 'success' : 'warning';
        var dateTextD = data.matches.date ? 'Found' : 'Optional';
        var authorStatusD = data.matches.author ? 'success' : 'warning';
        var authorTextD = data.matches.author ? 'Found' : 'Optional';
        
        matchesHtml = '<ul class="list-unstyled small">' +
            '<li class="mb-2"><strong>Title:</strong> <code>' + escapeHtml(titleSelD) + '</code>' +
            ' <span class="badge bg-' + titleStatusD + '">' + titleTextD + '</span></li>' +
            '<li class="mb-2"><strong>Content:</strong> <code>' + escapeHtml(contentSelD) + '</code>' +
            ' <span class="badge bg-' + contentStatusD + '">' + contentTextD + '</span></li>' +
            '<li class="mb-2"><strong>Image:</strong> <code>' + escapeHtml(imageSelD) + '</code>' +
            ' <span class="badge bg-' + imageStatusD + '">' + imageTextD + '</span></li>' +
            '<li class="mb-2"><strong>Excerpt:</strong> <code>' + escapeHtml(excerptSelD) + '</code>' +
            ' <span class="badge bg-' + excerptStatusD + '">' + excerptTextD + '</span></li>' +
            '<li class="mb-2"><strong>Date:</strong> <code>' + escapeHtml(dateSelD) + '</code>' +
            ' <span class="badge bg-' + dateStatusD + '">' + dateTextD + '</span></li>' +
            '<li><strong>Author:</strong> <code>' + escapeHtml(authorSelD) + '</code>' +
            ' <span class="badge bg-' + authorStatusD + '">' + authorTextD + '</span></li>' +
            '</ul>';
    }
    selectorMatchesDiv.innerHTML = matchesHtml;
    
    // Display raw HTML
    rawHtmlDiv.textContent = data.rawHtml || 'No HTML retrieved';
    
    document.getElementById('previewResults').classList.remove('d-none');
}

function applyToForm() {
    if (!currentPreviewPreset) return;
    
    bootstrap.Modal.getInstance(document.getElementById('previewModal')).hide();
    editPreset(currentPreviewPreset.id);
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>
