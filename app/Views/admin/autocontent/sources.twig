{% extends 'admin/layout.twig' %}

{% block title %}AI Article Sources{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><i class="bi bi-rss me-2"></i>Content Sources</h4>
  <a href="/admin/autocontent/sources/create" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Add Source
  </a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>URL</th>
            <th>Type</th>
            <th>Category</th>
            <th>Interval</th>
            <th>Status</th>
            <th>Last Fetched</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for source in sources %}
          <tr>
            <td>{{ source.id }}</td>
            <td class="fw-semibold">{{ source.name }}</td>
            <td class="text-truncate small" style="max-width: 200px;" title="{{ source.url }}">
              <a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.url }}</a>
            </td>
            <td><span class="badge bg-info text-uppercase">{{ source.type }}</span></td>
            <td>{{ source.category_name ?? '-' }}</td>
            <td>{{ (source.fetch_interval / 60)|round }}m</td>
            <td>
              <a href="/admin/autocontent/sources/toggle?id={{ source.id }}" class="text-decoration-none"
                 title="Click to toggle">
                {% if source.is_active %}
                  <span class="badge bg-success">Active</span>
                {% else %}
                  <span class="badge bg-secondary">Inactive</span>
                {% endif %}
              </a>
            </td>
            <td class="small">
              {% if source.last_fetched_at %}
                {{ source.last_fetched_at|date('M d, H:i') }}
              {% else %}
                <span class="text-muted">Never</span>
              {% endif %}
            </td>
            <td>
              <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-success" title="Collect Now"
                        onclick="collectFromSource({{ source.id }}, '{{ source.name|escape('js') }}')">
                  <i class="bi bi-cloud-download"></i>
                </button>
                <button type="button" class="btn btn-outline-dark" title="Multi-Layer Scrape"
                        onclick="multiLayerScrape({{ source.id }}, '{{ source.name|escape('js') }}')">
                  <i class="bi bi-layers"></i>
                </button>
                <a href="/admin/autocontent/sources/edit?id={{ source.id }}" class="btn btn-outline-primary" title="Edit">
                  <i class="bi bi-pencil"></i>
                </a>
                <a href="/admin/autocontent/sources/delete?id={{ source.id }}" class="btn btn-outline-danger"
                   title="Delete" onclick="deleteSource({{ source.id }}, '{{ source.name|escape('js') }}'); return false;">
                  <i class="bi bi-trash"></i>
                </a>
              </div>
            </td>
          </tr>
          {% else %}
          <tr>
            <td colspan="9" class="text-center text-muted py-4">
              <i class="bi bi-rss fs-3 d-block mb-2"></i>
              No sources configured yet. Click "Add Source" to get started.
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
async function collectFromSource(sourceId, sourceName) {
  var confirmed = typeof window.showConfirm === 'function'
    ? await window.showConfirm(
        'This will collect articles from "' + sourceName + '". Continue?',
        'Collect Articles?',
        'info',
        {
          confirmButtonText: 'Collect',
          cancelButtonText: 'Cancel'
        }
      )
    : true;

  if (!confirmed) {
    return;
  }

  try {
    if (window.MessageHandler && typeof window.MessageHandler.showLoading === 'function') {
      await window.MessageHandler.showLoading('Fetching articles from ' + sourceName, 'Collecting...');
    }

    const response = await fetch('/admin/autocontent/api/collect-single?source_id=' + sourceId, {
      method: 'GET',
      headers: {
        'X-Requested-With': 'XMLHttpRequest'
      }
    });
    const data = await response.json();

    if (window.MessageHandler && typeof window.MessageHandler.hideLoading === 'function') {
      window.MessageHandler.hideLoading();
    }

    if (data.success) {
      if (typeof window.showAlert === 'function') {
        await window.showAlert(data.message || 'Articles collected successfully', 'Success', 'success');
      }
      window.location.reload();
      return;
    }

    if (typeof window.showAlert === 'function') {
      await window.showAlert(data.message || 'Failed to collect articles', 'Error', 'danger');
    }
  } catch (error) {
    console.error('Error:', error);
    if (window.MessageHandler && typeof window.MessageHandler.hideLoading === 'function') {
      window.MessageHandler.hideLoading();
    }
    if (typeof window.showAlert === 'function') {
      await window.showAlert('An error occurred while collecting articles', 'Error', 'danger');
    }
  }
}

async function multiLayerScrape(sourceId, sourceName) {
  var confirmed = typeof window.showConfirm === 'function'
    ? await window.showConfirm(
        'This will run the 5-step scraping pipeline on "' + sourceName + '". Steps: Fetch List -> Extract Links -> Loop Articles -> Fetch Page -> Extract Content.',
        'Multi-Layer Scrape?',
        'info',
        {
          confirmButtonText: 'Start Scraping',
          cancelButtonText: 'Cancel'
        }
      )
    : true;

  if (!confirmed) {
    return;
  }

  try {
    if (window.MessageHandler && typeof window.MessageHandler.showLoading === 'function') {
      await window.MessageHandler.showLoading('Running 5-step pipeline on ' + sourceName, 'Scraping in Progress...');
    }

    const response = await fetch('/admin/autocontent/api/collect-multi?source_id=' + sourceId, {
      method: 'GET',
      headers: {
        'X-Requested-With': 'XMLHttpRequest'
      }
    });
    const data = await response.json();

    if (window.MessageHandler && typeof window.MessageHandler.hideLoading === 'function') {
      window.MessageHandler.hideLoading();
    }

    if (data.success) {
      var message = data.message || 'Articles scraped successfully!';
      if (data.debug) {
        message += '\n\nResults:';
        message += '\n- Links Found: ' + (data.debug.links_found || 0);
        message += '\n- Articles Processed: ' + (data.debug.articles_processed || 0);
        message += '\n- Articles Queued: ' + (data.debug.articles_queued || 0);
        if (data.debug.errors && data.debug.errors.length > 0) {
          message += '\n- Errors: ' + data.debug.errors.length;
        }
      }

      if (typeof window.showAlert === 'function') {
        await window.showAlert(message, 'Success', 'success');
      }
      window.location.reload();
      return;
    }

    if (typeof window.showAlert === 'function') {
      await window.showAlert(data.message || 'Failed to scrape articles', 'Error', 'danger');
    }
  } catch (error) {
    console.error('Error:', error);
    if (window.MessageHandler && typeof window.MessageHandler.hideLoading === 'function') {
      window.MessageHandler.hideLoading();
    }
    if (typeof window.showAlert === 'function') {
      await window.showAlert('An error occurred while scraping articles', 'Error', 'danger');
    }
  }
}

async function deleteSource(sourceId, sourceName) {
  const result = typeof window.showConfirm === 'function'
    ? await window.showConfirm(
        'This will permanently delete "' + sourceName + '" and all its queued articles. This cannot be undone.',
        'Delete Source?',
        'danger',
        {
          confirmButtonText: 'Delete',
          cancelButtonText: 'Cancel'
        }
      )
    : true;

  if (result) {
    window.location.href = '/admin/autocontent/sources/delete?id=' + sourceId;
  }
}
</script>
{% endblock %}
