{# templates/admin/applications/index.twig #}
{% extends "admin/layout.twig" %}
{% set skip_auto_breadcrumb = true %}
{% block title %}Service Applications - Admin Panel{% endblock %}
{% block content %}
  <div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-file-earmark me-2"></i>
        Service Applications
      </div>
      <div class="admin-page-subtitle">Manage service applications</div>
    </div>
    <div class="d-flex justify-content-end mb-4">
      <a href="/admin/applications/export/csv"
         class="modern-btn modern-btn-white">
        <i class="bi bi-download"></i> Export CSV
      </a>
    </div>
    <!-- Statistics Cards -->
    <div class="row mb-4">
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card border-left-primary">
          <div class="admin-panel-card-body">
            <div class="d-flex justify-content-between">
              <div>
                <h6 class="text-primary">Total</h6>
                <h3>{{ stats.total }}</h3>
              </div>
              <i class="bi bi-file-earmark-text fs-1 text-primary opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card border-left-warning">
          <div class="admin-panel-card-body">
            <div class="d-flex justify-content-between">
              <div>
                <h6 class="text-warning">Pending</h6>
                <h3>{{ stats.pending }}</h3>
              </div>
              <i class="bi bi-hourglass-split fs-1 text-warning opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card border-left-info">
          <div class="admin-panel-card-body">
            <div class="d-flex justify-content-between">
              <div>
                <h6 class="text-info">Processing</h6>
                <h3>{{ stats.processing }}</h3>
              </div>
              <i class="bi bi-gear fs-1 text-info opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="admin-panel-card border-left-success">
          <div class="admin-panel-card-body">
            <div class="d-flex justify-content-between">
              <div>
                <h6 class="text-success">Approved</h6>
                <h3>{{ stats.approved }}</h3>
              </div>
              <i class="bi bi-check-circle fs-1 text-success opacity-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Filters -->
    <div class="admin-panel-card mb-4">
      <div class="admin-panel-card-body">
        <form method="GET" class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Status</label>
            <select name="status" class="form-select">
              <option value="">All Statuses</option>
              <option value="pending"
                      {% if filters.status == 'pending' %}selected{% endif %}>Pending</option>
              <option value="processing"
                      {% if filters.status == 'processing' %}selected{% endif %}>Processing</option>
              <option value="approved"
                      {% if filters.status == 'approved' %}selected{% endif %}>Approved</option>
              <option value="rejected"
                      {% if filters.status == 'rejected' %}selected{% endif %}>Rejected</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">From</label>
            <input type="date"
                   name="date_from"
                   class="form-control"
                   value="{{ filters.date_from ?? '' }}">
          </div>
          <div class="col-md-4">
            <label class="form-label">To</label>
            <input type="date"
                   name="date_to"
                   class="form-control"
                   value="{{ filters.date_to ?? '' }}">
          </div>
          <div class="col-12">
            <button type="submit" class="modern-btn modern-btn-primary">
              <i class="bi bi-funnel"></i> Filter
            </button>
            <a href="/admin/applications" class="modern-btn modern-btn-white">
              <i class="bi bi-arrow-clockwise"></i> Reset
            </a>
          </div>
        </form>
      </div>
    </div>
    <!-- Applications Table -->
    <div class="admin-panel-card">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>User</th>
              <th>Service</th>
              <th>Status</th>
              <th>Submitted</th>
              <th>Approver</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for app in applications %}
              <tr>
                <td>
                  <strong>#{{ app.id }}</strong>
                </td>
                <td>
                  {{ app.user_name }}
                  <br>
                  <small class="text-muted">{{ app.user_email }}</small>
                </td>
                <td>
                  <strong>{{ app.service_name }}</strong>
                </td>
                <td>
                  {% set status_colors = {"pending": "warning", "processing": "info", "approved": "success", "rejected": "danger"} %}
                  <span class="badge bg-{{ status_colors[app.status] }}">{{ app.status|title }}</span>
                </td>
                <td>
                  <small>{{ app.created_at|date("M d, Y") }}</small>
                </td>
                <td>
                  {% if app.approved_by_name %}
                    <small>{{ app.approved_by_name }}</small>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                <td>
                  <div class="modern-btn-group btn-group-sm" role="group">
                    <a href="/admin/applications/{{ app.id }}"
                       class="modern-btn modern-btn-white"
                       title="View">
                      <i class="bi bi-eye"></i>
                    </a>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="7" class="text-center py-4 text-muted">
                  <i class="bi bi-inbox fs-2 mb-2"></i>
                  <p>No applications found</p>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <!-- Pagination -->
      {% if total_pages > 1 %}
        <nav aria-label="Page navigation" class="admin-panel-card-footer">
          <ul class="pagination justify-content-center mb-0">
            {% if page > 1 %}
              <li class="page-item">
                <a class="page-link" href="?page={{ page - 1 }}">Previous</a>
              </li>
            {% endif %}
            {% for p in range(max(1, page - 2), min(total_pages, page + 2) + 1) %}
              <li class="page-item {% if p == page %}active{% endif %}">
                <a class="page-link" href="?page={{ p }}">{{ p }}</a>
              </li>
            {% endfor %}
            {% if page < total_pages %}
              <li class="page-item">
                <a class="page-link" href="?page={{ page + 1 }}">Next</a>
              </li>
            {% endif %}
          </ul>
        </nav>
      {% endif %}
    </div>
  </div>
{% endblock %}
