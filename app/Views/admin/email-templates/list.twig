{% extends "admin/layout.twig" %}
{% set breadcrumbs = auto_admin_breadcrumbs() %}
{% block content %}
  <div class="container-fluid py-4" data-email-template-list="true">
    <!-- Page Header -->
    <div class="admin-page-header mb-4">
      <div class="admin-page-title">
        <i class="bi bi-envelope-at me-2"></i>
        Email Templates
      </div>
      <div class="admin-page-subtitle">Manage email notification templates</div>
    </div>
    {% if templates|length > 0 %}
      <div class="admin-panel-card">
        <div class="admin-panel-card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Name</th>
                  <th>Slug</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Last Updated</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for template in templates %}
                  <tr>
                    <td>
                      <strong>{{ template.name }}</strong>
                    </td>
                    <td>
                      <code class="bg-light">{{ template.slug }}</code>
                    </td>
                    <td>
                      <small class="text-muted">{{ template.description|default("N/A") |truncate(50) }}</small>
                    </td>
                    <td>
                      {% if template.is_active %}
                        <span class="badge bg-success">Active</span>
                      {% else %}
                        <span class="badge bg-secondary">Inactive</span>
                      {% endif %}
                    </td>
                    <td>
                      <small class="text-muted">{{ template.updated_at|date("M d, Y H:i") }}</small>
                    </td>
                    <td>
                      <a href="{{ admin_dir }}/email-templates/{{ template.id }}/edit"
                         class="modern-btn btn-sm btn-primary">
                        <i class="bi bi-pencil"></i> Edit
                      </a>
                      {% if template.slug not in ['welcome_email', 'email_verification', 'password_reset'] %}
                        <button class="modern-btn btn-sm btn-danger"
                                onclick="deleteTemplate({{ template.id }}, '{{ template.name }}')">
                          <i class="bi bi-trash"></i> Delete
                        </button>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    {% else %}
      <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No email templates found.
      </div>
    {% endif %}
  </div>
{% endblock %}
