{% extends "layout.twig" %}
{% block title %}{{ post.title }} | {{ app_settings.site_name|default("BroxBhai") }}{% endblock %}
{% set breadcrumbs = [
  { label: 'Articles', url: '/posts', icon: 'newspaper' },
  { label: post.title|slice(0, 40) ~ (post.title|length > 40 ? '...' : ''), icon: 'file-text' }
] %}
{% block content %}
  {# Structured Data - Article Schema #}
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ post.title|json_encode }},
  "description": {{ post.content|striptags|slice(0, 160)|json_encode }},
  "image": {{
    post.featured_image
      |default(post.image|default(app_settings.site_logo|default(url ~ 'assets/images/default-image.png')))
      |json_encode
  }},
  "datePublished": "{{ post.created_at|date('Y-m-d\\TH:i:s\\Z') }}",
  {% if post.updated_at %}"dateModified": "{{ post.updated_at|date('Y-m-d\\TH:i:s\\Z') }}",{% endif %}
  "author": {
    "@type": "Person",
    "name": {{ post.author|json_encode }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ app_settings.site_name|json_encode }},
    "logo": {
      "@type": "ImageObject",
    "url": "{{ app_settings.site_logo|default(url ~ 'assets/images/default-logo.png') }}"
    }
  }
}
  </script>
  {# Hero Header Section #}
  <section class="position-relative overflow-hidden mb-5 inl-p-0052">
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10"
         aria-hidden="true">
      <div class="position-absolute inl-p-0049"></div>
      <div class="position-absolute inl-p-0050"></div>
    </div>
    <div class="container position-relative">
      <div class="row align-items-center">
        <div class="col-lg-8">
          <h1 class="display-5 fw-bold mb-3 text-shadow-lg">{{ post.title }}</h1>
          {# Author & Meta Information #}
          <div class="d-flex flex-wrap gap-3 mb-3">
            <div class="d-flex align-items-center text-white">
              <img src="/assets/images/default-avatar.png"
                   alt="{{ post.author }}"
                   class="rounded-circle me-2 inl-p-0053"
                   loading="lazy">
              <span class="fw-semibold">{{ post.author }}</span>
            </div>
            {% if post.created_at %}
              <div class="text-white">
                <i class="bi bi-calendar-check me-1"></i>
                <time datetime="{{ post.created_at|date("Y-m-d") }}">
                  {{ post.created_at|date("F d, Y") }}
                </time>
              </div>
            {% endif %}
            <div class="text-white">
              <i class="bi bi-eye-fill me-1"></i>
              {{ post.views|number_format }} views
            </div>
            <div class="text-white">
              <i class="bi bi-bar-chart-fill me-1"></i>
              {{ post.impressions|number_format }} impressions
            </div>
          </div>
          {# Categories & Tags #}
          <div class="d-flex flex-wrap gap-2">
            {% if post.categories %}
              {% for cat in post.categories %}
                <a href="/category/{{ cat.slug }}"
                   class="badge bg-white text-primary text-decoration-none px-3 py-2 rounded-pill">
                  <i class="bi bi-folder-fill me-1"></i>{{ cat.name }}
                </a>
              {% endfor %}
            {% endif %}
            {% if post.tags %}
              {% for tag in post.tags %}
                <a href="/tag/{{ tag.slug }}"
                   class="badge bg-white bg-opacity-75 text-theme-strong text-decoration-none px-3 py-2 rounded-pill">
                  <i class="bi bi-tag-fill me-1"></i>{{ tag.name }}
                </a>
              {% endfor %}
            {% endif %}
          </div>
        </div>
        <div class="col-lg-4 text-center text-lg-end mt-4 mt-lg-0">
          <div class="d-inline-block p-4 bg-white bg-opacity-10 rounded-circle">
            <i class="bi bi-newspaper text-white inl-p-0002"></i>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="container pb-5">
    {# Quick Access Panel #}
    {% include 'partials/quick-access.twig' with { context_type: 'post', context_id: post.id } %}
    <div class="row g-4">
      {# Main Content Column #}
      <div class="col-lg-8">
        {# Post Content Card #}
        <article class="card border-0 shadow-sm rounded-4 mb-4">
          <div class="card-body p-4 p-md-5">
            <div class="content-wrapper fs-6 lh-lg">{{ post.content|raw }}</div>
          </div>
        </article>
        {% include 'partials/content-rating.twig' with { content_type: 'post', content_id: post.id } %}
        {# Author Info Card #}
        <aside class="card border-0 shadow-sm rounded-4 mb-4"
               aria-labelledby="author-info">
          <div class="card-body p-4">
            <div class="d-flex align-items-center">
              <div class="position-relative me-3">
                <img src="/assets/images/default-avatar.png"
                     alt="{{ post.author }}"
                     class="rounded-circle inl-p-0054"
                     loading="lazy">
                <div class="position-absolute bottom-0 end-0 bg-success rounded-circle inl-p-0055"
                     title="Active author"></div>
              </div>
              <div class="flex-grow-1">
                <h2 id="author-info" class="mb-1 fw-bold h5">{{ post.author }}</h2>
                <p class="text-muted mb-2 small">
                  <i class="bi bi-pen me-1"></i>Article Author
                </p>
                <p class="text-muted mb-0 small">
                  Published on <time datetime="{{ post.created_at|date("Y-m-d") }}">{{ post.created_at|date("F d, Y") }}</time>
                </p>
              </div>
              <div>
                <button class="btn btn-outline-primary btn-sm rounded-pill" type="button">
                  <i class="bi bi-person-plus me-1"></i>Follow
                </button>
              </div>
            </div>
          </div>
        </aside>
        {# Share Section #}
        <div class="mb-4">
          {% include 'partials/share.twig' with {
            url: current_url,
            title: post.title,
            description: post.content|striptags|slice(0, 100)
          } %}
        </div>
        {# Previous / Next Navigation #}
        <nav class="card border-0 shadow-sm rounded-4 mb-4"
             aria-label="Post navigation">
          <div class="card-body p-3">
            <div class="row g-2">
              <div class="col-6">
                {% if previousPost %}
                  <a href="/posts/view/{{ previousPost.url }}"
                     class="btn btn-outline-primary w-100 rounded-pill"
                     aria-label="Previous post: {{ previousPost.title }}">
                    <i class="bi bi-arrow-left me-2"></i>
                    <span class="d-none d-md-inline">Previous</span>
                  </a>
                {% else %}
                  <button class="btn btn-outline-secondary w-100 rounded-pill" disabled>
                    <i class="bi bi-arrow-left me-2"></i>
                    <span class="d-none d-md-inline">Previous</span>
                  </button>
                {% endif %}
              </div>
              <div class="col-6">
                {% if nextPost %}
                  <a href="/posts/view/{{ nextPost.url }}"
                     class="btn btn-outline-primary w-100 rounded-pill"
                     aria-label="Next post: {{ nextPost.title }}">
                    <span class="d-none d-md-inline">Next</span>
                    <i class="bi bi-arrow-right ms-2"></i>
                  </a>
                {% else %}
                  <button class="btn btn-outline-secondary w-100 rounded-pill" disabled>
                    <span class="d-none d-md-inline">Next</span>
                    <i class="bi bi-arrow-right ms-2"></i>
                  </button>
                {% endif %}
              </div>
            </div>
          </div>
        </nav>
        {# Comments Section #}
        <section id="comments-wrapper" class="mb-4" aria-labelledby="comments-title">
          <h2 id="comments-title" class="visually-hidden">Comments Section</h2>
          {% include 'comments/comments.twig' with { content_type: 'post', content_id: post.id, comments: comments } %}
        </section>
        {# Related Articles Section #}
        {% include 'partials/related-section.twig' with {
          items: relatedPosts,
          title: 'Related Articles',
          type: 'post',
          gradient: 'linear-gradient(135deg, #1417f1 0%, #8b5cf6 100%)',
          view_all_url: '/posts',
          id: 'related-articles-title',
          variant: 'pro'
        } %}
      </div>
      {# Sidebar #}
      <aside class="col-lg-4" role="complementary" aria-label="Sidebar">
        <div>
          {# Quick Navigation #}
          <nav class="card border-0 shadow-sm rounded-4 mb-4"
               aria-labelledby="quick-nav-title">
            <div class="card-header bg-primary p-3 border-0">
              <h2 id="quick-nav-title" class="mb-0 h6 fw-bold">
                <i class="bi bi-list-ul me-2"></i>Quick Navigation
              </h2>
            </div>
            <div class="card-body p-3">
              <ul class="list-unstyled mb-0 small">
                <li class="mb-2">
                  <a href="#comments-wrapper"
                     class="text-decoration-none d-flex align-items-center p-2 rounded hover-bg-light">
                    <i class="bi bi-chat-dots me-2 text-primary"></i>
                    <span>Comments</span>
                  </a>
                </li>
                {% if relatedPosts %}
                  <li class="mb-2">
                    <a href="#related-articles-title"
                       class="text-decoration-none d-flex align-items-center p-2 rounded hover-bg-light">
                      <i class="bi bi-link-45deg me-2 text-primary"></i>
                      <span>Related Articles</span>
                    </a>
                  </li>
                {% endif %}
                <li class="mb-0">
                  <a href="/posts"
                     class="text-decoration-none d-flex align-items-center p-2 rounded hover-bg-light">
                    <i class="bi bi-grid-3x3-gap me-2 text-secondary"></i>
                    <span>All Articles</span>
                  </a>
                </li>
              </ul>
            </div>
          </nav>
          {# Popular Articles #}
          {% if popularPosts and popularPosts|length > 0 %}
            <section class="card border-0 shadow-sm rounded-4 mb-4"
                     aria-labelledby="popular-title">
              <div class="card-header bg-success p-3 border-0">
                <h2 id="popular-title" class="mb-0 h6 fw-bold">
                  <i class="bi bi-fire me-2"></i>Popular Articles
                </h2>
              </div>
              <div class="card-body p-3">
                <ul class="list-unstyled mb-0">
                  {% for pp in popularPosts|slice(0, 5) %}
                    <li class="mb-3 {% if not loop.last %}pb-3 border-bottom{% endif %}">
                      <a href="/posts/view/{{ pp.url }}"
                         class="text-decoration-none text-theme-strong hover-text-primary d-block"
                         aria-label="Read popular article: {{ pp.title }}">
                        <h3 class="h6 fw-semibold mb-1 line-clamp-2">{{ pp.title }}</h3>
                      </a>
                      <div class="small text-muted d-flex align-items-center gap-3">
                        <span>
                          <i class="bi bi-eye-fill me-1"></i>{{ pp.views|number_format }}
                        </span>
                        <span>
                          <i class="bi bi-calendar3 me-1"></i>{{ pp.created_at|date("M d") }}
                        </span>
                      </div>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </section>
          {% endif %}
          {# Categories Widget #}
          {% if post.categories and post.categories|length > 0 %}
            <section class="card border-0 shadow-sm rounded-4 mb-4"
                     aria-labelledby="categories-title">
              <div class="card-header bg-warning p-3 border-0">
                <h2 id="categories-title" class="mb-0 h6 fw-bold">
                  <i class="bi bi-folder-fill me-2"></i>Categories
                </h2>
              </div>
              <div class="card-body p-3">
                <div class="d-flex flex-wrap gap-2">
                  {% for cat in post.categories %}
                    <a href="/category/{{ cat.slug }}"
                       class="badge bg-light text-surface-dark p-2 text-decoration-none rounded-pill hover-bg-warning">
                      <i class="bi bi-folder-open me-1"></i>{{ cat.name }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            </section>
          {% endif %}
          {# Tags Cloud #}
          {% if post.tags and post.tags|length > 0 %}
            <section class="card border-0 shadow-sm rounded-4 mb-4"
                     aria-labelledby="tags-title">
              <div class="card-header bg-info p-3 border-0">
                <h2 id="tags-title" class="mb-0 h6 fw-bold">
                  <i class="bi bi-tags-fill me-2"></i>Tags
                </h2>
              </div>
              <div class="card-body p-3">
                <div class="d-flex flex-wrap gap-2">
                  {% for tag in post.tags %}
                    <a href="/tag/{{ tag.slug }}"
                       class="badge bg-light text-surface-dark p-2 text-decoration-none rounded-pill hover-bg-info">
                      <i class="bi bi-tag me-1"></i>{{ tag.name }}
                    </a>
                  {% endfor %}
                </div>
              </div>
            </section>
          {% endif %}
          {# Article Stats Card #}
          <section class="card border-0 shadow-sm rounded-4"
                   aria-labelledby="stats-title">
            <div class="card-header bg-gradient p-3 border-0 inl-p-0051">
              <h2 id="stats-title" class="mb-0 h6 fw-bold">
                <i class="bi bi-graph-up me-2"></i>Article Statistics
              </h2>
            </div>
            <div class="card-body p-3">
              <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-between">
                  <span class="text-muted small">
                    <i class="bi bi-eye-fill text-primary me-1"></i>Views
                  </span>
                  <span class="fw-bold">{{ post.views|number_format }}</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <span class="text-muted small">
                    <i class="bi bi-bar-chart-fill text-success me-1"></i>Impressions
                  </span>
                  <span class="fw-bold">{{ post.impressions|number_format }}</span>
                </div>
                {% if post.created_at %}
                  <div class="d-flex align-items-center justify-content-between">
                    <span class="text-muted small">
                      <i class="bi bi-calendar-check text-info me-1"></i>Published
                    </span>
                    <span class="fw-bold small">{{ post.created_at|date("M d, Y") }}</span>
                  </div>
                {% endif %}
                <div class="d-flex align-items-center justify-content-between">
                  <span class="text-muted small">
                    <i class="bi bi-clock-fill text-warning me-1"></i>Read Time
                  </span>
                  <span class="fw-bold small">{{ ((post.content|striptags|length / 1000)|round)|default(1) }} min</span>
                </div>
              </div>
            </div>
          </section>
        </div>
      </aside>
    </div>
  </div>
  {# JavaScript #}
  <script>
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            const targetId = this.getAttribute('href');
            if (targetId === '#') return;

            const targetElement = document.querySelector(targetId);
            if (targetElement) {
                e.preventDefault();
                targetElement.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });

                // Update focus for accessibility
                targetElement.setAttribute('tabindex', '-1');
                targetElement.focus();
            }
        });
    });

    // Add external link icons and attributes
    document.querySelectorAll('.content-wrapper a[href^="http"]').forEach(link => {
        // Don't modify if it's an internal link
        if (!link.href.includes(window.location.hostname)) {
            link.setAttribute('target', '_blank');
            link.setAttribute('rel', 'noopener noreferrer');
            link.innerHTML += ' <i class="bi bi-box-arrow-up-right small"></i>';
        }
    });

    // Add reading progress bar
    const addReadingProgress = () => {
        const progressBar = document.createElement('div');
        progressBar.id = 'reading-progress';
        progressBar.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, #6366f1, #8b5cf6);
            width: 0%;
            z-index: 9999;
            transition: width 0.1s ease;
        `;
        document.body.appendChild(progressBar);

        window.addEventListener('scroll', () => {
            const windowHeight = window.innerHeight;
            const documentHeight = document.documentElement.scrollHeight;
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const scrollPercent = (scrollTop / (documentHeight - windowHeight)) * 100;
            progressBar.style.width = scrollPercent + '%';
        });
    };

    addReadingProgress();
  </script>
{% endblock %}
