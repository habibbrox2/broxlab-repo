{% extends "layout.twig" %}
{% block title %}Latest Articles & Posts - {{ app_settings.site_name|default("Mobile Updates") }}{% endblock %}
{% set breadcrumbs = [{"label": "Articles", "url": "/posts", "icon": "newspaper"}] %}
{% block content %}
  {# Structured Data - Collection Page Schema #}
  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "{{ title|default('Articles')|json }}",
  "description": "Browse our latest articles, posts, and tech insights",
  "url": "{{ current_url }}"
}
  </script>
  {# Hero Section #}
  <section class="hero-section position-relative py-5 mb-5 overflow-hidden inl-p-0014">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <h1 class="display-4 fw-bold text-white mb-3">
            <i class="bi bi-newspaper me-2"></i>Latest Articles
          </h1>
          <p class="lead text-white-50 fs-5">Stay updated with our latest news, insights, and in-depth articles</p>
        </div>
        <div class="col-lg-4 text-center">
          <div class="hero-icon inl-p-0002">📰</div>
        </div>
      </div>
    </div>
  </section>
  <div class="container py-5">
    <!-- Page Header -->
    <div class="listing-header">
      <h2>
        <i class="bi bi-newspaper text-primary me-2"></i>{{ title }}
      </h2>
    </div>
    <!-- Filter Card -->
    <div class="filter-card">
      <div class="filter-group">
        <!-- Search -->
        <div class="filter-section inl-p-0008">
          <form method="get" class="inl-p-0009">
            <input type="text"
                   name="search"
                   value="{{ search|default("") }}"
                   class="search-input"
                   placeholder="Search posts...">
            <button type="submit" class="btn-search">
              <i class="bi bi-search"></i>
            </button>
          </form>
        </div>
        <!-- Per Page -->
        <div class="filter-section">
          <label>Per Page</label>
          <form method="get">
            <select name="per_page" class="filter-select" onchange="this.form.submit()">
              {% for opt in available_per_page|default([6, 12, 18, 24, 36, 60]) %}
                <option value="{{ opt }}" {% if per_page == opt %}selected{% endif %}>{{ opt }}</option>
              {% endfor %}
            </select>
          </form>
        </div>
        <!-- Sort -->
        <div class="filter-section">
          <label>Sort By</label>
          <form method="get">
            <select name="sort" class="filter-select" onchange="this.form.submit()">
              <option value="latest" {% if sort == 'latest' %}selected{% endif %}>Latest</option>
              <option value="oldest" {% if sort == 'oldest' %}selected{% endif %}>Oldest</option>
              <option value="views" {% if sort == 'views' %}selected{% endif %}>Most Views</option>
              <option value="impressions" {% if sort == 'impressions' %}selected{% endif %}>Most Impressions</option>
            </select>
          </form>
        </div>
      </div>
    </div>
    <!-- Posts Grid -->
    {% if posts is not empty %}
      <div class="listing-grid">
        {% for post in posts %}
          {% include 'partials/content-card.twig' with { item: {
          images: post.images|default([]),
          image: post.image|default(post.thumbnail|default(post.image_path|default(null))),
          title: post.title|default('Untitled'),
          subtitle: post.excerpt|default(post.content|default('')|striptags|slice(0, 120) ~ '...'),
          categories: post.categories|default([]),
          tags: post.tags|default([]),
          created_at: post.created_at|default(''),
          url: post.slug|default(post.slug|default(post.id)),
          id: post.id,
          type: 'post',
          impressions: post.impressions|default(0),
          views: post.views|default(0)
          }, index: loop.index } %}
        {% endfor %}
      </div>
      <!-- Pagination -->
      {% if total_pages > 1 %}
        <div class="pagination-container">
          <div class="pagination">
            {% if current_page > 1 %}
              <a class="pagination-link"
                 href="?page={{ current_page - 1 }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}"
                 aria-label="Previous">
                <i class="bi bi-chevron-left"></i>
              </a>
            {% else %}
              <span class="pagination-link disabled"><i class="bi bi-chevron-left"></i></span>
            {% endif %}
            {% for p in 1..total_pages %}
              <a class="pagination-link {% if p == current_page %}active{% endif %}"
                 href="?page={{ p }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}">{{ p }}</a>
            {% endfor %}
            {% if current_page < total_pages %}
              <a class="pagination-link"
                 href="?page={{ current_page + 1 }}&search={{ search|default("") }}&sort={{ sort|default("latest") }}&order={{ order|default("DESC") }}&per_page={{ per_page|default(12) }}"
                 aria-label="Next">
                <i class="bi bi-chevron-right"></i>
              </a>
            {% else %}
              <span class="pagination-link disabled"><i class="bi bi-chevron-right"></i></span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% else %}
      <div class="empty-state">
        <i class="bi bi-newspaper"></i>
        <h3>No posts found</h3>
        <p>Try adjusting your search criteria</p>
      </div>
    {% endif %}
  </div>
{% endblock %}
