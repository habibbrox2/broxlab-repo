# BroxLab / BroxBhai - Environment Variables (Example)
# Copy to `.env` and fill real values. Do NOT commit `.env`.
#
# IMPORTANT:
# - Do not put inline comments after values (phpdotenv will treat them as part of the value).
#   Good:  APP_ENV=production
#   Bad:   APP_ENV=production  # comment

# ============================================================================
# Application
# ============================================================================
APP_NAME=BroxLab
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_DOMAIN=example.com
APP_TIMEZONE=Asia/Dhaka
MAINTENANCE_MODE=0

# ============================================================================
# Database
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_PREFIX=bb_

# ============================================================================
# Mail (optional)
# ============================================================================
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=BroxLab

# ============================================================================
# JWT / API
# ============================================================================
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# ============================================================================
# Deploy Tools UI (dev-only)
# ============================================================================
# This UI is dev-only by design. Enable only on trusted environments.
DEPLOY_TOOLS_UI_ENABLED=0

# ============================================================================
# GitHub Webhook (admin actions)
# ============================================================================
# Admin actions are the `action=status|versions|rollback` endpoints on `public_html/webhook/github.php`.
# Keep disabled in production by default; enable only if you need remote status/rollback.
WEBHOOK_ADMIN_ACTIONS_ENABLED=0

# If true, allow server-side auto-deploy execution from webhook when `webhook_auto_deploy=1` in DB settings.
WEBHOOK_AUTO_DEPLOY_ALLOWED=0

# Optional: override backup directory (MUST be outside web root)
# Default is `<repo_root>/storage/backups/webhook`
WEBHOOK_BACKUP_DIR=

# ============================================================================
# Local Push Deploy (scripts/*.ps1, scripts/*.sh)
# ============================================================================
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PORT=22
DEPLOY_REMOTE_PATH=

# Prefer a key path instead of embedding a private key in `.env`.
DEPLOY_SSH_KEY_PATH=

# Legacy (not recommended): embed key contents directly in `.env`
DEPLOY_SSH_KEY=

# How many old releases to keep on the remote (folders like `...__old_YYYYMMDD_HHMMSS`)
DEPLOY_KEEP_OLD_RELEASES=5

# ============================================================================
# Optional: DB Transfer (scripts/db_transfer.*)
# ============================================================================
DEPLOY_REMOTE_DB_HOST=localhost
DEPLOY_REMOTE_DB_PORT=3306
DEPLOY_REMOTE_DB_NAME=
DEPLOY_REMOTE_DB_USER=
DEPLOY_REMOTE_DB_PASS=

