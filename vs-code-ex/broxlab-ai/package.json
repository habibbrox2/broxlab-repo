{
    "name": "broxlab-ai",
    "displayName": "BroxLab AI",
    "description": "Autonomous coding assistant using OpenRouter",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Machine Learning",
        "Chat"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "broxlab-activitybar",
                    "title": "BroxLab AI",
                    "icon": "$(sparkle)"
                }
            ]
        },
        "views": {
            "broxlab-activitybar": [
                {
                    "type": "webview",
                    "id": "broxlab.chatView",
                    "name": "Chat & Settings",
                    "icon": "$(sparkle)"
                }
            ]
        },
        "commands": [
            {
                "command": "broxlab.setApiKey",
                "title": "BroxLab AI: Set OpenRouter API Key"
            },
            {
                "command": "broxlab.openSettings",
                "title": "BroxLab AI: Open Settings"
            },
            {
                "command": "broxlab.moveToSecondarySideBar",
                "title": "Move to Secondary Side Bar",
                "icon": "$(layout-sidebar-right)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "broxlab.moveToSecondarySideBar",
                    "when": "view == broxlab.chatView",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "BroxLab AI",
            "properties": {
                "broxlab.defaultModel": {
                    "type": "string",
                    "default": "anthropic/claude-3.7-sonnet",
                    "description": "Default OpenRouter model to use (e.g., anthropic/claude-3.7-sonnet)"
                },
                "broxlab.customPrompt": {
                    "type": "string",
                    "default": "Generate an enhanced version of this prompt (reply with only the enhanced prompt - no conversation, explanations, lead-in, bullet points, placeholders, or surrounding quotes): ${userInput}",
                    "description": "A template to enhance or wrap your prompt before sending it to the AI. Use ${userInput} as a placeholder."
                },
                "broxlab.approvalMode": {
                    "type": "string",
                    "enum": [
                        "Auto Approve",
                        "Ask Every Time",
                        "Ask Once Per Session"
                    ],
                    "default": "Ask Every Time",
                    "description": "Configure when the agent should ask for confirmation before modifying files or executing commands."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@types/node": "20.x",
        "@types/vscode": "^1.90.0",
        "typescript": "^5.x"
    }
}