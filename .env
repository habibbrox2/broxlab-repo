# Project name
# Local development server port
# Database backup directory (relative path)
# ============================================================================
# Multi-Location Branch Configuration
# ============================================================================
# Choose which location/branch you're working from: home OR office
# This is used to safely sync code between locations
# Branch names for each location
# ডাল নোট: শুধু main branch ব্যবহার করুন safe থাকার জন্য
# যদি এডভান্সড user হন তাহলে branch ব্যবহার করতে পারেন:
# WORK_LOCATION=home   =>  git checkout home
# WORK_LOCATION=office =>  git checkout office
PROJECT_NAME=broxlab
WORK_LOCATION=home
BRANCH_HOME=home
BRANCH_OFFICE=office
LOCAL_SERVER_PORT=8000
DB_BACKUP_DIR=./Database/backups
# ============================================================================
# JWT Configuration (if used for API authentication)
# ============================================================================
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400
