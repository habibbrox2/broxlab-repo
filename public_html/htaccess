<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Fix Multiple Slashes (//) - লুপ ছাড়া নিখুঁত ক্লিনআপ
    RewriteCond %{THE_REQUEST} \s[^?]*//
    RewriteRule ^.*$ /$0 [R=301,L,NE]

    # 2. Force HTTPS and Non-WWW (SEO এর জন্য এটি সক্রিয় করা উচিত)
    # নিচে আপনার ডোমেইন নাম বসিয়ে কমেন্ট (#) সরিয়ে দিতে পারেন
    # RewriteCond %{HTTPS} off [OR]
    # RewriteCond %{HTTP_HOST} ^www\. [NC]
    # RewriteRule ^(.*)$ https://example.com/$1 [L,R=301]

    # 3. Handle Trailing Slash (ডিরেক্টরি না হলে স্ল্যাশ রিমুভ)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/assets/ [NC]
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]

    # 4. Front Controller (ফাইল না থাকলে index.php তে পাঠানো)
    RewriteCond %{REQUEST_URI} !^/assets/ [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ---------------- Browser Caching & Gzip Compression ----------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Gzip Compression যোগ করা হলো (পেজ দ্রুত লোড হওয়ার জন্য)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# ---------------- Security ----------------
Options -Indexes
# ফাইল এডিটিং বা পিএইচপি এক্সিকিউশন সিকিউরিটি (ঐচ্ছিক)
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# ---------------- PHP 8.2 Handler ----------------
<IfModule mime_module>
    AddHandler application/x-httpd-ea-php82 .php .php8 .phtml
</IfModule>