# Dependencies
/vendor/
/node_modules/


# Environment variables (keep example files)
.env
.env.*
!.env.example
!.env.sample

# Logs & cache
*.log
/logs/
/cache/
/storage/logs/
/storage/cache/
/storage/tmp/
/storage/backups/
/storage/logs/deploy_jobs/
.tmp.*

# Uploads (user-generated content)
/uploads/
/public_html/uploads/
/public_html/assets/uploads/

# Build artifacts
/build/
**/dist**/
/\.deploy/

# Database dumps/backups
/Database/
/*.sql
db.sql

# Secrets / service configs
/Config/broxlab-firebase.json

# IDE / OS
/.vscode/
/.idea/
.DS_Store
Thumbs.db


# Archives
*.zip

# ============================================
# Deployment related (for development only)
# ============================================

# Temporary deployment scripts generated by the system
/deploy_*.ps1
/deploy_*.sh
/deploy_*.bat
/deploy_*.cmd

# Lock files for deployment
/deploy_lock.json
/deploy_ratelimit_*.json

# Progress files
/deploy_progress_*.json

# Backup files created during deployment
/backups/
public_html/backups/

# Deploy worker logs
/deploy_worker*.log

# Webhook configurations (can contain sensitive data)
public_html/webhook/config.php
public_html/webhook/settings.php

# ===========================================
# Scripts folder - Keep core scripts, ignore generated
# ===========================================

# Ignore output files but keep core scripts
scripts/output/
scripts/temp/
scripts/logs/

# IDE specific in scripts
scripts/.idea/
scripts/.vscode/
