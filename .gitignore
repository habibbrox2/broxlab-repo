# ═══════════════════════════════════════════════════════════════════╗
# ║                    PROJECT .gitignore                            ║
# ║          GitHub Webhook → Enterprise Auto Deploy System          ║
# ═══════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────
#  1. DEPENDENCIES
# ─────────────────────────────────────────────────────────────────
/vendor/
/node_modules/

# ─────────────────────────────────────────────────────────────────
#  2. ENVIRONMENT & SECRETS
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample

# Firebase & Service Configs (secrets)
/Config/broxlab-firebase.json

# ─────────────────────────────────────────────────────────────────
#  3. LOGS & CACHE (development only)
# ─────────────────────────────────────────────────────────────────
*.log
/logs/
/cache/
/storage/logs/
/storage/cache/
/storage/tmp/
/storage/backups/
/storage/logs/deploy_jobs/
.tmp.*

# ─────────────────────────────────────────────────────────────────
#  4. USER UPLOADS (keep schema, ignore content)
# ─────────────────────────────────────────────────────────────────
/uploads/
/public_html/uploads/
/public_html/assets/uploads/

# ─────────────────────────────────────────────────────────────────
#  5. BUILD ARTIFACTS
# ─────────────────────────────────────────────────────────────────
/build/
**/dist/
/.deploy/

# ─────────────────────────────────────────────────────────────────
#  6. IDE & OS FILES
# ─────────────────────────────────────────────────────────────────
/.vscode/
/.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────
#  7. ARCHIVES
# ─────────────────────────────────────────────────────────────────
*.zip

# ═══════════════════════════════════════════════════════════════════╗
# ║              DEPLOYMENT SYSTEM (GitHub Webhook)                 ║
# ═══════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────
# Deployment Directories (Generated at runtime)
# ─────────────────────────────────────────────────────────────────
/deploys/                          # All deployment releases & cache
/deploy_lock
/deploy.last
sys_temp_dir/deploy*               # Temp lock files

# ─────────────────────────────────────────────────────────────────
# Deployment Config Files (contains secrets - DO NOT COMMIT)
# ─────────────────────────────────────────────────────────────────
scripts/.deploy-config
.deploy-config

# ─────────────────────────────────────────────────────────────────
# Webhook Core Files (TRACKED - very important!)
# ─────────────────────────────────────────────────────────────────
public_html/github.php
public_html/deploy_config.php

version_file.json                   # Version tracking (generated at runtime)

# ─────────────────────────────────────────────────────────────────
# Database Schema (TRACKED - required for git)
# ─────────────────────────────────────────────────────────────────
!Database/
!Database/*.sql

# Database Backups (generated during deploy, not tracked)
/Database/backups/
*.sql.backup

# ─────────────────────────────────────────────────────────────────
# Migrations (TRACKED - required for git)
# ─────────────────────────────────────────────────────────────────
!migrations/
!migrations/*.sql

# Migration status tracking (generated at runtime)
/migrations/.status

# ─────────────────────────────────────────────────────────────────
# SCRIPTS FOLDER
# ─────────────────────────────────────────────────────────────────
/scripts/output/
/scripts/temp/
/scripts/logs/
/scripts/.idea/
/scripts/.vscode/

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
/Database/
db.sql

# ─────────────────────────────────────────────────────────────────
# Composer
# ─────────────────────────────────────────────────────────────────
composer.lock
package-lock.json

# ═══════════════════════════════════════════════════════════════════╗
# ║              Local development files                             ║
# ═══════════════════════════════════════════════════════════════════╝
.DS_Store
/tmp/
/temp/
